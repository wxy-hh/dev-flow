#!/usr/bin/env bash
# 生成审查包：提交列表、统计摘要和带上下文的净 diff。
# 审查者一次读取该文件即可完成任务级审查。
# 使用记录的任务 BASE（而不是 HEAD~1）可以保留多提交任务的完整差异。
#
# 除 BASE..HEAD 的已提交 diff 外，还附加当前工作区的 staged / unstaged /
# untracked 清单，满足完整审查输入要求。
#
# 用法：
#   review-package BASE HEAD --feature FEATURE_ID [OUTFILE]
#   DEV_FLOW_FEATURE_ID=... review-package BASE HEAD [OUTFILE]
#
# 默认 OUTFILE：feature-scoped SDD workspace 下的
# review-<base7>..<head7>.diff。不读取 legacy shared SDD。
set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)

if [ $# -lt 2 ]; then
  echo "用法: review-package BASE HEAD --feature FEATURE_ID [OUTFILE]" >&2
  exit 2
fi

base=$1
head=$2
shift 2

feature_id=${DEV_FLOW_FEATURE_ID:-}
out=""
while [ $# -gt 0 ]; do
  case "$1" in
    --feature)
      feature_id=${2:-}
      shift 2
      ;;
    --help|-h)
      echo "用法: review-package BASE HEAD --feature FEATURE_ID [OUTFILE]"
      exit 0
      ;;
    -*)
      echo "未知参数: $1" >&2
      exit 2
      ;;
    *)
      if [ -z "$out" ]; then
        out=$1
        shift
      else
        echo "多余参数: $1" >&2
        exit 2
      fi
      ;;
  esac
done

case "$base" in -*) echo "无效 BASE: $base" >&2; exit 2 ;; esac
case "$head" in -*) echo "无效 HEAD: $head" >&2; exit 2 ;; esac
base_sha=$(git rev-parse --verify --quiet "${base}^{commit}") \
  || { echo "无效 BASE: $base" >&2; exit 2; }
head_sha=$(git rev-parse --verify --quiet "${head}^{commit}") \
  || { echo "无效 HEAD: $head" >&2; exit 2; }
if ! printf '%s\n' "$base_sha" | rg -q '^[0-9a-f]{40,64}$' \
  || ! printf '%s\n' "$head_sha" | rg -q '^[0-9a-f]{40,64}$'; then
  echo "BASE/HEAD 未解析为 commit hash" >&2
  exit 2
fi

if [ -z "$feature_id" ]; then
  echo "缺少 --feature FEATURE_ID（或 DEV_FLOW_FEATURE_ID）；v0.8 要求 feature-scoped SDD" >&2
  exit 2
fi
dir=$("$SCRIPT_DIR/sdd-workspace" "$feature_id")

if [ -z "$out" ]; then
  out="$dir/review-$(git rev-parse --short "$base_sha")..$(git rev-parse --short "$head_sha").diff"
fi

requested_out=$out
if ! out=$(node -e '
  const fs=require("fs");
  const path=require("path");
  const workspace=path.resolve(process.argv[1]);
  const output=path.resolve(process.argv[2]);
  const relative=path.relative(workspace, output);
  if (!relative || relative === ".." || relative.startsWith(".." + path.sep) || path.isAbsolute(relative)) {
    process.exit(2);
  }
  let current=workspace;
  for (const segment of relative.split(path.sep).slice(0, -1)) {
    current=path.join(current, segment);
    if (fs.existsSync(current) && fs.lstatSync(current).isSymbolicLink()) process.exit(3);
  }
  if (fs.existsSync(output) && fs.lstatSync(output).isSymbolicLink()) process.exit(3);
  process.stdout.write(output);
' "$dir" "$requested_out"); then
  echo "OUTFILE 必须位于当前 feature 的 SDD workspace 内，且不能经过符号链接: $requested_out" >&2
  exit 2
fi
mkdir -p "$(dirname "$out")"
output_tmp=$(mktemp "$(dirname "$out")/.review-package.XXXXXX")
cleanup_output_tmp() {
  rm -f "$output_tmp" 2>/dev/null || true
}
trap cleanup_output_tmp EXIT

{
  echo "# 审查包：${base_sha}..${head_sha}"
  echo
  echo "## 提交列表"
  git log --oneline "${base_sha}..${head_sha}"
  echo
  echo "## 变更文件"
  git diff --stat "${base_sha}..${head_sha}"
  echo
  echo "## 差异"
  git diff --binary -U10 "${base_sha}..${head_sha}"
  echo
  echo "## 工作区未提交改动"
  echo
  echo "### staged"
  git diff --cached --stat
  echo
  git diff --cached --binary -U10
  echo
  echo "### unstaged"
  git diff --stat
  echo
  git diff --binary -U10
  echo
  echo "### untracked"
  while IFS= read -r -d '' file; do
    echo
    echo "#### $file"
    diff_rc=0
    git diff --no-index --binary -U10 -- /dev/null "$file" || diff_rc=$?
    if [ "$diff_rc" -ne 0 ] && [ "$diff_rc" -ne 1 ]; then
      exit "$diff_rc"
    fi
  done < <(git -c core.quotePath=false ls-files -z --others --exclude-standard)
} > "$output_tmp"

mv -f "$output_tmp" "$out"
trap - EXIT

commits=$(git rev-list --count "${base_sha}..${head_sha}")
bytes=$(wc -c < "$out" | tr -d ' ')
echo "已写入 ${out}: ${commits} 个提交，${bytes} 字节"
