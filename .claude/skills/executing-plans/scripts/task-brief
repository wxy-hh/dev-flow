#!/usr/bin/env bash
# 从实现计划中提取单个任务全文，写入实现者一次性读取的文件。
# 这样控制者不需要把整段任务文本粘贴进上下文。
#
# 用法：
#   task-brief PLAN_FILE TASK_NUMBER --feature FEATURE_ID [OUTFILE]
#   DEV_FLOW_FEATURE_ID=... task-brief PLAN_FILE TASK_NUMBER [OUTFILE]
#
# 默认 OUTFILE：feature-scoped SDD workspace 下的 task-<N>-brief.md
# 不读取 legacy shared SDD（裸 .claude/runtime/sdd/ 下的文件）。
set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)

if [ $# -lt 2 ]; then
  echo "用法: task-brief PLAN_FILE TASK_NUMBER --feature FEATURE_ID [OUTFILE]" >&2
  exit 2
fi

plan=$1
n=$2
shift 2

feature_id=${DEV_FLOW_FEATURE_ID:-}
out=""
while [ $# -gt 0 ]; do
  case "$1" in
    --feature)
      feature_id=${2:-}
      shift 2
      ;;
    --help|-h)
      echo "用法: task-brief PLAN_FILE TASK_NUMBER --feature FEATURE_ID [OUTFILE]"
      exit 0
      ;;
    -*)
      echo "未知参数: $1" >&2
      exit 2
      ;;
    *)
      if [ -z "$out" ]; then
        out=$1
        shift
      else
        echo "多余参数: $1" >&2
        exit 2
      fi
      ;;
  esac
done

[ -f "$plan" ] || { echo "计划文件不存在: $plan" >&2; exit 2; }

if [ -z "$feature_id" ]; then
  echo "缺少 --feature FEATURE_ID（或 DEV_FLOW_FEATURE_ID）；v0.8 要求 feature-scoped SDD" >&2
  exit 2
fi
dir=$("$SCRIPT_DIR/sdd-workspace" "$feature_id")

if [ -z "$out" ]; then
  out="$dir/task-${n}-brief.md"
fi

requested_out=$out
if ! out=$(node -e '
  const fs=require("fs");
  const path=require("path");
  const workspace=path.resolve(process.argv[1]);
  const output=path.resolve(process.argv[2]);
  const relative=path.relative(workspace, output);
  if (!relative || relative === ".." || relative.startsWith(".." + path.sep) || path.isAbsolute(relative)) {
    process.exit(2);
  }
  let current=workspace;
  for (const segment of relative.split(path.sep).slice(0, -1)) {
    current=path.join(current, segment);
    if (fs.existsSync(current) && fs.lstatSync(current).isSymbolicLink()) process.exit(3);
  }
  if (fs.existsSync(output) && fs.lstatSync(output).isSymbolicLink()) process.exit(3);
  process.stdout.write(output);
' "$dir" "$requested_out"); then
  echo "OUTFILE 必须位于当前 feature 的 SDD workspace 内，且不能经过符号链接: $requested_out" >&2
  exit 2
fi
mkdir -p "$(dirname "$out")"
output_tmp=$(mktemp "$(dirname "$out")/.task-brief.XXXXXX")
cleanup_output_tmp() {
  rm -f "$output_tmp" 2>/dev/null || true
}
trap cleanup_output_tmp EXIT

awk -v n="$n" '
  /^```/ { infence = !infence }
  !infence && /^#+[ \t]+(Task|任务)[ \t]+[0-9]+/ {
    intask = ($0 ~ ("^#+[ \t]+(Task|任务)[ \t]+" n "([^0-9]|$)"))
  }
  intask { print }
' "$plan" > "$output_tmp"

if [ ! -s "$output_tmp" ]; then
  echo "未在 ${plan} 中找到任务 ${n}（标题需匹配 'Task ${n}' 或 '任务 ${n}'）" >&2
  exit 3
fi

mv -f "$output_tmp" "$out"
trap - EXIT
echo "已写入 ${out}: $(wc -l < "$out" | tr -d ' ') 行"
