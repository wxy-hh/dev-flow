#!/usr/bin/env bash
# Feature-scoped recoverable SDD checkpoint.
#
# Layout (under sdd-workspace <feature-id>):
#   checkpoint.json  — machine state
#   progress.md      — human ledger (derived)
#
# Plan fingerprint is sha256 of the plan file contents. When the plan
# changes without `refresh-plan`, `check-plan` / mark-done report stale.
# Legacy shared files under the bare sdd root are never read.
#
# Usage:
#   sdd-checkpoint <feature-id> init --plan <path>
#   sdd-checkpoint <feature-id> show [--json]
#   sdd-checkpoint <feature-id> check-plan
#   sdd-checkpoint <feature-id> refresh-plan [--plan <path>]
#   sdd-checkpoint <feature-id> mark-done <task-n> [--base SHA] [--head SHA] [--note TEXT]
#   sdd-checkpoint <feature-id> mark-progress <task-n> [--note TEXT]
#   sdd-checkpoint <feature-id> done-list
#   sdd-checkpoint <feature-id> clear
set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)

if [ $# -lt 2 ]; then
  echo "用法: sdd-checkpoint <feature-id> <command> [args...]" >&2
  exit 2
fi

feature_id=$1
shift
cmd=$1
shift

case "$feature_id" in
  *..*|*/*|*"\\"*|""|.*)
    echo "非法 feature-id: $feature_id" >&2
    exit 2
    ;;
esac

workspace=$("$SCRIPT_DIR/sdd-workspace" "$feature_id")
checkpoint="$workspace/checkpoint.json"
progress="$workspace/progress.md"

plan_fingerprint() {
  local plan=$1
  if command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$plan" | awk '{print $1}'
  else
    sha256sum "$plan" | awk '{print $1}'
  fi
}

iso_now() {
  date -u +"%Y-%m-%dT%H:%M:%SZ"
}

resolve_plan_path() {
  local plan=$1
  if [ -z "$plan" ]; then
    echo ""
    return
  fi
  if [ -f "$plan" ]; then
    # Prefer repo-relative when under repo root.
    local root
    root=$(git rev-parse --show-toplevel 2>/dev/null || true)
    if [ -n "$root" ]; then
      local abs
      abs=$(cd "$(dirname "$plan")" && pwd)/$(basename "$plan")
      case "$abs" in
        "$root"/*) printf '%s\n' "${abs#"$root"/}" ; return ;;
      esac
      printf '%s\n' "$abs"
      return
    fi
    printf '%s\n' "$plan"
  else
    printf '%s\n' "$plan"
  fi
}

find_plan_file() {
  local stored=$1
  if [ -z "$stored" ]; then
    return 1
  fi
  if [ -f "$stored" ]; then
    printf '%s\n' "$stored"
    return 0
  fi
  local root
  root=$(git rev-parse --show-toplevel 2>/dev/null || true)
  if [ -n "$root" ] && [ -f "$root/$stored" ]; then
    printf '%s\n' "$root/$stored"
    return 0
  fi
  return 1
}

write_progress_md() {
  node -e '
    const fs = require("fs");
    const cp = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
    const out = process.argv[2];
    const lines = [];
    lines.push("# SDD Progress: " + cp.feature_id);
    lines.push("");
    lines.push("- Plan: `" + (cp.plan_path || "") + "`");
    lines.push("- Plan fingerprint: `" + (cp.plan_fingerprint || "") + "`");
    lines.push("- Plan status: **" + (cp.plan_stale ? "stale" : "fresh") + "**");
    lines.push("- Updated: " + (cp.updated_at || ""));
    lines.push("");
    lines.push("## Done");
    const done = Array.isArray(cp.done) ? cp.done : [];
    if (!done.length) lines.push("- (none)");
    else {
      for (const id of done) {
        const t = (cp.tasks && cp.tasks[id]) || {};
        const parts = ["Task " + id];
        if (t.base || t.head) parts.push("commits " + (t.base || "?") + ".." + (t.head || "?"));
        if (t.note) parts.push(t.note);
        lines.push("- " + parts.join(" — "));
      }
    }
    lines.push("");
    lines.push("## In progress");
    if (cp.in_progress == null || cp.in_progress === "") lines.push("- (none)");
    else {
      const id = String(cp.in_progress);
      const t = (cp.tasks && cp.tasks[id]) || {};
      lines.push("- Task " + id + (t.note ? " — " + t.note : ""));
    }
    lines.push("");
    fs.writeFileSync(out, lines.join("\n") + "\n");
  ' "$checkpoint" "$progress"
}

load_checkpoint() {
  if [ ! -f "$checkpoint" ]; then
    echo "checkpoint 不存在: $checkpoint（先运行 init）" >&2
    exit 2
  fi
}

annotate_stale() {
  # Reads checkpoint.json, recomputes plan_stale into a temp annotated view on stdout.
  node -e '
    const fs = require("fs");
    const cp = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
    const planFile = process.argv[2] || "";
    let stale = false;
    let current = "";
    if (!planFile || !fs.existsSync(planFile)) {
      stale = true;
    } else {
      const crypto = require("crypto");
      current = crypto.createHash("sha256").update(fs.readFileSync(planFile)).digest("hex");
      stale = current !== cp.plan_fingerprint;
    }
    cp.plan_stale = stale;
    cp.plan_fingerprint_current = current || null;
    process.stdout.write(JSON.stringify(cp));
  ' "$checkpoint" "${1:-}"
}

cmd_init() {
  local plan=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --plan) plan=${2:-}; shift 2 ;;
      *) echo "未知参数: $1" >&2; exit 2 ;;
    esac
  done
  if [ -z "$plan" ] || [ ! -f "$plan" ]; then
    echo "init 需要存在的 --plan <path>" >&2
    exit 2
  fi
  local stored fp now
  stored=$(resolve_plan_path "$plan")
  fp=$(plan_fingerprint "$plan")
  now=$(iso_now)
  node -e '
    const fs = require("fs");
    const out = process.argv[1];
    const data = {
      schema_version: 1,
      feature_id: process.argv[2],
      plan_path: process.argv[3],
      plan_fingerprint: process.argv[4],
      updated_at: process.argv[5],
      in_progress: null,
      done: [],
      tasks: {},
    };
    // Preserve done/tasks if re-init same feature with same plan fingerprint.
    if (fs.existsSync(out)) {
      try {
        const prev = JSON.parse(fs.readFileSync(out, "utf8"));
        if (prev.plan_fingerprint === data.plan_fingerprint && prev.feature_id === data.feature_id) {
          data.done = Array.isArray(prev.done) ? prev.done : [];
          data.tasks = prev.tasks && typeof prev.tasks === "object" ? prev.tasks : {};
          data.in_progress = prev.in_progress ?? null;
        }
      } catch (e) {}
    }
    fs.writeFileSync(out, JSON.stringify(data, null, 2) + "\n");
  ' "$checkpoint" "$feature_id" "$stored" "$fp" "$now"
  write_progress_md
  echo "已初始化 checkpoint: $checkpoint"
  echo "plan_fingerprint: $fp"
}

cmd_show() {
  load_checkpoint
  local as_json=false
  while [ $# -gt 0 ]; do
    case "$1" in
      --json) as_json=true; shift ;;
      *) echo "未知参数: $1" >&2; exit 2 ;;
    esac
  done
  local plan_file=""
  plan_file=$(find_plan_file "$(node -e 'const c=JSON.parse(require("fs").readFileSync(process.argv[1],"utf8"));process.stdout.write(c.plan_path||"")' "$checkpoint")" 2>/dev/null || true)
  local annotated
  annotated=$(annotate_stale "$plan_file")
  if [ "$as_json" = true ]; then
    printf '%s\n' "$annotated"
  else
    node -e '
      const cp = JSON.parse(process.argv[1]);
      console.log("feature_id: " + cp.feature_id);
      console.log("plan_path: " + (cp.plan_path || ""));
      console.log("plan_fingerprint: " + (cp.plan_fingerprint || ""));
      console.log("plan_status: " + (cp.plan_stale ? "stale" : "fresh"));
      console.log("done: " + (cp.done || []).join(",") );
      console.log("in_progress: " + (cp.in_progress == null ? "" : cp.in_progress));
      console.log("updated_at: " + (cp.updated_at || ""));
      console.log("workspace: " + process.argv[2]);
    ' "$annotated" "$workspace"
  fi
}

cmd_check_plan() {
  load_checkpoint
  local plan_file
  plan_file=$(find_plan_file "$(node -e 'const c=JSON.parse(require("fs").readFileSync(process.argv[1],"utf8"));process.stdout.write(c.plan_path||"")' "$checkpoint")" 2>/dev/null || true)
  if [ -z "$plan_file" ]; then
    echo "plan_status: missing"
    echo "计划文件缺失，无法校验 fingerprint" >&2
    exit 2
  fi
  local annotated status
  annotated=$(annotate_stale "$plan_file")
  status=$(node -e 'const c=JSON.parse(process.argv[1]); process.stdout.write(c.plan_stale ? "stale" : "fresh")' "$annotated")
  echo "plan_status: $status"
  if [ "$status" = "stale" ]; then
    echo "计划 fingerprint 已过期（stale）；运行 refresh-plan 或重新 init" >&2
    exit 3
  fi
}

require_fresh_plan() {
  # Used by mark-done / mark-progress. Does not exit the process on its own
  # when embedded; returns 0 if fresh, non-zero + message if not.
  local plan_file annotated status
  plan_file=$(find_plan_file "$(node -e 'const c=JSON.parse(require("fs").readFileSync(process.argv[1],"utf8"));process.stdout.write(c.plan_path||"")' "$checkpoint")" 2>/dev/null || true)
  if [ -z "$plan_file" ]; then
    echo "plan_status: missing" >&2
    return 2
  fi
  annotated=$(annotate_stale "$plan_file")
  status=$(node -e 'const c=JSON.parse(process.argv[1]); process.stdout.write(c.plan_stale ? "stale" : "fresh")' "$annotated")
  if [ "$status" = "stale" ]; then
    echo "plan_status: stale" >&2
    return 3
  fi
  return 0
}

cmd_refresh_plan() {
  load_checkpoint
  local plan=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --plan) plan=${2:-}; shift 2 ;;
      *) echo "未知参数: $1" >&2; exit 2 ;;
    esac
  done
  if [ -z "$plan" ]; then
    plan=$(find_plan_file "$(node -e 'const c=JSON.parse(require("fs").readFileSync(process.argv[1],"utf8"));process.stdout.write(c.plan_path||"")' "$checkpoint")" 2>/dev/null || true)
  fi
  if [ -z "$plan" ] || [ ! -f "$plan" ]; then
    echo "refresh-plan 需要可读计划文件（--plan 或 checkpoint.plan_path）" >&2
    exit 2
  fi
  local stored fp now
  stored=$(resolve_plan_path "$plan")
  fp=$(plan_fingerprint "$plan")
  now=$(iso_now)
  node -e '
    const fs = require("fs");
    const path = process.argv[1];
    const cp = JSON.parse(fs.readFileSync(path, "utf8"));
    cp.plan_path = process.argv[2];
    cp.plan_fingerprint = process.argv[3];
    cp.updated_at = process.argv[4];
    fs.writeFileSync(path, JSON.stringify(cp, null, 2) + "\n");
  ' "$checkpoint" "$stored" "$fp" "$now"
  write_progress_md
  echo "已刷新 plan_fingerprint: $fp"
}

cmd_mark_done() {
  load_checkpoint
  if [ $# -lt 1 ]; then
    echo "用法: sdd-checkpoint <feature-id> mark-done <task-n> [--base SHA] [--head SHA] [--note TEXT]" >&2
    exit 2
  fi
  local task=$1
  shift
  local base="" head="" note=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --base) base=${2:-}; shift 2 ;;
      --head) head=${2:-}; shift 2 ;;
      --note) note=${2:-}; shift 2 ;;
      *) echo "未知参数: $1" >&2; exit 2 ;;
    esac
  done
  # Refuse when plan is stale.
  if ! require_fresh_plan; then
    echo "拒绝 mark-done：plan fingerprint stale" >&2
    exit 3
  fi
  local now
  now=$(iso_now)
  node -e '
    const fs = require("fs");
    const path = process.argv[1];
    const task = String(process.argv[2]);
    const base = process.argv[3] || "";
    const head = process.argv[4] || "";
    const note = process.argv[5] || "";
    const now = process.argv[6];
    const cp = JSON.parse(fs.readFileSync(path, "utf8"));
    cp.tasks = cp.tasks || {};
    cp.done = Array.isArray(cp.done) ? cp.done.map(String) : [];
    if (!cp.done.includes(task)) cp.done.push(task);
    cp.done.sort((a, b) => Number(a) - Number(b));
    if (String(cp.in_progress) === task) cp.in_progress = null;
    cp.tasks[task] = Object.assign({}, cp.tasks[task] || {}, {
      status: "done",
      base: base || (cp.tasks[task] && cp.tasks[task].base) || "",
      head: head || (cp.tasks[task] && cp.tasks[task].head) || "",
      note: note || (cp.tasks[task] && cp.tasks[task].note) || "",
      at: now,
    });
    cp.updated_at = now;
    fs.writeFileSync(path, JSON.stringify(cp, null, 2) + "\n");
  ' "$checkpoint" "$task" "$base" "$head" "$note" "$now"
  write_progress_md
  echo "已标记 Task $task done"
}

cmd_mark_progress() {
  load_checkpoint
  if [ $# -lt 1 ]; then
    echo "用法: sdd-checkpoint <feature-id> mark-progress <task-n> [--note TEXT]" >&2
    exit 2
  fi
  local task=$1
  shift
  local note=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --note) note=${2:-}; shift 2 ;;
      *) echo "未知参数: $1" >&2; exit 2 ;;
    esac
  done
  if ! require_fresh_plan; then
    echo "拒绝 mark-progress：plan fingerprint stale" >&2
    exit 3
  fi
  local now
  now=$(iso_now)
  node -e '
    const fs = require("fs");
    const path = process.argv[1];
    const task = String(process.argv[2]);
    const note = process.argv[3] || "";
    const now = process.argv[4];
    const cp = JSON.parse(fs.readFileSync(path, "utf8"));
    cp.tasks = cp.tasks || {};
    cp.in_progress = task;
    cp.tasks[task] = Object.assign({}, cp.tasks[task] || {}, {
      status: "in_progress",
      note: note || (cp.tasks[task] && cp.tasks[task].note) || "",
      at: now,
    });
    cp.updated_at = now;
    fs.writeFileSync(path, JSON.stringify(cp, null, 2) + "\n");
  ' "$checkpoint" "$task" "$note" "$now"
  write_progress_md
  echo "已标记 Task $task in_progress"
}

cmd_done_list() {
  load_checkpoint
  node -e '
    const fs = require("fs");
    const cp = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
    const done = Array.isArray(cp.done) ? cp.done.map(String) : [];
    process.stdout.write(done.join(",") + (done.length ? "\n" : "\n"));
  ' "$checkpoint"
  # Warn on stale but still emit done list for scheduling.
  local plan_file
  plan_file=$(find_plan_file "$(node -e 'const c=JSON.parse(require("fs").readFileSync(process.argv[1],"utf8"));process.stdout.write(c.plan_path||"")' "$checkpoint")" 2>/dev/null || true)
  if [ -n "$plan_file" ]; then
    local annotated
    annotated=$(annotate_stale "$plan_file")
    if node -e 'const c=JSON.parse(process.argv[1]); process.exit(c.plan_stale?0:1)' "$annotated"; then
      echo "WARN plan fingerprint stale for feature $feature_id" >&2
    fi
  fi
}

cmd_clear() {
  rm -f "$checkpoint" "$progress"
  echo "已清除 checkpoint/progress: $workspace"
}

case "$cmd" in
  init) cmd_init "$@" ;;
  show) cmd_show "$@" ;;
  check-plan) cmd_check_plan "$@" ;;
  refresh-plan) cmd_refresh_plan "$@" ;;
  mark-done) cmd_mark_done "$@" ;;
  mark-progress) cmd_mark_progress "$@" ;;
  done-list) cmd_done_list "$@" ;;
  clear) cmd_clear "$@" ;;
  *)
    echo "未知命令: $cmd" >&2
    echo "支持: init show check-plan refresh-plan mark-done mark-progress done-list clear" >&2
    exit 2
    ;;
esac
