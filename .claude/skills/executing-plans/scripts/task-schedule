#!/usr/bin/env bash
# task-schedule — decide which plan tasks may run in parallel.
#
# Reads a plan markdown file, extracts Task N blocks with Depends on / Writes
# metadata, and prints a schedule of ready batches. A task is ready when all
# dependencies are complete and its Writes set does not overlap any other ready
# task's Writes (file, parent, child, or glob). Missing Writes => not dispatchable.
# Phase 0 (Task 0) is exclusive.
#
# Usage:
#   task-schedule <plan-file> [--done 1,2,3] [--feature FEATURE_ID] [--json]
#
# When --feature is set and --done is omitted, done list is loaded from
# sdd-checkpoint <feature-id> done-list (feature-scoped; never legacy shared SDD).
set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)

if [ $# -lt 1 ]; then
  echo "用法: task-schedule PLAN_FILE [--done 1,2,3] [--feature FEATURE_ID] [--json]" >&2
  exit 2
fi

plan=$1
shift
done_list=""
feature_id=${DEV_FLOW_FEATURE_ID:-}
as_json=false
done_explicit=false
while [ $# -gt 0 ]; do
  case "$1" in
    --done) done_list=${2:-}; done_explicit=true; shift 2 ;;
    --feature) feature_id=${2:-}; shift 2 ;;
    --json) as_json=true; shift ;;
    --help|-h) echo "用法: task-schedule PLAN_FILE [--done 1,2,3] [--feature FEATURE_ID] [--json]"; exit 0 ;;
    *) echo "未知参数: $1" >&2; exit 2 ;;
  esac
done

[ -f "$plan" ] || { echo "计划文件不存在: $plan" >&2; exit 2; }

if [ "$done_explicit" = false ] && [ -n "$feature_id" ]; then
  if [ -x "$SCRIPT_DIR/sdd-checkpoint" ]; then
    # done-list prints WARN on stderr when plan is stale; still usable.
    done_list=$("$SCRIPT_DIR/sdd-checkpoint" "$feature_id" done-list 2>/dev/null || true)
    done_list=$(printf '%s' "$done_list" | tr -d '\n')
  fi
fi

# Parse with Node for portable regex (macOS awk lacks match 3-arg form).
parsed=$(node -e '
  const fs = require("fs");
  const text = fs.readFileSync(process.argv[1], "utf8");
  const lines = text.split(/\r?\n/);
  let fence = false;
  let cur = null;
  const tasks = [];
  const flush = () => { if (cur) tasks.push(cur); cur = null; };
  for (const raw of lines) {
    if (/^```/.test(raw)) { fence = !fence; continue; }
    if (fence) continue;
    const title = raw.match(/^#{1,3}[ \t]+(?:Task|任务)[ \t]+(\d+)\b(.*)$/);
    if (title) {
      flush();
      const id = title[1];
      cur = {
        id,
        deps: [],
        writes: [],
        phase0: id === "0" || /phase[ \t]*0/i.test(title[2] || ""),
        inWrites: false,
      };
      continue;
    }
    if (!cur) continue;
    const dep = raw.match(/^\*\*Depends on:\*\*[ \t]*(.*)$/i);
    if (dep) {
      cur.inWrites = false;
      const body = dep[1].trim();
      if (!body || /^(none|无)$/i.test(body)) cur.deps = [];
      else {
        cur.deps = body
          .replace(/(?:Task|任务)[ \t]+/g, "")
          .split(/[,\s]+/)
          .map((s) => s.replace(/[^0-9]/g, ""))
          .filter(Boolean);
      }
      continue;
    }
    if (/^\*\*Writes:\*\*/i.test(raw)) {
      cur.inWrites = true;
      const rest = raw.replace(/^\*\*Writes:\*\*[ \t]*/i, "").trim();
      if (rest) cur.writes.push(rest.replace(/`/g, "").replace(/^[- \t]+/, ""));
      continue;
    }
    if (cur.inWrites) {
      if (/^\*\*/.test(raw) || /^#{1,3}[ \t]/.test(raw) || /^---/.test(raw)) {
        cur.inWrites = false;
      } else if (/^[ \t]*-/.test(raw)) {
        cur.writes.push(raw.replace(/^[ \t]*-[ \t]*/, "").replace(/`/g, "").trim());
      } else if (raw.trim() === "") {
        // keep collecting
      } else {
        cur.inWrites = false;
      }
    }
  }
  flush();
  if (tasks.length === 0) {
    process.stderr.write("未在计划中找到 Task 标题\n");
    process.exit(2);
  }
  process.stdout.write(JSON.stringify(tasks));
' "$plan")

result=$(DONE_LIST="$done_list" AS_JSON="$as_json" node -e '
  const tasks = JSON.parse(process.argv[1]);
  const doneList = (process.env.DONE_LIST || "").split(",").map((s) => s.trim()).filter(Boolean);
  const asJson = process.env.AS_JSON === "true";
  const isDone = (id) => doneList.includes(String(id));

  function expand(p) {
    p = p.replace(/\\/g, "/").replace(/\/+$/, "").replace(/^\.\//, "");
    if (p.endsWith("/**")) return { type: "dir", prefix: p.slice(0, -3) };
    if (p.endsWith("/*")) return { type: "dir", prefix: p.slice(0, -2) };
    if (p.includes("*")) {
      const prefix = p.split("*")[0].replace(/\/$/, "");
      return { type: "dir", prefix };
    }
    return { type: "file", path: p };
  }
  function pathOverlaps(a, b) {
    const X = expand(a), Y = expand(b);
    if (X.type === "file" && Y.type === "file") return X.path === Y.path;
    if (X.type === "file" && Y.type === "dir") return X.path === Y.prefix || X.path.startsWith(Y.prefix + "/");
    if (X.type === "dir" && Y.type === "file") return Y.path === X.prefix || Y.path.startsWith(X.prefix + "/");
    return X.prefix === Y.prefix || X.prefix.startsWith(Y.prefix + "/") || Y.prefix.startsWith(X.prefix + "/");
  }
  function writesOverlap(wa, wb) {
    for (const a of wa) for (const b of wb) if (pathOverlaps(a, b)) return true;
    return false;
  }
  function depsSatisfied(deps) {
    return deps.every((d) => isDone(d));
  }

  const pending = tasks.filter((t) => !isDone(t.id));
  if (pending.length === 0) {
    if (asJson) process.stdout.write(JSON.stringify({ ready: [], blocked: [], serial_reason: "all tasks done" }) + "\n");
    else process.stdout.write("所有任务已完成\n");
    process.exit(0);
  }

  const phase0 = pending.find((t) => t.phase0);
  const blocked = [];
  let candidates = [];

  if (phase0) {
    for (const t of pending) {
      if (t.id === phase0.id) {
        if (!t.writes.length) blocked.push({ id: Number(t.id), reason: "missing Writes" });
        else if (!depsSatisfied(t.deps)) blocked.push({ id: Number(t.id), reason: "depends on incomplete tasks" });
        else candidates.push(t);
      } else {
        blocked.push({ id: Number(t.id), reason: `waiting for Phase 0 task ${phase0.id}` });
      }
    }
  } else {
    for (const t of pending) {
      if (!t.writes.length) blocked.push({ id: Number(t.id), reason: "missing Writes" });
      else if (!depsSatisfied(t.deps)) blocked.push({ id: Number(t.id), reason: "depends on incomplete tasks" });
      else candidates.push(t);
    }
  }

  // greedy non-overlapping concurrent set (stable by numeric id)
  candidates.sort((a, b) => Number(a.id) - Number(b.id));
  const ready = [];
  for (const t of candidates) {
    if (ready.some((r) => writesOverlap(r.writes, t.writes))) {
      blocked.push({ id: Number(t.id), reason: "Writes overlap with a concurrent ready task" });
    } else {
      ready.push(t);
    }
  }

  if (asJson) {
    process.stdout.write(JSON.stringify({
      ready: ready.map((t) => Number(t.id)),
      blocked,
      done: doneList.map((x) => Number(x)).filter((n) => !Number.isNaN(n)),
    }) + "\n");
  } else {
    process.stdout.write("Ready (parallel-safe): " + (ready.map((t) => t.id).join(" ") || "<none>") + "\n");
    if (blocked.length) {
      process.stdout.write("Blocked:\n");
      for (const b of blocked) process.stdout.write(`  - Task ${b.id}: ${b.reason}\n`);
    }
  }
  process.exit(ready.length === 0 ? 3 : 0);
' "$parsed")

printf '%s\n' "$result"
