#!/usr/bin/env bash
# Resolve (and ensure) the feature-scoped SDD workspace directory.
#
# v0.8 layout:
#   <sdd_root>/<feature-id>/
#     checkpoint.json   # machine checkpoint (sdd-checkpoint)
#     progress.md       # human progress ledger
#     task-*-brief.md
#     review-*.diff
#     reports/
#
# Legacy shared files directly under <sdd_root>/ (task-*.md, progress.*,
# review-*.diff) are NOT part of the workspace and must not be read.
#
# Usage:
#   sdd-workspace <feature-id>
#   DEV_FLOW_FEATURE_ID=<id> sdd-workspace
#
# Prints the absolute path of the feature workspace.
set -euo pipefail

root=$(git rev-parse --show-toplevel)

feature_id=${1:-${DEV_FLOW_FEATURE_ID:-}}
if [ -z "$feature_id" ]; then
  echo "用法: sdd-workspace <feature-id>" >&2
  echo "或设置 DEV_FLOW_FEATURE_ID" >&2
  exit 2
fi

# Reject path traversal and empty segments.
case "$feature_id" in
  *..*|*/*|*"\\"*|""|.*)
    echo "非法 feature-id: $feature_id" >&2
    exit 2
    ;;
esac

read_dev_flow_path() {
  local key=$1
  local config="$root/.claude/rules/project-workflow.md"

  [ -f "$config" ] || return 1

  awk -v key="$key" '
    NR == 1 && $0 == "---" { in_front = 1; next }
    in_front && $0 == "---" { exit }
    !in_front { next }

    /^dev_flow:/ { in_dev = 1; next }
    in_dev && /^[^[:space:]]/ { in_dev = 0; in_paths = 0 }
    in_dev && /^  paths:/ { in_paths = 1; next }
    in_dev && /^  [^ ].*:/ && $0 !~ /^  paths:/ { in_paths = 0 }

    in_paths && $0 ~ ("^    " key ":") {
      value = $0
      sub("^[[:space:]]*" key ":[[:space:]]*", "", value)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", value)
      gsub(/^["\047]|["\047]$/, "", value)
      print value
      exit
    }
  ' "$config"
}

usable_path() {
  local value=$1
  [ -n "$value" ] &&
    [[ "$value" != *"<"* ]] &&
    [ "$value" != "none" ] &&
    [ "$value" != "needs-confirmation" ]
}

resolve_repo_path() {
  local value=$1
  case "$value" in
    /*) printf '%s\n' "$value" ;;
    *) printf '%s\n' "$root/${value#./}" ;;
  esac
}

sdd_progress=$(read_dev_flow_path sdd_progress || true)
runtime_root=$(read_dev_flow_path runtime_root || true)

# Base SDD root only. Feature content always lives under <base>/<feature-id>/.
# If sdd_progress points at a file (e.g. progress.md) or a bare shared dir,
# use its parent/dir as the base — never treat the bare shared dir as the
# workspace for a feature.
if usable_path "$sdd_progress"; then
  resolved=$(resolve_repo_path "$sdd_progress")
  base=$(basename "$resolved")
  if [[ "$resolved" == */ ]]; then
    sdd_base=${resolved%/}
  elif [[ "$base" == *.* ]]; then
    sdd_base=$(dirname "$resolved")
  else
    sdd_base=$resolved
  fi
elif usable_path "$runtime_root"; then
  sdd_base="$(resolve_repo_path "$runtime_root")/sdd"
else
  sdd_base="$root/.claude/runtime/sdd"
fi

# Ensure base exists and is self-ignored, but never use it as content root.
mkdir -p "$sdd_base"
printf '*\n' > "$sdd_base/.gitignore"

dir="$sdd_base/$feature_id"
mkdir -p "$dir/reports"
printf '*\n' > "$dir/.gitignore"
cd "$dir" && pwd
