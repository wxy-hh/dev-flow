#!/usr/bin/env bash
# 解析并确保 SDD 的临时产物目录存在：任务简报、实现报告、
# 审查包和进度台账都会放在这里。输出该目录的绝对路径。
#
# 目录放在工作树里（不放进 .git/），避免宿主环境阻止子代理写报告。
# 自忽略的 .gitignore 能让这些临时产物不进入 `git status`，
# 也不会意外进入提交。
#
# 优先读取 .claude/rules/project-workflow.md frontmatter 中的
# dev_flow.paths.sdd_progress 或 dev_flow.paths.runtime_root。
# 如果项目尚未 onboarding 或配置缺失，回退到 .claude/runtime/sdd。
#
# 这里是工作区位置的唯一来源，避免 task-brief 和 review-package 漂移到不同目录。
#
# 用法：sdd-workspace
set -euo pipefail

root=$(git rev-parse --show-toplevel)

read_dev_flow_path() {
  local key=$1
  local config="$root/.claude/rules/project-workflow.md"

  [ -f "$config" ] || return 1

  awk -v key="$key" '
    NR == 1 && $0 == "---" { in_front = 1; next }
    in_front && $0 == "---" { exit }
    !in_front { next }

    /^dev_flow:/ { in_dev = 1; next }
    in_dev && /^[^[:space:]]/ { in_dev = 0; in_paths = 0 }
    in_dev && /^  paths:/ { in_paths = 1; next }
    in_dev && /^  [^ ].*:/ && $0 !~ /^  paths:/ { in_paths = 0 }

    in_paths && $0 ~ ("^    " key ":") {
      value = $0
      sub("^[[:space:]]*" key ":[[:space:]]*", "", value)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", value)
      gsub(/^["\047]|["\047]$/, "", value)
      print value
      exit
    }
  ' "$config"
}

usable_path() {
  local value=$1
  [ -n "$value" ] &&
    [[ "$value" != *"<"* ]] &&
    [ "$value" != "none" ] &&
    [ "$value" != "needs-confirmation" ]
}

resolve_repo_path() {
  local value=$1
  case "$value" in
    /*) printf '%s\n' "$value" ;;
    *) printf '%s\n' "$root/${value#./}" ;;
  esac
}

sdd_progress=$(read_dev_flow_path sdd_progress || true)
runtime_root=$(read_dev_flow_path runtime_root || true)

if usable_path "$sdd_progress"; then
  resolved=$(resolve_repo_path "$sdd_progress")
  base=$(basename "$resolved")
  if [[ "$resolved" == */ ]]; then
    dir=${resolved%/}
  elif [[ "$base" == *.* ]]; then
    dir=$(dirname "$resolved")
  else
    dir=$resolved
  fi
elif usable_path "$runtime_root"; then
  dir="$(resolve_repo_path "$runtime_root")/sdd"
else
  dir="$root/.claude/runtime/sdd"
fi

mkdir -p "$dir"
printf '*\n' > "$dir/.gitignore"
cd "$dir" && pwd
