#!/usr/bin/env bash
# Validate the single work.md used by L or risk-gated dev-flow tasks.
set -uo pipefail
feature_id=""
finish=false
for arg in "$@"; do
  case "$arg" in
    --finish) finish=true ;;
    --help|-h)
      printf 'Usage: %s <feature-id> [--finish]\n' "$0"
      exit 0
      ;;
    --*) printf 'ERROR unknown option: %s\n' "$arg" >&2; exit 2 ;;
    *)
      [ -z "$feature_id" ] || { printf 'ERROR only one feature-id is accepted\n' >&2; exit 2; }
      feature_id=$arg
      ;;
  esac
done
if ! [[ "$feature_id" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]]; then
  printf 'ERROR unsafe feature-id: %s\n' "$feature_id" >&2
  exit 2
fi
root=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
cd "$root" || exit 2
workflow_file=.claude/rules/project-workflow.md
passes=0
failures=0
pass() { printf 'PASS %s\n' "$1"; passes=$((passes + 1)); }
fail() { printf 'FAIL %s\n' "$1"; failures=$((failures + 1)); }
summary() {
  printf '\nSummary: %s passed, %s failure(s)\n' "$passes" "$failures"
  [ "$failures" -eq 0 ]
}
if [ ! -f "$workflow_file" ]; then
  fail "project workflow is missing: $workflow_file"
  summary
  exit $?
fi
config_value() {
  local key=$1
  awk -v key="$key" '$0 ~ "^[[:space:]]*" key ":" {
    value=$0
    sub("^[^:]*:[[:space:]]*", "", value)
    gsub(/^"|"$/, "", value)
    print value
    exit
  }' "$workflow_file"
}
safe_relative_path() {
  local value=$1 segment old_ifs
  [ -n "$value" ] || return 1
  case "$value" in /*|*\\*|*$'\n'*|*$'\r'*) return 1 ;; esac
  old_ifs=$IFS
  IFS=/
  for segment in $value; do
    [ -n "$segment" ] && [ "$segment" != . ] && [ "$segment" != .. ] || { IFS=$old_ifs; return 1; }
  done
  IFS=$old_ifs
}
has_symlink_component() {
  local value=$1 current=$root segment old_ifs
  old_ifs=$IFS
  IFS=/
  for segment in $value; do
    current="$current/$segment"
    if [ -L "$current" ]; then IFS=$old_ifs; return 0; fi
  done
  IFS=$old_ifs
  return 1
}
feature_root=$(config_value feature_root)
workflow_version=$(config_value version)
if [ "$workflow_version" != 0.4.0 ]; then
  fail "project workflow must use version 0.4.0, got: ${workflow_version:-missing}"
fi
if ! safe_relative_path "$feature_root"; then
  fail 'project workflow has an unsafe feature_root'
  summary
  exit $?
fi
if has_symlink_component "$feature_root"; then
  fail 'feature_root passes through a symbolic link'
  summary
  exit $?
fi
work_file="$feature_root/$feature_id/work.md"
if [ ! -f "$work_file" ]; then
  fail "work.md is missing: $work_file"
  summary
  exit $?
fi
if has_symlink_component "$work_file"; then
  fail 'work.md passes through a symbolic link'
  summary
  exit $?
fi
pass 'work.md exists at a safe path'
state_value() {
  local key=$1
  awk -v key="$key" '
    /^## State[[:space:]]*$/ { in_state=1; next }
    in_state && /^## / { exit }
    in_state && index($0, "- " key ": ") == 1 {
      sub("^- " key ": ", "")
      print
      exit
    }
  ' "$work_file"
}
state_count() {
  local key=$1
  awk -v key="$key" '
    /^## State[[:space:]]*$/ { in_state=1; next }
    in_state && /^## / { exit }
    in_state && index($0, "- " key ": ") == 1 { count++ }
    END { print count + 0 }
  ' "$work_file"
}
section() {
  local heading=$1
  awk -v heading="$heading" '
    $0 == "## " heading { in_section=1; next }
    in_section && /^## / { exit }
    in_section { print }
  ' "$work_file"
}
meaningful_text() {
  local normalized
  normalized=$(printf '%s' "$1" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | tr '[:upper:]' '[:lower:]')
  case "$normalized" in ''|none|pending|'not required'|'not-required'|'not run'|'not-run'|未运行|待验证) return 1 ;; esac
}
level=$(state_value Level)
risks=$(state_value Risks)
phase=$(state_value Phase)
approval=$(state_value Approval)
approval_evidence=$(state_value 'Approval evidence')
verification=$(state_value Verification)
accepted_risks=$(state_value 'Accepted risks')
updated=$(state_value Updated)
for key in Level Risks Phase Approval 'Approval evidence' Verification 'Accepted risks' Updated; do
  count=$(state_count "$key")
  [ "$count" -eq 1 ] || fail "State field must appear exactly once: $key (found $count)"
done
case "$level" in XS|S|M|L) pass "recognized level: $level" ;; *) fail 'State has no recognized Level' ;; esac
case "$phase" in planning|implementation|verification|done|blocked) pass "recognized phase: $phase" ;; *) fail 'State has no recognized Phase' ;; esac
case "$verification" in pending|passed|partial|failed) pass "recognized verification: $verification" ;; *) fail 'State has no recognized Verification' ;; esac
[ -n "$updated" ] && [ "$updated" != none ] && pass 'Updated is recorded' || fail 'Updated is missing'
has_risk=false
if [ "$risks" = none ]; then
  pass 'no risk gate is required'
elif [ -z "$risks" ]; then
  fail 'Risks is missing'
else
  unknown_risks=""
  while IFS= read -r risk; do
    risk=$(printf '%s' "$risk" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    case "$risk" in
      security|data|money|external|availability) has_risk=true ;;
      *) unknown_risks="${unknown_risks}${unknown_risks:+, }${risk:-empty}" ;;
    esac
  done < <(printf '%s\n' "$risks" | tr ',' '\n')
  if [ -n "$unknown_risks" ]; then fail "unknown risk tag(s): $unknown_risks"; else pass "recognized risk tags: $risks"; fi
fi
if [ "$has_risk" = true ]; then
  case "$approval" in
    pending)
      [ "$finish" = false ] && pass 'risk approval is pending before implementation' || fail 'risk approval is still pending'
      ;;
    confirmed)
      if meaningful_text "$approval_evidence"; then
        pass 'risk approval is confirmed with evidence'
      else
        fail 'risk approval is confirmed without evidence'
      fi
      ;;
    skipped)
      if meaningful_text "$approval_evidence" && meaningful_text "$accepted_risks"; then
        pass 'risk gate was skipped with explicit accepted-risk evidence'
      else
        fail 'skipped risk gate lacks approval or accepted-risk evidence'
      fi
      ;;
    *) fail 'risk task Approval must be pending, confirmed or skipped' ;;
  esac
else
  case "$approval" in not-required|confirmed) pass "approval state is valid: $approval" ;; *) fail 'low-risk task Approval must be not-required or confirmed' ;; esac
fi
if [ "$finish" = true ]; then
  [ "$phase" = done ] && pass 'phase is done' || fail 'finish requires Phase: done'
  batches=$(section Batches)
  if printf '%s\n' "$batches" | rg -q '^- \[ \]'; then fail 'one or more batches are incomplete'; else pass 'no incomplete batches remain'; fi
  if printf '%s\n' "$batches" | rg -q '^- \[[xX]\]'; then pass 'completed batch evidence exists'; else fail 'no completed batch is recorded'; fi
  case "$verification" in
    passed) pass 'verification passed' ;;
    partial)
      if meaningful_text "$accepted_risks"; then
        pass 'partial verification has explicit accepted-risk evidence'
      else
        fail 'partial verification has no accepted-risk evidence'
      fi
      ;;
    *) fail "finish requires passed verification, got: ${verification:-missing}" ;;
  esac
  verification_evidence=$(section Verification | sed -n 's/^- Evidence: //p' | tail -1)
  if meaningful_text "$verification_evidence"; then pass 'verification evidence is recorded'; else fail 'verification evidence is missing or still a placeholder'; fi
fi
summary
