#!/usr/bin/env bash
# Layer 2: asset dry-run / archive / delete for one completed feature.
# Calls Layer 0 (fingerprint, policy) and Layer 1 (validator) only; may read check-ok.
# Must not call dev-flow-status or dev-flow-feature-check.
# Mutates only after --confirm with a matching --inventory. Layer 3 owns post-finalize feature-check.
set -u

root=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
cd "$root" || exit 2

feature_id=""
retention=""
confirm=false
inventory_arg=""
confirm_untracked=""
expect_inventory_value=false
expect_untracked_value=false
for arg in "$@"; do
  if [ "$expect_inventory_value" = true ]; then
    inventory_arg=$arg
    expect_inventory_value=false
    continue
  fi
  if [ "$expect_untracked_value" = true ]; then
    confirm_untracked=$arg
    expect_untracked_value=false
    continue
  fi
  case "$arg" in
    --retention=compact) retention=compact ;;
    --retention=full) retention=full ;;
    --confirm) confirm=true ;;
    --inventory=*) inventory_arg=${arg#--inventory=} ;;
    --inventory) expect_inventory_value=true ;;
    --confirm-untracked=*) confirm_untracked=${arg#--confirm-untracked=} ;;
    --confirm-untracked) expect_untracked_value=true ;;
    --help|-h)
      printf 'Usage: %s <feature-id> --retention=compact|full [--confirm --inventory <sha256>] [--confirm-untracked DELETE-UNTRACKED:<sha>:<count>]\n' "$0"
      exit 0
      ;;
    --*)
      printf 'ERROR unknown option: %s\n' "$arg" >&2
      exit 2
      ;;
    *)
      if [ -n "$feature_id" ]; then
        printf 'ERROR only one feature-id is accepted\n' >&2
        exit 2
      fi
      feature_id=$arg
      ;;
  esac
done
if [ "$expect_inventory_value" = true ]; then
  printf 'ERROR --inventory requires a value\n' >&2
  exit 2
fi
if [ "$expect_untracked_value" = true ]; then
  printf 'ERROR --confirm-untracked requires a value\n' >&2
  exit 2
fi

if [ -z "$feature_id" ] || [ -z "$retention" ]; then
  printf 'Usage: %s <feature-id> --retention=compact|full [--confirm --inventory <sha256>] [--confirm-untracked DELETE-UNTRACKED:<sha>:<count>]\n' "$0" >&2
  exit 2
fi
if [ "$confirm" = true ] && [ -z "$inventory_arg" ]; then
  printf 'ERROR --confirm requires --inventory <sha256> from the latest dry-run\n' >&2
  exit 2
fi

script_dir=$(dirname "$0")
validator="$script_dir/dev-flow-validate.mjs"
fingerprint_cmd="$script_dir/dev-flow-fingerprint"
policy_cmd="$script_dir/dev-flow-policy.mjs"
if ! command -v node >/dev/null 2>&1; then
  printf 'ERROR Node.js is required for dev-flow validation\n' >&2
  exit 2
fi
if ! node "$validator" feature-id "$feature_id"; then
  exit 2
fi

workflow_file=.claude/rules/project-workflow.md
if [ ! -f "$workflow_file" ]; then
  printf 'ERROR project workflow is missing: %s\n' "$workflow_file" >&2
  exit 2
fi

config_value() {
  local key=$1
  awk -v key="$key" '$0 ~ "^[[:space:]]*" key ":" { value=$0; sub("^[^:]*:[[:space:]]*", "", value); gsub(/^"|"$/, "", value); print value; exit }' "$workflow_file"
}

feature_root=$(config_value feature_root)
review_root=$(config_value review_root)
if [ -z "$feature_root" ] || [ -z "$review_root" ]; then
  printf 'ERROR project workflow has no feature_root/review_root\n' >&2
  exit 2
fi
if ! node "$validator" roots "$root" "$feature_root" "$review_root"; then
  printf 'ERROR project workflow has unsafe feature/review roots\n' >&2
  exit 2
fi

feature_dir="$feature_root/$feature_id"
status_file="$feature_dir/status.md"
feature_file="$feature_dir/feature.md"
completion_file="$feature_dir/completion.md"
stamp_file=".claude/runtime/dev-flow/$feature_id.check-ok"
auth_file=".claude/runtime/dev-flow/write-authorization.json"
sdd_dir=".claude/runtime/sdd/$feature_id"
runtime_dir=".claude/runtime/dev-flow"

if [ ! -f "$status_file" ]; then
  printf 'ERROR active status is missing: %s\n' "$status_file" >&2
  exit 1
fi
if ! node "$validator" asset "$root" "$feature_root" "$review_root" "$status_file"; then
  printf 'ERROR active status has an unsafe path: %s\n' "$status_file" >&2
  exit 1
fi
if [ ! -f "$feature_file" ] || [ ! -f "$completion_file" ]; then
  printf 'ERROR feature.md and completion.md must be generated and reviewed before finalization\n' >&2
  exit 1
fi
for protected_destination in "$feature_dir/archive" "$feature_dir/manual-test.md"; do
  if [ -L "$protected_destination" ]; then
    printf 'ERROR finalization destination must not be a symbolic link: %s\n' "$protected_destination" >&2
    exit 1
  fi
done
if [ -e "$feature_dir/archive" ] && [ ! -d "$feature_dir/archive" ]; then
  printf 'ERROR finalization archive destination is not a directory: %s\n' "$feature_dir/archive" >&2
  exit 1
fi
if [ -e "$feature_dir/manual-test.md" ] && [ ! -f "$feature_dir/manual-test.md" ]; then
  printf 'ERROR finalization manual-test destination is not a file: %s\n' "$feature_dir/manual-test.md" >&2
  exit 1
fi

# CLI --retention is authoritative. Inventory deliberately ignores the retention
# choice so the same dry-run hash works for compact or full confirm; completion
# retention is rewritten to match on successful confirm.
completion_retention=$(awk '
  /^  retention:/ {
    value=$0
    sub(/^[^:]*:[[:space:]]*/, "", value)
    gsub(/^"|"$/, "", value)
    print value
    exit
  }
' "$completion_file")
completion_outcome=$(awk '
  /^  outcome:/ {
    value=$0
    sub(/^[^:]*:[[:space:]]*/, "", value)
    gsub(/^"|"$/, "", value)
    print value
    exit
  }
' "$completion_file")

# A check-ok stamp binds the business diff, not mutable process metadata.
# Re-run the read-only active route validator so a later status change cannot
# reuse an older stamp to bypass required process gates.
if ! node "$validator" feature "$root" "$feature_id" --stage active; then
  printf 'ERROR active feature route validation failed before finalization\n' >&2
  exit 1
fi

if ! node "$validator" final-assets "$root" "$feature_file" "$completion_file" --status "$status_file"; then
  printf 'ERROR final-assets validation failed\n' >&2
  exit 1
fi

if [ ! -f "$stamp_file" ]; then
  printf 'ERROR fresh check-ok stamp is required before finalization: %s\n' "$stamp_file" >&2
  exit 1
fi
stamped_fingerprint=$(sed -n 's/^fingerprint: //p' "$stamp_file")
stamped_version=$(sed -n 's/^workflow_version: //p' "$stamp_file")
stamped_outcome=$(sed -n 's/^outcome: //p' "$stamp_file")
current_fingerprint=$("$fingerprint_cmd" "$feature_root" "$review_root" 2>/dev/null || true)
expected_version=$(node "$policy_cmd" version 2>/dev/null || true)
if [ -z "$stamped_fingerprint" ] || [ -z "$current_fingerprint" ] \
  || [ "$stamped_fingerprint" != "$current_fingerprint" ] \
  || [ -z "$stamped_version" ] || [ -z "$expected_version" ] \
  || [ "$stamped_version" != "$expected_version" ] \
  || [ -z "$stamped_outcome" ] || [ "$stamped_outcome" != "$completion_outcome" ]; then
  printf 'ERROR check-ok stamp is missing, stale, wrong workflow_version, or has an outcome mismatch (re-run feature-check --finish)\n' >&2
  exit 1
fi

KNOWN_SUFFIXES="plan-review code-review security-review verification manual-test partial-acceptance"

is_feature_owned_review_name() {
  local name=$1
  case "$name" in
    *.md) ;;
    *) return 1 ;;
  esac
  local base=${name%.md}
  local suffix
  for suffix in $KNOWN_SUFFIXES; do
    if [ "$base" = "${feature_id}-${suffix}" ]; then
      return 0
    fi
    case "$base" in
      [0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]-"${feature_id}-${suffix}") return 0 ;;
    esac
  done
  return 1
}

owned_list=$(mktemp "${TMPDIR:-/tmp}/dev-flow-owned.XXXXXX")
inventory_body=$(mktemp "${TMPDIR:-/tmp}/dev-flow-inv.XXXXXX")
cleanup_temps() {
  rm -f "$owned_list" "$inventory_body" 2>/dev/null || true
}
trap cleanup_temps EXIT

add_owned() {
  local p=$1
  [ -z "$p" ] && return 0
  p=${p#./}
  printf '%s\n' "$p" >> "$owned_list"
}

while IFS= read -r asset; do
  [ -z "$asset" ] && continue
  add_owned "$asset"
done < <(sed -n 's/^    - {path: "\([^"]*\)".*/\1/p' "$status_file")

while IFS= read -r ref; do
  [ -z "$ref" ] && continue
  case "$ref" in
    "$feature_root"/*|"$review_root"/*) add_owned "$ref" ;;
  esac
done < <(sed -n 's/^[[:space:]]*\(path\|report\|verification\): "\([^"]*\)"/\2/p' "$status_file")

if [ -d "$review_root" ]; then
  while IFS= read -r entry; do
    [ -z "$entry" ] && continue
    name=$(basename "$entry")
    if is_feature_owned_review_name "$name"; then
      add_owned "$review_root/$name"
    fi
  done < <(find "$review_root" -maxdepth 1 -type f -name '*.md' 2>/dev/null)
fi

add_owned "$status_file"

if [ -d "$feature_dir" ]; then
  while IFS= read -r entry; do
    [ -z "$entry" ] && continue
    base=$(basename "$entry")
    case "$base" in
      feature.md|completion.md|manual-test.md|archive) continue ;;
      *) add_owned "${entry#./}" ;;
    esac
  done < <(find "$feature_dir" -mindepth 1 -maxdepth 1 \( -type f -o -type d -o -type l \) 2>/dev/null)
fi

sorted_owned=$(sort -u "$owned_list" | sed '/^$/d')

while IFS= read -r asset; do
  [ -z "$asset" ] && continue
  if ! node "$validator" asset "$root" "$feature_root" "$review_root" "$asset"; then
    printf 'ERROR feature-owned asset has an unsafe path: %s\n' "$asset" >&2
    exit 1
  fi
done <<< "$sorted_owned"

file_sha() {
  local f=$1
  if [ ! -e "$f" ]; then
    printf 'missing'
    return 0
  fi
  if [ -L "$f" ]; then
    printf 'symlink:%s' "$(readlink "$f" 2>/dev/null || true)"
    return 0
  fi
  if [ -d "$f" ]; then
    find "$f" -type f -print 2>/dev/null | sort | while IFS= read -r child; do
      printf '%s\t' "${child#$f/}"
      shasum -a 256 "$child" 2>/dev/null | awk '{print $1}'
    done | shasum -a 256 | awk '{print $1}'
    return 0
  fi
  if [ -f "$f" ]; then
    shasum -a 256 "$f" 2>/dev/null | awk '{print $1}'
    return 0
  fi
  printf 'other'
}

git_tracked() {
  local f=$1
  git -C "$root" ls-files --error-unmatch -- "$f" >/dev/null 2>&1
}

# A directory is safe to classify as tracked only when every leaf that compact
# would delete is tracked. One tracked child must not hide untracked/ignored
# siblings that Git cannot restore.
asset_has_untracked_content() {
  local asset=$1
  local child
  local child_count=0
  [ -e "$asset" ] || return 1
  if [ ! -d "$asset" ]; then
    ! git_tracked "$asset"
    return
  fi
  while IFS= read -r child; do
    [ -z "$child" ] && continue
    child_count=$((child_count + 1))
    if ! git_tracked "$child"; then
      return 0
    fi
  done < <(find "$asset" \( -type f -o -type l \) -print 2>/dev/null)
  # Git cannot track an empty directory, so deleting it is still an untracked
  # path operation (low cost, but kept under the same exact confirmation rule).
  [ "$child_count" -eq 0 ] && return 0
  return 1
}

asset_tracking_class() {
  local asset=$1
  if [ ! -e "$asset" ]; then
    printf 'missing'
  elif asset_has_untracked_content "$asset"; then
    printf 'untracked'
  else
    printf 'tracked'
  fi
}

is_reusable_manual() {
  local f=$1
  [ -f "$f" ] || return 1
  rg -q '^reusable: true$' "$f" 2>/dev/null
}

manual_report=""
while IFS= read -r asset; do
  [ -z "$asset" ] && continue
  base=$(basename "$asset")
  if is_feature_owned_review_name "$base"; then
    case "$base" in
      *-manual-test.md|"$feature_id-manual-test.md")
        manual_report=$asset
        ;;
    esac
  fi
done <<< "$sorted_owned"

reusable_manual=false
if [ -n "$manual_report" ] && is_reusable_manual "$manual_report"; then
  reusable_manual=true
fi

{
  printf 'feature_id=%s\n' "$feature_id"
  printf 'feature_md=%s\n' "$(file_sha "$feature_file")"
  printf 'completion_md=%s\n' "$(file_sha "$completion_file")"
  printf 'status_md=%s\n' "$(file_sha "$status_file")"
  printf 'reusable_manual=%s\n' "$reusable_manual"
  printf 'manual_report=%s\n' "$manual_report"
  while IFS= read -r asset; do
    [ -z "$asset" ] && continue
    if [ -L "$asset" ]; then
      kind=symlink
      size=0
    elif [ -d "$asset" ]; then
      kind=dir
      size=$(find "$asset" -type f -print 2>/dev/null | wc -l | tr -d ' ')
    elif [ -f "$asset" ]; then
      kind=file
      size=$(wc -c < "$asset" | tr -d ' ')
    elif [ ! -e "$asset" ]; then
      kind=missing
      size=0
    else
      kind=other
      size=0
    fi
    printf 'asset\t%s\t%s\t%s\t%s\t%s\n' \
      "$asset" "$kind" "$size" "$(file_sha "$asset")" "$(asset_tracking_class "$asset")"
  done <<< "$sorted_owned"
} > "$inventory_body"

inventory_sha=$(shasum -a 256 "$inventory_body" | awk '{print $1}')

working_files=0
working_bytes=0
keep_files=2
keep_bytes=0
if [ -f "$feature_file" ]; then
  keep_bytes=$((keep_bytes + $(wc -c < "$feature_file" | tr -d ' ')))
fi
if [ -f "$completion_file" ]; then
  keep_bytes=$((keep_bytes + $(wc -c < "$completion_file" | tr -d ' ')))
fi
if [ "$reusable_manual" = true ] && [ -f "$manual_report" ]; then
  keep_files=$((keep_files + 1))
  keep_bytes=$((keep_bytes + $(wc -c < "$manual_report" | tr -d ' ')))
fi

process_list=$(mktemp "${TMPDIR:-/tmp}/dev-flow-proc.XXXXXX")
while IFS= read -r asset; do
  [ -z "$asset" ] && continue
  [ "$asset" = "$feature_file" ] && continue
  [ "$asset" = "$completion_file" ] && continue
  if [ "$reusable_manual" = true ] && [ "$asset" = "$manual_report" ]; then
    continue
  fi
  if [ "$asset" = "$feature_dir/archive" ]; then
    continue
  fi
  printf '%s\n' "$asset" >> "$process_list"
  if [ -f "$asset" ]; then
    working_files=$((working_files + 1))
    working_bytes=$((working_bytes + $(wc -c < "$asset" | tr -d ' ')))
  elif [ -d "$asset" ]; then
    while IFS= read -r child; do
      [ -z "$child" ] && continue
      working_files=$((working_files + 1))
      working_bytes=$((working_bytes + $(wc -c < "$child" | tr -d ' ')))
    done < <(find "$asset" -type f -print 2>/dev/null)
  fi
done <<< "$sorted_owned"

untracked_count=0
printf 'Retention: %s\n' "$retention"
printf 'Feature: %s\n' "$feature_id"
printf 'Inventory: %s\n' "$inventory_sha"
printf 'Working set: %s files / %s bytes\n' "$working_files" "$working_bytes"
printf 'Long-term keep: %s files / %s bytes\n' "$keep_files" "$keep_bytes"
printf 'Reusable manual-test: %s\n' "$reusable_manual"
printf 'Semantics: compact=delete intermediate assets; full=archive intermediate assets; not now=skip without blocking Git.\n'
printf 'Assets to process:\n'
printf '[keep] %s\n' "$feature_file"
printf '[keep] %s\n' "$completion_file"
if [ "$reusable_manual" = true ] && [ -n "$manual_report" ]; then
  printf '[keep] %s -> %s\n' "$manual_report" "$feature_dir/manual-test.md"
fi
while IFS= read -r asset; do
  [ -z "$asset" ] && continue
  if [ ! -e "$asset" ]; then
    printf '[conflict] missing %s\n' "$asset"
    continue
  fi
  if [ "$retention" = full ]; then
    printf '[archive] %s -> %s/...\n' "$asset" "$feature_dir/archive"
  else
    if [ "$(asset_tracking_class "$asset")" = tracked ]; then
      printf '[delete][tracked] %s\n' "$asset"
    else
      printf '[delete][untracked] %s\n' "$asset"
      untracked_count=$((untracked_count + 1))
    fi
  fi
done < "$process_list"

untracked_token=""
if [ "$retention" = compact ] && [ "$untracked_count" -gt 0 ]; then
  untracked_token="DELETE-UNTRACKED:${inventory_sha}:${untracked_count}"
  printf '\nUntracked delete token:\n%s\n' "$untracked_token"
  printf 'compact will permanently delete untracked files. Ordinary --confirm --inventory is refused.\n'
  printf 'Reply with the exact token, then re-run with --confirm --inventory %s --confirm-untracked "%s"\n' \
    "$inventory_sha" "$untracked_token"
  printf 'Or choose retain full (archive) or not now (no changes; Git not blocked).\n'
fi

if [ "$confirm" != true ]; then
  printf 'Dry run only. This turn must not --confirm; wait for exact user choice compact / retain full / not now.\n'
  if [ -n "$untracked_token" ]; then
    printf 'If compact with untracked deletes: --confirm --inventory %s --confirm-untracked "%s"\n' \
      "$inventory_sha" "$untracked_token"
  else
    printf 'Re-run with --confirm --inventory %s after an exact user choice.\n' "$inventory_sha"
  fi
  rm -f "$process_list"
  exit 0
fi

if [ "$inventory_arg" != "$inventory_sha" ]; then
  printf 'ERROR INVENTORY_CHANGED (got %s, expected %s). Re-run dry-run; zero modifications made.\n' \
    "$inventory_arg" "$inventory_sha" >&2
  rm -f "$process_list"
  exit 1
fi

if [ "$retention" = compact ] && [ "$untracked_count" -gt 0 ]; then
  expected_token="DELETE-UNTRACKED:${inventory_sha}:${untracked_count}"
  if [ -z "$confirm_untracked" ]; then
    printf 'ERROR UNTRACKED_DELETE_CONFIRMATION_REQUIRED: compact would delete %s untracked path(s). Re-run dry-run and pass --confirm-untracked "%s". Zero modifications made.\n' \
      "$untracked_count" "$expected_token" >&2
    rm -f "$process_list"
    exit 1
  fi
  if [ "$confirm_untracked" != "$expected_token" ]; then
    printf 'ERROR UNTRACKED_DELETE_CONFIRMATION_REQUIRED: token mismatch (got %s, expected %s). Zero modifications made.\n' \
      "$confirm_untracked" "$expected_token" >&2
    rm -f "$process_list"
    exit 1
  fi
fi

mkdir -p "$runtime_dir"
ts=$(date '+%Y%m%d-%H%M%S')
if ! quarantine_root=$(mktemp -d "$runtime_dir/finalize-quarantine-${feature_id}-${ts}.XXXXXX"); then
  printf 'ERROR could not create an isolated finalization quarantine\n' >&2
  rm -f "$process_list"
  exit 1
fi
run_nonce=${quarantine_root##*.}
archive_root="$feature_dir/archive/${ts}-${run_nonce}"

move_log="$quarantine_root/.move-log"
: > "$move_log"
completion_backup="$quarantine_root/.completion-original"
completion_tmp=""
if ! cp "$completion_file" "$completion_backup"; then
  printf 'ERROR failed to back up completion.md before finalization\n' >&2
  rm -rf "$quarantine_root" 2>/dev/null || true
  rm -f "$process_list"
  exit 1
fi
fail_after=${DEV_FLOW_FINALIZE_FAIL_AFTER:-}
move_count=0
manual_placed=false

restore_all() {
  local restore_failed=0
  local restore_attempts=0
  local inject_restore_failure=${DEV_FLOW_FINALIZE_FAIL_RESTORE_AFTER:-}
  if [ -n "$completion_tmp" ] && ! rm -f "$completion_tmp" 2>/dev/null; then
    printf 'ERROR restore could not remove temporary completion: %s\n' "$completion_tmp" >&2
    restore_failed=1
  fi
  if [ "$manual_placed" = true ]; then
    if ! rm -f "$feature_dir/manual-test.md" 2>/dev/null; then
      printf 'ERROR restore could not remove placed manual-test.md\n' >&2
      restore_failed=1
    fi
  fi
  if [ -f "$move_log" ]; then
    local reverse_log="$quarantine_root/.move-log-reversed"
    if command -v tac >/dev/null 2>&1; then
      reverse_cmd=(tac)
    else
      reverse_cmd=(tail -r)
    fi
    if ! "${reverse_cmd[@]}" "$move_log" > "$reverse_log" 2>/dev/null; then
      printf 'ERROR restore could not read the move log in reverse order\n' >&2
      restore_failed=1
    else
      while IFS=$'\t' read -r original qpath; do
        [ -z "$original" ] && continue
        [ -e "$qpath" ] || continue
        restore_attempts=$((restore_attempts + 1))
        if [ -n "$inject_restore_failure" ] && [ "$restore_attempts" -eq "$inject_restore_failure" ]; then
          printf 'ERROR injected restore failure for %s\n' "$original" >&2
          restore_failed=1
          continue
        fi
        if ! mkdir -p "$(dirname "$original")"; then
          printf 'ERROR restore could not create parent for %s\n' "$original" >&2
          restore_failed=1
          continue
        fi
        if [ -e "$original" ] && ! rm -rf "$original"; then
          printf 'ERROR restore could not clear conflicting path: %s\n' "$original" >&2
          restore_failed=1
          continue
        fi
        if ! mv "$qpath" "$original" 2>/dev/null; then
          printf 'ERROR restore could not move %s back to %s\n' "$qpath" "$original" >&2
          restore_failed=1
        fi
      done < "$reverse_log"
    fi
  fi
  if [ -f "$completion_backup" ]; then
    if ! cp "$completion_backup" "$completion_file" 2>/dev/null; then
      printf 'ERROR restore could not restore completion.md\n' >&2
      restore_failed=1
    fi
  fi
  if [ -d "$archive_root" ]; then
    if ! rm -rf "$archive_root"; then
      printf 'ERROR restore could not remove partial archive: %s\n' "$archive_root" >&2
      restore_failed=1
    fi
  fi
  if [ "$restore_failed" -ne 0 ]; then
    printf 'ERROR restore incomplete; quarantine preserved for manual recovery: %s\n' "$quarantine_root" >&2
    return 1
  fi
  if ! rm -rf "$quarantine_root" 2>/dev/null; then
    printf 'ERROR restored assets but could not remove quarantine: %s\n' "$quarantine_root" >&2
    return 1
  fi
  return 0
}

on_fail() {
  local msg=$1
  printf 'ERROR %s — restoring quarantine\n' "$msg" >&2
  if ! restore_all; then
    printf 'ERROR automatic restore did not complete; do not retry finalization until the preserved quarantine is reconciled\n' >&2
  fi
  rm -f "$process_list"
  exit 1
}

quarantine_move() {
  local asset=$1
  [ -e "$asset" ] || return 0
  local qpath="$quarantine_root/$asset"
  mkdir -p "$(dirname "$qpath")"
  if ! mv "$asset" "$qpath"; then
    on_fail "failed to quarantine $asset"
  fi
  printf '%s\t%s\n' "$asset" "$qpath" >> "$move_log"
  move_count=$((move_count + 1))
  if [ -n "$fail_after" ] && [ "$move_count" -ge "$fail_after" ]; then
    on_fail "injected failure after $move_count move(s) (DEV_FLOW_FINALIZE_FAIL_AFTER)"
  fi
}

# Align completion retention only after its original content is recoverable.
# Inventory intentionally ignores this single field so one dry-run can support
# either exact user choice.
if [ -n "$completion_retention" ] && [ "$completion_retention" != "$retention" ]; then
  if ! completion_tmp=$(mktemp "$feature_dir/.completion.md.XXXXXX"); then
    on_fail "failed to create an isolated completion update"
  fi
  if ! awk -v ret="$retention" '
    /^  retention:/ {
      print "  retention: \"" ret "\""
      next
    }
    { print }
  ' "$completion_file" > "$completion_tmp" || ! mv "$completion_tmp" "$completion_file"; then
    on_fail "failed to align completion retention"
  fi
fi

if [ "$reusable_manual" = true ] && [ -n "$manual_report" ] && [ -e "$manual_report" ]; then
  quarantine_move "$manual_report"
  q_manual="$quarantine_root/$manual_report"
  dest_manual="$feature_dir/manual-test.md"
  mkdir -p "$(dirname "$dest_manual")"
  if ! cp -R "$q_manual" "$dest_manual"; then
    on_fail "failed to place reusable manual-test at $dest_manual"
  fi
  manual_placed=true
fi

while IFS= read -r asset; do
  [ -z "$asset" ] && continue
  [ -e "$asset" ] || continue
  quarantine_move "$asset"
done < "$process_list"

if [ "$retention" = full ]; then
  # Copy into archive first so quarantine remains the restore source until success.
  while IFS= read -r asset; do
    [ -z "$asset" ] && continue
    qpath="$quarantine_root/$asset"
    [ -e "$qpath" ] || continue
    if [[ "$asset" == "$review_root"/* ]]; then
      relative=${asset#"$review_root"/}
      destination="$archive_root/reviews/$relative"
    elif [[ "$asset" == "$feature_dir"/* ]] || [[ "$asset" == "$feature_root/$feature_id"/* ]]; then
      relative=${asset#"$feature_root/$feature_id"/}
      destination="$archive_root/feature/$relative"
    else
      destination="$archive_root/feature/$(basename "$asset")"
    fi
    mkdir -p "$(dirname "$destination")"
    if ! cp -R "$qpath" "$destination"; then
      on_fail "failed to archive $asset -> $destination"
    fi
    move_count=$((move_count + 1))
    if [ -n "$fail_after" ] && [ "$move_count" -ge "$fail_after" ]; then
      on_fail "injected failure after $move_count move(s) (DEV_FLOW_FINALIZE_FAIL_AFTER)"
    fi
  done < "$process_list"
else
  # compact: originals already quarantined; drop them on success path.
  :
fi

# Runtime cleanup is transactional too: move it into the same quarantine and
# destroy it only after all finalized postconditions pass.
auth_quarantined=false
if [ -d "$sdd_dir" ]; then
  quarantine_move "$sdd_dir"
fi
if [ -f "$auth_file" ]; then
  auth_feature=$(node -e '
    try {
      const a = JSON.parse(require("fs").readFileSync(process.argv[1], "utf8"));
      if (a && a.feature_id) process.stdout.write(String(a.feature_id));
    } catch (e) {}
  ' "$auth_file" 2>/dev/null || true)
  if [ "$auth_feature" = "$feature_id" ]; then
    quarantine_move "$auth_file"
    auth_quarantined=true
  fi
fi
if [ -f "$stamp_file" ]; then
  quarantine_move "$stamp_file"
fi

# Preserve a closed authorization record so finish-guard can bind the immediate
# Git handoff to the feature that was just finalized. The original auth remains
# in quarantine and is restored if any later postcondition fails.
if [ "$auth_quarantined" = true ]; then
  quarantined_auth="$quarantine_root/$auth_file"
  if ! node - "$quarantined_auth" "$auth_file" <<'NODE'
const fs = require('fs');
const path = require('path');
const [source, destination] = process.argv.slice(2);
const auth = JSON.parse(fs.readFileSync(source, 'utf8'));
auth.state = 'closed';
auth.closed_at = new Date().toISOString();
fs.mkdirSync(path.dirname(destination), { recursive: true });
const temporary = `${destination}.tmp-${process.pid}`;
fs.writeFileSync(temporary, `${JSON.stringify(auth, null, 2)}\n`, 'utf8');
fs.renameSync(temporary, destination);
NODE
  then
    on_fail "failed to preserve closed authorization for $feature_id"
  fi
fi

leftover=0
if [ -d "$review_root" ]; then
  while IFS= read -r entry; do
    [ -z "$entry" ] && continue
    name=$(basename "$entry")
    if is_feature_owned_review_name "$name"; then
      leftover=$((leftover + 1))
    fi
  done < <(find "$review_root" -maxdepth 1 -type f -name '*.md' 2>/dev/null)
fi
if [ "$leftover" -ne 0 ]; then
  on_fail "review-root still has $leftover feature-owned leftover(s) after finalization"
fi

if [ "${DEV_FLOW_FINALIZE_FAIL_POSTCONDITION:-}" = "1" ]; then
  on_fail "injected finalized postcondition failure (DEV_FLOW_FINALIZE_FAIL_POSTCONDITION)"
fi

if ! node "$validator" feature "$root" "$feature_id" --stage finalized; then
  on_fail "finalized feature postcondition failed"
fi

# Commit the transaction only after every postcondition passes.
rm -rf "$quarantine_root" 2>/dev/null || true
find "$feature_dir" -type d -empty -delete 2>/dev/null || true
rm -f "$process_list"

printf 'Finalization passed: %s\n' "$retention"
printf 'Inventory: %s\n' "$inventory_sha"
exit 0
