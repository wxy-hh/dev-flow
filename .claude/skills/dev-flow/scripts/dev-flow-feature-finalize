#!/usr/bin/env bash
# Compact or archive completed feature evidence. Mutates only after --confirm.
set -u

root=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
cd "$root" || exit 2

feature_id=""
retention=""
confirm=false
for arg in "$@"; do
  case "$arg" in
    --retention=compact) retention=compact ;;
    --retention=full) retention=full ;;
    --confirm) confirm=true ;;
    --help|-h) printf 'Usage: %s <feature-id> --retention=compact|full [--confirm]\n' "$0"; exit 0 ;;
    --*) printf 'ERROR unknown option: %s\n' "$arg" >&2; exit 2 ;;
    *)
      if [ -n "$feature_id" ]; then printf 'ERROR only one feature-id is accepted\n' >&2; exit 2; fi
      feature_id=$arg
      ;;
  esac
done

if [ -z "$feature_id" ] || [ -z "$retention" ]; then
  printf 'Usage: %s <feature-id> --retention=compact|full [--confirm]\n' "$0" >&2
  exit 2
fi
if [[ "$feature_id" == */* || "$feature_id" == .* ]]; then
  printf 'ERROR feature-id must be a relative identifier: %s\n' "$feature_id" >&2
  exit 2
fi

workflow_file=.claude/rules/project-workflow.md
if [ ! -f "$workflow_file" ]; then
  printf 'ERROR project workflow is missing: %s\n' "$workflow_file" >&2
  exit 2
fi

config_value() {
  local key=$1
  awk -v key="$key" '$0 ~ "^[[:space:]]*" key ":" { value=$0; sub("^[^:]*:[[:space:]]*", "", value); gsub(/^"|"$/, "", value); print value; exit }' "$workflow_file"
}

feature_root=$(config_value feature_root)
review_root=$(config_value review_root)
feature_dir="$feature_root/$feature_id"
status_file="$feature_dir/status.md"
feature_file="$feature_dir/feature.md"
completion_file="$feature_dir/completion.md"

if [ ! -f "$status_file" ]; then
  printf 'ERROR active status is missing: %s\n' "$status_file" >&2
  exit 1
fi
if [ ! -f "$feature_file" ] || [ ! -f "$completion_file" ]; then
  printf 'ERROR feature.md and completion.md must be generated and reviewed before finalization\n' >&2
  exit 1
fi
completion_retention=$(sed -n 's/^  retention: "\([^"]*\)"$/\1/p' "$completion_file")
if [ -n "$completion_retention" ] && [ "$completion_retention" != "$retention" ]; then
  printf 'ERROR completion.md retention (%s) does not match requested retention (%s)\n' "$completion_retention" "$retention" >&2
  exit 1
fi

checker="$(dirname "$0")/dev-flow-feature-check"
if ! "$checker" "$feature_id" --finish; then
  printf 'ERROR feature-check failed; no assets were changed\n' >&2
  exit 1
fi

status_section() {
  sed -n "/^  $1:/,/^  $2:/p" "$status_file"
}

assets=$(status_section assets context_manifests | sed -n 's/^    - //p')
manual_report=$(find "$review_root" -maxdepth 1 -type f \( -name "$feature_id-manual-test.md" -o -name "*-$feature_id-manual-test.md" \) -print -quit 2>/dev/null)
archive_root="$feature_dir/archive/$(date '+%Y%m%d-%H%M%S')"

while IFS= read -r asset; do
  [ -z "$asset" ] && continue
  case "$asset" in
    "$feature_dir"/*|"$review_root"/*) ;;
    *) printf 'ERROR status asset is outside feature/review roots: %s\n' "$asset" >&2; exit 1 ;;
  esac
done <<< "$assets"

printf 'Retention: %s\n' "$retention"
printf 'Feature: %s\n' "$feature_id"
printf 'Assets to process:\n'
while IFS= read -r asset; do
  [ -z "$asset" ] && continue
  case "$asset" in
    "$feature_file"|"$completion_file") continue ;;
    "$manual_report")
      if rg -q '^reusable: true$' "$manual_report" 2>/dev/null; then continue; fi
      ;;
  esac
  printf -- '- %s\n' "$asset"
done <<< "$assets"
if [ "$retention" = full ]; then printf -- '- %s\n' "$feature_dir/patches"; fi

if [ "$confirm" != true ]; then
  printf 'Dry run only. Re-run with --confirm after reviewing this list.\n'
  exit 3
fi

keep_manual=false
if [ -n "$manual_report" ] && rg -q '^reusable: true$' "$manual_report" 2>/dev/null; then
  mv "$manual_report" "$feature_dir/manual-test.md"
  keep_manual=true
fi

move_to_archive() {
  local asset=$1
  local relative destination
  if [[ "$asset" == "$review_root"/* ]]; then
    relative=${asset#"$review_root"/}
    destination="$archive_root/reviews/$relative"
  else
    relative=${asset#"$feature_root/$feature_id"/}
    destination="$archive_root/feature/$relative"
  fi
  mkdir -p "$(dirname "$destination")"
  mv "$asset" "$destination"
}

while IFS= read -r asset; do
  [ -z "$asset" ] && continue
  [ "$asset" = "$feature_file" ] && continue
  [ "$asset" = "$completion_file" ] && continue
  [ "$keep_manual" = true ] && [ "$asset" = "$manual_report" ] && continue
  [ -e "$asset" ] || continue
  if [ "$retention" = full ]; then
    move_to_archive "$asset"
  else
    rm -rf "$asset"
  fi
done <<< "$assets"

if [ -n "$manual_report" ] && [ "$keep_manual" != true ] && [ -e "$manual_report" ]; then
  if [ "$retention" = full ]; then
    move_to_archive "$manual_report"
  else
    rm -f "$manual_report"
  fi
fi

if [ "$retention" = full ]; then
  if [ -d "$feature_dir/patches" ]; then
    mkdir -p "$archive_root/feature"
    mv "$feature_dir/patches" "$archive_root/feature/patches"
  fi
else
  rm -rf "$feature_dir/context" "$feature_dir/patches"
fi

find "$feature_dir" -type d -empty -delete 2>/dev/null || true
if "$checker" "$feature_id" --finish; then
  printf 'Finalization passed: %s\n' "$retention"
  exit 0
fi

printf 'ERROR finalized assets failed feature-check; inspect the feature directory before Git actions\n' >&2
exit 1
