#!/usr/bin/env bash
# Tests for dev-flow-status.mjs and partial / gate_evidence validation.
set -u

root=$(cd "$(dirname "$0")/.." && pwd)
status_cli="$root/dev-flow-status.mjs"
validator="$root/dev-flow-validate.mjs"
checker="$root/dev-flow-feature-check"
policy="$root/dev-flow-policy.mjs"
classifier="$root/dev-flow-command.mjs"
tmp=$(mktemp -d "${TMPDIR:-/tmp}/dev-flow-status.XXXXXX")
trap 'rm -rf "$tmp"' EXIT

failures=0
run() {
  if [ "${DEBUG:-0}" = 1 ]; then
    "$@"
  else
    "$@" >/dev/null 2>&1
  fi
}
run_in_tmp() {
  (cd "$tmp" && "$@")
}
expect_pass() {
  if run "$@"; then
    printf 'PASS %s\n' "$*"
  else
    printf 'FAIL expected pass: %s\n' "$*"
    failures=$((failures + 1))
  fi
}
expect_fail() {
  if run "$@"; then
    printf 'FAIL expected failure: %s\n' "$*"
    failures=$((failures + 1))
  else
    printf 'PASS expected failure: %s\n' "$*"
  fi
}
expect_file() {
  if [ -f "$1" ]; then
    printf 'PASS file exists: %s\n' "$1"
  else
    printf 'FAIL expected file: %s\n' "$1"
    failures=$((failures + 1))
  fi
}
expect_contains() {
  if rg -q -- "$2" "$1"; then
    printf 'PASS contains %s in %s\n' "$2" "$1"
  else
    printf 'FAIL expected %s in %s\n' "$2" "$1"
    failures=$((failures + 1))
  fi
}
expect_not_contains() {
  if rg -q -- "$2" "$1"; then
    printf 'FAIL did not expect %s in %s\n' "$2" "$1"
    failures=$((failures + 1))
  else
    printf 'PASS absent %s in %s\n' "$2" "$1"
  fi
}

mkdir -p "$tmp/.claude/rules" "$tmp/.claude/skills" "$tmp/docs/dev-flow/features" "$tmp/docs/dev-flow/reviews" "$tmp/src" "$tmp/apps/web"
skill_root=$(cd "$root/.." && pwd)
ln -s "$skill_root" "$tmp/.claude/skills/dev-flow"
git -C "$tmp" init -q
printf '%s\n' \
  'dev_flow:' \
  '  paths:' \
  '    feature_root: docs/dev-flow/features' \
  '    review_root: docs/dev-flow/reviews' \
  '  verification:' \
  '    webapp_testing: "disabled"' \
  '  artifacts:' \
  '    retention: "compact"' \
  '  enforcement_mode: "ask"' \
  '  protected_write_roots:' \
  '    - "src/**"' \
  > "$tmp/.claude/rules/project-workflow.md"
printf '%s\n' 'baseline' > "$tmp/src/business.js"
git -C "$tmp" add .
git -C "$tmp" -c user.name='dev-flow test' -c user.email='dev-flow@example.test' commit -qm baseline

no_increment_result=$(node --input-type=module - "$policy" <<'NODE'
const policyPath = process.argv[2];
const { loadContract, deriveRoute, labelsWithNoGateIncrement } = await import(`file://${policyPath}`);
const contract = loadContract();
const riskMinimalBase = deriveRoute(contract, {
  level: 'S', profile: 'risk-minimal', riskLabels: [],
});
const standardLBase = deriveRoute(contract, {
  level: 'L', profile: 'standard', riskLabels: [],
});
const data = labelsWithNoGateIncrement(contract, ['data'], riskMinimalBase.riskGates);
const external = labelsWithNoGateIncrement(contract, ['external'], standardLBase.riskGates);
process.stdout.write(`data=${data.join(',')};external=${external.join(',')}`);
NODE
)
if [ "$no_increment_result" = 'data=;external=external' ]; then
  printf 'PASS risk-label no-increment compares against the unlabeled base route\n'
else
  printf 'FAIL risk-label no-increment result: %s\n' "$no_increment_result"
  failures=$((failures + 1))
fi

# Table-driven policy matrix: every status-bearing route × every risk label.
if node --input-type=module - "$policy" <<'NODE'
const policyPath = process.argv[2];
const {
  STANDARD_REQUIREMENT_ENTRY_GATES,
  deriveRoute,
  deriveStartPlan,
  gateRank,
  loadContract,
  routeObligations,
  validateTopology,
} = await import(`file://${policyPath}`);
const contract = loadContract();
const rank = gateRank(contract);
const routes = [
  { name: 'risk-minimal-xs', level: 'XS', profile: 'risk-minimal' },
  { name: 'risk-minimal-s', level: 'S', profile: 'risk-minimal' },
  { name: 'risk-minimal-m', level: 'M', profile: 'risk-minimal' },
  { name: 'standard-m', level: 'M', profile: 'standard', entryGate: 'req-probe' },
  { name: 'standard-l', level: 'L', profile: 'standard', entryGate: 'grillme' },
  { name: 'lightweight-l', level: 'L', profile: 'standard', lightweightL: true },
];
let checked = 0;
const assert = (condition, message) => {
  if (!condition) throw new Error(message);
};
for (const routeInput of routes) {
  for (const label of contract.risk_labels) {
    const derived = deriveRoute(contract, { ...routeInput, riskLabels: [label] });
    for (const [gate, minimum] of Object.entries(contract.minimum_risk_gates[label])) {
      assert(
        rank[derived.riskGates[gate]] >= rank[minimum],
        `${routeInput.name}/${label} weakened ${gate}`,
      );
    }
    assert(derived.codeReview.required, `${routeInput.name}/${label} lacks code-review`);
    if (label === 'critical_correctness' || label === 'irreversible_consequence') {
      assert(
        derived.codeReview.evidence_level === 'full',
        `${routeInput.name}/${label} must use full code-review`,
      );
    }
    if (routeInput.name.startsWith('risk-minimal')) {
      assert(derived.riskGates.requirements_coverage === 'none', `${routeInput.name} added coverage`);
      assert(derived.riskGates.plan_review === 'none', `${routeInput.name} added plan-review`);
    }
    if (routeInput.name === 'standard-m') {
      assert(derived.riskGates.requirements_coverage === 'none', 'standard M forced coverage');
      assert(rank[derived.riskGates.plan_review] >= rank.light, 'standard M lacks plan-review');
    }
    if (routeInput.name === 'standard-l') {
      assert(derived.riskGates.requirements_coverage === 'full', 'standard L coverage is not full');
      assert(derived.riskGates.behavior_verification === 'full', 'standard L behavior is not full');
    }
    if (routeInput.name === 'lightweight-l') {
      assert(derived.riskGates.rollback_units !== 'none', 'lightweight L lacks rollback');
      assert(derived.riskGates.behavior_verification === 'full', 'lightweight L behavior is not full');
    }
    checked += 1;
  }
}
for (const entryGate of STANDARD_REQUIREMENT_ENTRY_GATES) {
  const derived = deriveRoute(contract, {
    level: 'M', profile: 'standard', riskLabels: [], entryGate,
  });
  assert(derived.initialCurrentGate === entryGate, `entry gate was not preserved: ${entryGate}`);
}

const levels = contract.levels;
const topologies = contract.classification_topologies;
const executions = [undefined, ...contract.execution_modes];
const riskSets = [[], ...contract.risk_labels.map((label) => [label])];
let startInputs = 0;
let startAccepted = 0;
for (const level of levels) {
  for (const topology of topologies) {
    for (const execution of executions) {
      for (const riskLabels of riskSets) {
        for (const processMode of contract.process_modes) {
          startInputs += 1;
          const executionValid = ['XS', 'S'].includes(level)
            ? execution === undefined
            : contract.execution_modes.includes(execution);
          const topologyValid = validateTopology(contract, level, topology) === null;
          const shouldPass = executionValid && topologyValid;
          let plan;
          let error;
          try {
            plan = deriveStartPlan(contract, {
              level,
              topology,
              execution,
              requirements: execution === 'standard' ? 'confirmed' : undefined,
              riskLabels,
              processMode,
            });
          } catch (caught) {
            error = caught;
          }
          assert(Boolean(plan) === shouldPass, [
            level, topology, execution ?? 'derived-light', riskLabels[0] ?? 'no-risk', processMode,
            error?.message ?? plan?.route,
          ].join('/'));
          if (!plan) continue;
          if (processMode === 'retrospective') {
            assert(plan.kind === 'status', 'retrospective route must be status-bearing');
            const expectedRoute = ['XS', 'S'].includes(level)
              ? 'risk-minimal'
              : level === 'M' && execution === 'light'
                ? 'risk-minimal-m'
                : level === 'M'
                  ? 'standard-m'
                  : execution === 'light'
                    ? 'lightweight-l'
                    : 'standard-l';
            assert(plan.route === expectedRoute, `retrospective route mismatch: ${plan.route}/${expectedRoute}`);
            assert(plan.humanGates.implementation_approval.required, 'retrospective route lacks approval');
            assert(plan.codeReview.required, 'retrospective route lacks code-review');
            assert(plan.entryGate === undefined, 'retrospective route must not backfill an entry gate');
            const obligations = routeObligations(contract, {
              level,
              profile: plan.profile,
              riskLabels,
              humanGates: plan.humanGates,
              riskGates: plan.riskGates,
              processMode,
              execution: execution ?? 'light',
            });
            assert(obligations.approvalProcessGates.length === 0, 'retrospective approval backfilled process gates');
            assert(!obligations.finishProcessGates.includes('plan-review'), 'retrospective finish backfilled plan-review');
            assert(!obligations.finishProcessGates.includes('requirements-coverage'), 'retrospective finish backfilled coverage');
            assert(obligations.finishProcessGates.includes('code-review'), 'retrospective finish lacks code-review');
            assert(obligations.finishProcessGates.includes('verification-before-completion'), 'retrospective finish lacks verification');
          } else if (
            riskLabels.length === 0 &&
            (['XS', 'S'].includes(level) || (level === 'M' && execution === 'light'))
          ) {
            assert(plan.kind === 'authorize', 'no-risk normal light route should be stateless');
          }
          startAccepted += 1;
        }
      }
    }
  }
}
process.stdout.write(`policy matrix checked ${checked} route/label and ${startInputs} full-axis inputs (${startAccepted} accepted)\n`);
NODE
then
  printf 'PASS policy matrix covers topology, level, execution, risk, and process mode\n'
else
  printf 'FAIL policy matrix route/risk-label contract\n'
  failures=$((failures + 1))
fi

# --- 1.0 high-level start/topology fixtures ---
dry_a=$(run_in_tmp node "$status_cli" start fixture-a --level M \
  --topology shared-contract --risk-labels security --execution light \
  --evidence-result verified --dry-run)
if printf '%s' "$dry_a" | rg -q '"route": "risk-minimal-m"'; then
  printf 'PASS Fixture A dry-run derives risk-minimal-m\n'
else
  printf 'FAIL Fixture A did not derive risk-minimal-m\n'
  failures=$((failures + 1))
fi
start_a=$(run_in_tmp node "$status_cli" start fixture-a --level M \
  --topology shared-contract --risk-labels security --execution light \
  --evidence-result verified)
if printf '%s' "$start_a" | rg -q 'risk-minimal-m' \
  && printf '%s' "$start_a" | rg -q 'next_command: /security-review'; then
  printf 'PASS Fixture A real start matches dry-run route and emits next_command\n'
else
  printf 'FAIL Fixture A real start route or next_command differs from policy\n'
  failures=$((failures + 1))
fi
expect_pass run_in_tmp node "$status_cli" record-risk-evidence fixture-a security \
  --mode inline --conclusion 'auth branches reviewed' --verification 'relevant checks passed'
expect_contains "$tmp/docs/dev-flow/features/fixture-a/status.md" 'current_gate: "security-review"'
active_auth_before=$(shasum -a 256 "$tmp/.claude/runtime/dev-flow/write-authorization.json" | awk '{print $1}')
expect_fail run_in_tmp node "$status_cli" start fixture-a --level S --topology local
expect_fail run_in_tmp node "$status_cli" start fixture-a --level S --topology local --dry-run
expect_fail run_in_tmp node "$status_cli" authorize --level S --note 'must not replace active status'
active_auth_after=$(shasum -a 256 "$tmp/.claude/runtime/dev-flow/write-authorization.json" | awk '{print $1}')
if [ "$active_auth_before" = "$active_auth_after" ]; then
  printf 'PASS active status-backed authorization cannot be downgraded or replaced\n'
else
  printf 'FAIL downgrade attempt mutated active status-backed authorization\n'
  failures=$((failures + 1))
fi
expect_fail run_in_tmp node "$status_cli" complete-gate fixture-a security-review \
  --evidence-inline 'Reviewed security and found no issues'
complete_a=$(run_in_tmp node "$status_cli" complete-gate fixture-a security-review \
  --evidence-inline 'Auth matrix verified: anonymous denied, account and OAuth allowed')
if printf '%s' "$complete_a" | rg -q '^next_command: node ".*/\.claude/skills/dev-flow/scripts/dev-flow-status\.mjs" "confirm-human" "fixture-a" "implementation_approval"'; then
  printf 'PASS complete-gate emits the first HUMAN GATE command directly\n'
else
  printf 'FAIL complete-gate did not emit the first HUMAN GATE command\n'
  failures=$((failures + 1))
fi
printf '%s\n' 'API_TOKEN=supersecretvalue123' > "$tmp/docs/dev-flow/reviews/fixture-a-secret-review.md"
secret_output=$(run_in_tmp node "$status_cli" add-asset fixture-a \
  --path docs/dev-flow/reviews/fixture-a-secret-review.md --kind review 2>&1 || true)
if printf '%s' "$secret_output" | rg -q 'fixture-a-secret-review.md.*API_TOKEN' \
  && ! printf '%s' "$secret_output" | rg -q 'supersecretvalue123'; then
  printf 'PASS secret scan reports only managed path/key and never the value\n'
else
  printf 'FAIL secret scan omitted path/key or leaked the value\n'
  failures=$((failures + 1))
fi
next_command=$(printf '%s\n' "$complete_a" | sed -n 's/^next_command: //p')
fixture_root=$(git -C "$tmp" rev-parse --show-toplevel)
classified_next=$(cd "$tmp/apps/web" && DEV_FLOW_REPO_ROOT="$fixture_root" node "$classifier" "$next_command")
subdir_output=$(cd "$tmp/apps/web" && bash -c "$next_command")
next_a=$(run_in_tmp node "$status_cli" next fixture-a)
if printf '%s' "$classified_next" | rg -q '"is_control":true' \
  && printf '%s' "$subdir_output" | rg -q 'human gate implementation_approval: confirmed' \
  && printf '%s' "$subdir_output" | rg -q 'next_command: /executing-plans' \
  && printf '%s' "$next_a" | rg -q 'command: /executing-plans' \
  && ! printf '%s' "$next_a" | rg -q 'command: node '; then
  printf 'PASS Fixture A command runs from a subdirectory; slash route keeps its form\n'
else
  printf 'FAIL Fixture A subdirectory command or slash route is invalid\n'
  failures=$((failures + 1))
fi

security_status="$tmp/docs/dev-flow/features/fixture-a/status.md"
check_security_summary() {
  local description=$1 summary=$2 expected=$3 backup="$security_status.before"
  cp "$security_status" "$backup"
  node - "$security_status" "$summary" <<'NODE'
const fs = require('fs');
const [,, file, summary] = process.argv;
const quote = JSON.stringify(summary);
const text = fs.readFileSync(file, 'utf8').replace(/(summary:\s*)"[^"]*"/, `$1${quote}`);
fs.writeFileSync(file, text, 'utf8');
NODE
  if node "$validator" status "$tmp" "docs/dev-flow/features/fixture-a/status.md" >/dev/null 2>&1; then
    actual=pass
  else
    actual=fail
  fi
  mv "$backup" "$security_status"
  if [ "$actual" = "$expected" ]; then
    printf 'PASS %s\n' "$description"
  else
    printf 'FAIL %s (expected %s, got %s)\n' "$description" "$expected" "$actual"
    failures=$((failures + 1))
  fi
}
check_security_summary 'auth no-touch evidence is accepted' \
  'scope=auth；登录、SSO、token、session 和权限均不触及，因为本次仅改展示文案；结果：通过' pass
check_security_summary 'legacy token auth branch evidence is accepted' \
  'Auth token verified: expired token denied, refreshed token allowed' pass
check_security_summary 'legacy session auth branch evidence is accepted' \
  'Auth session verified: missing session denied, active session allowed' pass
check_security_summary 'privacy allow/exclude/enforcement evidence is accepted' \
  'scope=privacy；白名单：id,name；排除字段：token,email；强制边界：序列化导出 props；结果：通过' pass
check_security_summary 'generic security conclusion is rejected' '已审查，无问题' fail
check_security_summary 'auth evidence without result is rejected' 'scope=auth; anonymous denied, account allowed' fail
check_security_summary 'privacy evidence without allowlist is rejected' \
  'scope=privacy；排除字段：token；强制边界：序列化；结果：通过' fail
check_security_summary 'privacy evidence without exclusions is rejected' \
  'scope=privacy；白名单：id,name；强制边界：序列化；结果：通过' fail
check_security_summary 'privacy evidence without enforcement is rejected' \
  'scope=privacy；白名单：id,name；排除字段：token；结果：通过' fail

expect_pass run_in_tmp node "$status_cli" start stable-shared --level M \
  --topology shared-contract --execution standard --requirements confirmed --dry-run
expect_pass run_in_tmp node "$status_cli" start required-l --level L \
  --topology multi-chain --execution standard --requirements confirmed --dry-run
expect_fail run_in_tmp node "$status_cli" start invalid-multi-m --level M \
  --topology multi-chain --execution light --dry-run
expect_fail run_in_tmp node "$status_cli" start invalid-rollback-m --level M \
  --topology coordinated-rollback --execution standard --requirements confirmed --dry-run
expect_fail run_in_tmp node "$status_cli" start invalid-local-l --level L \
  --topology local --execution light --dry-run
expect_fail run_in_tmp node "$status_cli" start invalid-xs-execution --level XS \
  --topology local --execution light --dry-run
expect_fail run_in_tmp node "$status_cli" start invalid-standard-input --level M \
  --topology local --execution standard --dry-run

auth_before=$(shasum -a 256 "$tmp/.claude/runtime/dev-flow/write-authorization.json" | awk '{print $1}')
expect_fail run_in_tmp node "$status_cli" start atomic-policy-fail --level M \
  --topology multi-chain --execution light
auth_after=$(shasum -a 256 "$tmp/.claude/runtime/dev-flow/write-authorization.json" | awk '{print $1}')
if [ "$auth_before" = "$auth_after" ] && [ ! -e "$tmp/docs/dev-flow/features/atomic-policy-fail/status.md" ]; then
  printf 'PASS failed start leaves no half-status or authorization mutation\n'
else
  printf 'FAIL failed start left partial state\n'
  failures=$((failures + 1))
fi

# --- approval baseline and retrospective semantics ---
printf '%s\n' 'user-authored requirement input' > "$tmp/docs/requirement-input.md"
doc_dirty_output=$(run_in_tmp node "$status_cli" start docs-hint --level S --topology local 2>&1 || true)
if printf '%s' "$doc_dirty_output" | rg -q '用户预先编写的需求输入，已纳入 B0 基线'; then
  printf 'PASS pure untracked documentation diff receives the B0 hint\n'
else
  printf 'FAIL pure untracked documentation diff did not receive the B0 hint\n'
  failures=$((failures + 1))
fi
rm -f "$tmp/docs/requirement-input.md"
printf '%s\n' 'unrelated legacy diff (content must not be printed)' > "$tmp/src/business.js"
printf '%s\n' 'mixed documentation input' > "$tmp/docs/mixed-input.md"
dirty_output=$(run_in_tmp node "$status_cli" start dirty-missing-disposition --level S \
  --topology local --risk-labels external 2>&1 || true)
if printf '%s' "$dirty_output" | rg -q 'src/business.js' \
  && ! printf '%s' "$dirty_output" | rg -q 'content must not be printed' \
  && ! printf '%s' "$dirty_output" | rg -q '用户预先编写的需求输入，已纳入 B0 基线'; then
  printf 'PASS source or mixed dirty diff has no documentation-only hint\n'
else
  printf 'FAIL dirty start leaked content, omitted path, or showed a documentation-only hint\n'
  failures=$((failures + 1))
fi
rm -f "$tmp/docs/mixed-input.md"
expect_pass run_in_tmp node "$status_cli" start unrelated-normal --level S \
  --topology local --risk-labels external --existing-diff unrelated \
  --reason 'pre-existing unrelated work'
expect_pass run_in_tmp node "$status_cli" confirm-human unrelated-normal implementation_approval \
  --status confirmed --evidence 'user approved implementation on the unrelated baseline'
approved_next=$(run_in_tmp node "$status_cli" next unrelated-normal)
if printf '%s' "$approved_next" | rg -q 'current_gate: implementation' \
  && printf '%s' "$approved_next" | rg -q 'blocked: no' \
  && printf '%s' "$approved_next" | rg -q 'blocker: none' \
  && printf '%s' "$approved_next" | rg -q 'command: /executing-plans'; then
  printf 'PASS next reports the actual post-approval gate and executable command\n'
else
  printf 'FAIL next reports a stale gate or invalid implementation command\n'
  failures=$((failures + 1))
fi
printf '%s\n' 'approved feature code plus legacy diff' > "$tmp/src/business.js"
expect_pass run_in_tmp node "$validator" authorization "$tmp" \
  .claude/runtime/dev-flow/write-authorization.json
expect_pass run_in_tmp node "$status_cli" activate unrelated-normal
expect_pass run_in_tmp node "$status_cli" confirm-human unrelated-normal implementation_approval \
  --status confirmed --evidence 'user reconfirmed the approved implementation after code changes'
expect_pass run_in_tmp node "$validator" authorization "$tmp" \
  .claude/runtime/dev-flow/write-authorization.json
printf '%s\n' 'baseline' > "$tmp/src/business.js"

expect_pass run_in_tmp node "$status_cli" start preapproval-drift --level S \
  --topology local --risk-labels external
baseline_before=$(sed -n 's/^    baseline_business_diff_fingerprint: "\([0-9a-f]*\)"/\1/p' \
  "$tmp/docs/dev-flow/features/preapproval-drift/status.md")
printf '%s\n' 'unauthorized preapproval business write' > "$tmp/src/business.js"
status_before=$(shasum -a 256 "$tmp/docs/dev-flow/features/preapproval-drift/status.md" | awk '{print $1}')
auth_before=$(shasum -a 256 "$tmp/.claude/runtime/dev-flow/write-authorization.json" | awk '{print $1}')
expect_fail run_in_tmp node "$status_cli" confirm-human preapproval-drift implementation_approval \
  --status confirmed --evidence 'user approved after accidental implementation'
status_after=$(shasum -a 256 "$tmp/docs/dev-flow/features/preapproval-drift/status.md" | awk '{print $1}')
auth_after=$(shasum -a 256 "$tmp/.claude/runtime/dev-flow/write-authorization.json" | awk '{print $1}')
if [ "$status_before" = "$status_after" ] && [ "$auth_before" = "$auth_after" ]; then
  printf 'PASS preapproval fingerprint drift fails with zero status/auth mutations\n'
else
  printf 'FAIL preapproval fingerprint drift mutated status or authorization\n'
  failures=$((failures + 1))
fi
expect_pass run_in_tmp node "$status_cli" mark-retrospective preapproval-drift \
  --reason 'implementation began before approval'
baseline_after=$(sed -n 's/^    baseline_business_diff_fingerprint: "\([0-9a-f]*\)"/\1/p' \
  "$tmp/docs/dev-flow/features/preapproval-drift/status.md")
if [ "$baseline_before" = "$baseline_after" ]; then
  printf 'PASS mark-retrospective preserves the original baseline fingerprint\n'
else
  printf 'FAIL mark-retrospective refreshed the original baseline\n'
  failures=$((failures + 1))
fi
expect_pass run_in_tmp node "$status_cli" confirm-human preapproval-drift implementation_approval \
  --status confirmed --evidence 'user approved retrospective review and repair'
expect_pass run_in_tmp node "$status_cli" scaffold preapproval-drift --asset completion
expect_contains "$tmp/docs/dev-flow/features/preapproval-drift/completion.md" 'schema_version: "2"'
expect_contains "$tmp/docs/dev-flow/features/preapproval-drift/completion.md" 'process_mode: "retrospective"'
expect_contains "$tmp/docs/dev-flow/features/preapproval-drift/completion.md" 'retrospective_reason: "implementation began before approval"'
expect_fail run_in_tmp node "$status_cli" scaffold preapproval-drift --asset code-review --refresh
expect_pass run_in_tmp node "$status_cli" scaffold preapproval-drift --asset completion --refresh
cp "$tmp/docs/dev-flow/features/preapproval-drift/status.md" \
  "$tmp/docs/dev-flow/features/preapproval-drift/status.basis-backup"
sed -i.bak 's/baseline_business_diff_fingerprint: "[0-9a-f]*"/baseline_business_diff_fingerprint: "ffffffffffffffffffffffffffffffffffffffff"/' \
  "$tmp/docs/dev-flow/features/preapproval-drift/status.md"
expect_fail run_in_tmp node "$validator" authorization "$tmp" \
  .claude/runtime/dev-flow/write-authorization.json
mv "$tmp/docs/dev-flow/features/preapproval-drift/status.basis-backup" \
  "$tmp/docs/dev-flow/features/preapproval-drift/status.md"
printf '%s\n' 'baseline' > "$tmp/src/business.js"

# Every in-scope start is status-bearing, including no-risk XS/S and light M.
