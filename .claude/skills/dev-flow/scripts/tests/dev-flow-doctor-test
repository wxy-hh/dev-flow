#!/usr/bin/env bash
# Task 5 acceptance: doctor ready-to-finalize WARN for verified-unfinalized,
# plus package-level finish protocol checks.
set -u

root=$(cd "$(dirname "$0")/.." && pwd)
repo=$(cd "$root/../../../.." && pwd)
doctor="$root/dev-flow-doctor"
hooks_root=$(cd "$root/../../../hooks" && pwd)
finish_guard="$hooks_root/dev-flow-finish-guard.sh"
fingerprint_cmd="$root/dev-flow-fingerprint"
policy_cmd="$root/dev-flow-policy.mjs"

tmp=$(mktemp -d "${TMPDIR:-/tmp}/dev-flow-doctor.XXXXXX")
trap 'rm -rf "$tmp"' EXIT

failures=0

assert_eq() {
  local desc=$1 expected=$2 actual=$3
  if [ "$expected" = "$actual" ]; then
    printf 'PASS %s\n' "$desc"
  else
    printf 'FAIL %s (expected=%s actual=%s)\n' "$desc" "$expected" "$actual"
    failures=$((failures + 1))
  fi
}

assert_contains() {
  local desc=$1 needle=$2 haystack=$3
  if printf '%s' "$haystack" | rg -q -- "$needle"; then
    printf 'PASS %s\n' "$desc"
  else
    printf 'FAIL %s (missing: %s)\n' "$desc" "$needle"
    failures=$((failures + 1))
  fi
}

assert_not_contains() {
  local desc=$1 needle=$2 haystack=$3
  if printf '%s' "$haystack" | rg -q -- "$needle"; then
    printf 'FAIL %s (unexpected: %s)\n' "$desc" "$needle"
    failures=$((failures + 1))
  else
    printf 'PASS %s\n' "$desc"
  fi
}

# ---------- package-level doctor (source migration package) ----------
pkg_out=$("$doctor" 2>&1)
pkg_rc=$?
assert_eq 'package doctor exits 0' 0 "$pkg_rc"
assert_contains 'package doctor documents ASSET FINALIZATION' 'finish.md documents ASSET FINALIZATION stop protocol' "$pkg_out"
assert_contains 'package doctor requires inventory on confirm docs' 'finishing skill requires --inventory on confirm' "$pkg_out"
assert_contains 'package doctor checks complete-verification orchestration' 'finish.md records verification through status CLI before feature-check' "$pkg_out"
assert_contains 'package doctor checks project default retention' 'finish.md derives dry-run retention from project config' "$pkg_out"
assert_contains 'package doctor checks finish-guard verified-unfinalized' 'finish-guard handles verified-unfinalized' "$pkg_out"
assert_contains 'package doctor skips feature scan without project-workflow' 'skip verified-unfinalized scan' "$pkg_out"
assert_not_contains 'package doctor has no ready-to-finalize WARN without features' 'ready-to-finalize' "$pkg_out"

# An unmanaged project skill may exceed the package budget without making the
# reusable dev-flow doctor fail; only manifest-owned skills are budgeted.
scope_tmp="$tmp/managed-scope"
mkdir -p "$scope_tmp"
cp -R "$repo/.claude" "$scope_tmp/.claude"
cp -R "$repo/docs" "$scope_tmp/docs"
cp -R "$repo/templates" "$scope_tmp/templates"
cp "$repo/README.md" "$scope_tmp/README.md"
cp "$repo/.gitignore" "$scope_tmp/.gitignore"
mkdir -p "$scope_tmp/.claude/skills/custom-over-budget"
for i in $(seq 1 220); do
  printf 'custom project rule %s\n' "$i"
done > "$scope_tmp/.claude/skills/custom-over-budget/SKILL.md"
git -C "$scope_tmp" init -q
scope_out=$(cd "$scope_tmp" && .claude/skills/dev-flow/scripts/dev-flow-doctor 2>&1)
scope_rc=$?
assert_eq 'doctor ignores unmanaged custom skill line budget' 0 "$scope_rc"
assert_not_contains 'custom skill is outside line-budget report' 'custom-over-budget/SKILL.md' "$scope_out"
rm -rf "$scope_tmp"

# ---------- simulated onboarded project with three feature shapes ----------
mkdir -p \
  "$tmp/.claude/rules" \
  "$tmp/.claude/skills/dev-flow/scripts" \
  "$tmp/.claude/hooks" \
  "$tmp/.claude/runtime/dev-flow" \
  "$tmp/docs/dev-flow/features/active-feature" \
  "$tmp/docs/dev-flow/features/verified-unfinalized" \
  "$tmp/docs/dev-flow/features/legacy-finalized" \
  "$tmp/docs/dev-flow/reviews" \
  "$tmp/src"

# Minimal onboarded workflow so doctor scans features. Other package checks
# still run against the real repo when we invoke doctor from $root; for the
# feature WARN path we exercise a small inline scanner matching doctor logic.
printf '%s\n' \
  'dev_flow:' \
  '  paths:' \
  '    feature_root: docs/dev-flow/features' \
  '    review_root: docs/dev-flow/reviews' \
  '  verification:' \
  '    webapp_testing: "disabled"' \
  '  artifacts:' \
  '    retention: "compact"' \
  '  enforcement_mode: "ask"' \
  '  protected_write_roots:' \
  '    - "src/**"' \
  > "$tmp/.claude/rules/project-workflow.md"

# active: status only
printf '%s\n' \
  '---' \
  'dev_flow_status:' \
  '  schema_version: "3"' \
  '  feature_id: "active-feature"' \
  '  level: "S"' \
  '---' > "$tmp/docs/dev-flow/features/active-feature/status.md"

# verified-unfinalized: status + completion
printf '%s\n' \
  '---' \
  'dev_flow_status:' \
  '  schema_version: "3"' \
  '  feature_id: "verified-unfinalized"' \
  '  level: "S"' \
  '---' > "$tmp/docs/dev-flow/features/verified-unfinalized/status.md"
workflow_version=$(node "$policy_cmd" version)
printf '%s\n' \
  '---' \
  'dev_flow_completion:' \
  '  retention: "compact"' \
  '  outcome: "verified"' \
  "  workflow_version: \"$workflow_version\"" \
  '---' \
  '# completion' > "$tmp/docs/dev-flow/features/verified-unfinalized/completion.md"
printf '%s\n' '# feature' > "$tmp/docs/dev-flow/features/verified-unfinalized/feature.md"

# legacy-finalized: completion only (no status)
printf '%s\n' \
  '---' \
  'dev_flow_completion:' \
  '  retention: "compact"' \
  '  outcome: "verified"' \
  '---' \
  '# legacy completion' > "$tmp/docs/dev-flow/features/legacy-finalized/completion.md"
printf '%s\n' '# feature' > "$tmp/docs/dev-flow/features/legacy-finalized/feature.md"

# Inline scan mirroring doctor "在途 feature" section.
scan_unfinalized() {
  local feature_root=$1
  local out=""
  local n=0
  while IFS= read -r feature_dir; do
    [ -z "$feature_dir" ] && continue
    [ -f "$feature_dir/status.md" ] || continue
    [ -f "$feature_dir/completion.md" ] || continue
    feature_id=$(basename "$feature_dir")
    out="${out}WARN ready-to-finalize: feature ${feature_id} is verified-unfinalized"$'\n'
    n=$((n + 1))
  done < <(find "$feature_root" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort)
  if [ "$n" -eq 0 ]; then
    out="${out}PASS no verified-unfinalized features"$'\n'
  fi
  printf '%s' "$out"
}

scan_out=$(scan_unfinalized "$tmp/docs/dev-flow/features")
assert_contains 'scan WARNs verified-unfinalized only' \
  'ready-to-finalize: feature verified-unfinalized is verified-unfinalized' "$scan_out"
assert_not_contains 'scan ignores active-only feature' \
  'feature active-feature' "$scan_out"
assert_not_contains 'scan ignores legacy-finalized (no status)' \
  'feature legacy-finalized' "$scan_out"
warn_count=$(printf '%s' "$scan_out" | rg -c 'ready-to-finalize' || true)
assert_eq 'exactly one ready-to-finalize WARN' 1 "$warn_count"

# ---------- finish-guard interaction with the three shapes ----------
# Install a minimal hook environment under tmp so finish-guard resolves scripts.
cp "$fingerprint_cmd" "$tmp/.claude/skills/dev-flow/scripts/dev-flow-fingerprint"
cp "$policy_cmd" "$tmp/.claude/skills/dev-flow/scripts/dev-flow-policy.mjs"
cp "$finish_guard" "$tmp/.claude/hooks/dev-flow-finish-guard.sh"
chmod +x "$tmp/.claude/skills/dev-flow/scripts/dev-flow-fingerprint" \
  "$tmp/.claude/hooks/dev-flow-finish-guard.sh"
# policy.mjs may import siblings; copy contract for version lookup if needed.
mkdir -p "$tmp/.claude/skills/dev-flow"
if [ -f "$root/../contract.json" ]; then
  cp "$root/../contract.json" "$tmp/.claude/skills/dev-flow/contract.json"
elif [ -f "$root/../../dev-flow/contract.json" ]; then
  cp "$root/../../dev-flow/contract.json" "$tmp/.claude/skills/dev-flow/contract.json"
else
  # Prefer real package contract via relative path from scripts/
  cp "$(cd "$root/.." && pwd)/contract.json" "$tmp/.claude/skills/dev-flow/contract.json" 2>/dev/null || true
fi

git -C "$tmp" init -q
printf '%s\n' 'baseline' > "$tmp/src/business.js"
git -C "$tmp" add .
git -C "$tmp" -c user.name='dev-flow test' -c user.email='dev-flow@example.test' commit -qm baseline

run_guard() {
  local cmd=$1
  (cd "$tmp" && printf '{"tool_name":"Bash","tool_input":{"command":"%s"}}' "$cmd" \
    | "$tmp/.claude/hooks/dev-flow-finish-guard.sh")
}

# active feature without stamp → ask
out=$(run_guard "git commit -am wip")
assert_contains 'guard asks for active feature without stamp' 'permissionDecision":"ask"' "$out"

# stamp verified-unfinalized; active still unstamped so overall ask
workflow_version=$(node "$policy_cmd" version)
fp=$(cd "$tmp" && "$fingerprint_cmd" docs/dev-flow/features docs/dev-flow/reviews)
printf 'workflow_version: %s\nfingerprint: %s\noutcome: verified\nchecked_at: 2026-01-01T00:00:00Z\n' \
  "$workflow_version" "$fp" > "$tmp/.claude/runtime/dev-flow/verified-unfinalized.check-ok"
printf 'workflow_version: %s\nfingerprint: %s\noutcome: verified\nchecked_at: 2026-01-01T00:00:00Z\n' \
  "$workflow_version" "$fp" > "$tmp/.claude/runtime/dev-flow/active-feature.check-ok"

out=$(run_guard "git commit -am wip")
assert_contains 'guard asks while any verified-unfinalized feature remains' 'verified-unfinalized' "$out"

# remove active status so only verified-unfinalized remains → still ask
rm -f "$tmp/docs/dev-flow/features/active-feature/status.md"
out=$(run_guard "git push origin main")
assert_contains 'guard asks solely for verified-unfinalized' 'verified-unfinalized' "$out"

# finalize verified-unfinalized (drop status) → allow (legacy-finalized already has no status)
rm -f "$tmp/docs/dev-flow/features/verified-unfinalized/status.md"
out=$(run_guard "git commit -am wip")
if [ -z "$out" ]; then
  printf 'PASS guard allows when only finalized features remain\n'
else
  printf 'FAIL expected allow after finalization (got: %s)\n' "$out"
  failures=$((failures + 1))
fi

printf '\nSummary: %s failure(s)\n' "$failures"
[ "$failures" -eq 0 ]
