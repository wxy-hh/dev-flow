#!/usr/bin/env bash
# Tests for dev-flow-upgrade / manifest / v0.8 in-flight migration.
set -u

root=$(cd "$(dirname "$0")/.." && pwd)
repo=$(cd "$root/../../../.." && pwd)
upgrade="$root/dev-flow-upgrade"
manifest_cmd="$root/dev-flow-manifest"
tmp=$(mktemp -d "${TMPDIR:-/tmp}/dev-flow-upgrade.XXXXXX")
trap 'rm -rf "$tmp"' EXIT

failures=0
pass() { printf 'PASS %s\n' "$1"; }
fail() { printf 'FAIL %s\n' "$1"; failures=$((failures + 1)); }

# Ensure source manifest exists
(cd "$repo" && "$manifest_cmd" build --out .claude/dev-flow.manifest.json) >/dev/null

# ---------------------------------------------------------------------------
# Fixture target: old-style layout with drift + deprecated + custom skill +
# project-workflow + legacy SDD + auth + check-ok + three feature types
# ---------------------------------------------------------------------------
target="$tmp/target"
mkdir -p \
  "$target/.claude/skills/custom-team" \
  "$target/.claude/skills/grilling" \
  "$target/.claude/rules" \
  "$target/.claude/hooks" \
  "$target/.claude/runtime/dev-flow" \
  "$target/.claude/runtime/sdd/feat-keep" \
  "$target/docs/dev-flow/features/feat-active" \
  "$target/docs/dev-flow/features/feat-verified" \
  "$target/docs/dev-flow/features/feat-legacy" \
  "$target/docs/dev-flow/features/feat-legacy/archive/2026-01-01T000000Z/feature" \
  "$target/src"

git -C "$target" init -q

printf '%s\n' 'custom skill' > "$target/.claude/skills/custom-team/SKILL.md"
printf '%s\n' 'stale grilling' > "$target/.claude/skills/grilling/SKILL.md"
printf '%s\n' '# Vue 3 rules (deprecated package leak)' > "$target/.claude/rules/vue3.md"

printf '%s\n' \
  'dev_flow:' \
  '  version: "0.6.0"' \
  '  paths:' \
  '    feature_root: docs/dev-flow/features' \
  '    review_root: docs/dev-flow/reviews' \
  '  verification:' \
  '    webapp_testing: "disabled"' \
  '  artifacts:' \
  '    retention: "compact"' \
  > "$target/.claude/rules/project-workflow.md"

# partial old managed files (drift)
mkdir -p "$target/.claude/skills/dev-flow"
printf '%s\n' '{"workflow_version":"0.6.0"}' > "$target/.claude/skills/dev-flow/contract.json"
printf '%s\n' 'old skill' > "$target/.claude/skills/dev-flow/SKILL.md"
printf '%s\n' '{"hooks":{"PreToolUse":[{"matcher":"Bash","hooks":[{"type":"command","command":"echo custom"}]}]}}' \
  > "$target/.claude/settings.json"
printf '%s\n' 'baseline' > "$target/src/a.js"

# Old authorization + check-ok stamps (must be invalidated on successful apply)
printf '%s\n' '{"state":"approved","feature_id":"feat-active","workflow_version":"0.7.0"}' \
  > "$target/.claude/runtime/dev-flow/write-authorization.json"
printf '%s\n' 'workflow_version: 0.7.0' 'fingerprint: old' 'outcome: verified' \
  > "$target/.claude/runtime/dev-flow/feat-active.check-ok"
printf '%s\n' 'workflow_version: 0.7.0' 'fingerprint: old' 'outcome: verified' \
  > "$target/.claude/runtime/dev-flow/feat-verified.check-ok"

# Legacy shared SDD top-level files (must quarantine) + feature-scoped dir (must keep)
printf '%s\n' 'legacy progress' > "$target/.claude/runtime/sdd/progress.md"
printf '%s\n' 'legacy task' > "$target/.claude/runtime/sdd/task-1.md"
printf '%s\n' 'feature scoped progress' > "$target/.claude/runtime/sdd/feat-keep/progress.md"

# Three feature types (must be left alone by upgrade)
printf '%s\n' '---' 'feature_id: feat-active' 'current_gate: implementation' '---' '# active' \
  > "$target/docs/dev-flow/features/feat-active/status.md"
printf '%s\n' 'active feature body' \
  > "$target/docs/dev-flow/features/feat-active/需求说明书.md"

printf '%s\n' '---' 'feature_id: feat-verified' 'current_gate: verification' '---' '# verified' \
  > "$target/docs/dev-flow/features/feat-verified/status.md"
printf '%s\n' '---' 'feature_id: feat-verified' 'outcome: verified' '---' '# completion' \
  > "$target/docs/dev-flow/features/feat-verified/completion.md"
printf '%s\n' 'mid asset' \
  > "$target/docs/dev-flow/features/feat-verified/实现计划.md"

printf '%s\n' '---' 'feature_id: feat-legacy' 'outcome: verified' '---' '# legacy completion' \
  > "$target/docs/dev-flow/features/feat-legacy/completion.md"
printf '%s\n' 'feature.md retained' \
  > "$target/docs/dev-flow/features/feat-legacy/feature.md"
printf '%s\n' 'archived mid' \
  > "$target/docs/dev-flow/features/feat-legacy/archive/2026-01-01T000000Z/feature/实现计划.md"

git -C "$target" add .
git -C "$target" -c user.name=t -c user.email=t@t commit -qm base

# Snapshot of feature assets to compare after apply
snapshot_features() {
  find "$target/docs/dev-flow/features" -type f | sort | while IFS= read -r f; do
    printf '%s\t%s\n' "${f#"$target/"}" "$(cksum < "$f" | awk '{print $1" "$2}')"
  done
}
pre_features=$(snapshot_features)

# ---------------------------------------------------------------------------
# --check should report drift/missing
# ---------------------------------------------------------------------------
if (cd "$repo" && "$upgrade" --target "$target" --check) >/tmp/upgrade-check.out 2>&1; then
  fail "check should fail on drifted target"
else
  if rg -q 'DRIFT|MISSING' /tmp/upgrade-check.out; then
    pass "check reports drift/missing"
  else
    fail "check output lacks DRIFT/MISSING"
    cat /tmp/upgrade-check.out
  fi
fi

if rg -q 'DEPRECATED_PRESENT.*vue3' /tmp/upgrade-check.out || rg -q 'DEPRECATED_PRESENT .claude/rules/vue3.md' /tmp/upgrade-check.out; then
  pass "check reports deprecated vue3 present"
else
  # DEPRECATED_PRESENT may still print for grilling; vue3 is also deprecated
  if rg -q 'DEPRECATED_PRESENT' /tmp/upgrade-check.out; then
    pass "check reports deprecated paths present"
  else
    fail "check should report DEPRECATED_PRESENT"
    cat /tmp/upgrade-check.out
  fi
fi

# ---------------------------------------------------------------------------
# v1.0: continue refusing apply while a pre-v1.0 active status exists.
# ---------------------------------------------------------------------------
if (cd "$repo" && "$upgrade" --target "$target" --apply) >/tmp/upgrade-refuse.out 2>&1; then
  fail "apply should refuse when active status exists"
  cat /tmp/upgrade-refuse.out
else
  if rg -q 'active pre-v1.0 feature status present' /tmp/upgrade-refuse.out; then
    pass "apply refuses active feature status with zero mutations"
  else
    fail "apply refuses active feature status with zero mutations"
    cat /tmp/upgrade-refuse.out
  fi
fi
mkdir -p "$target/.claude/runtime/dev-flow/held-status"
cp "$target/docs/dev-flow/features/feat-active/status.md" \
  "$target/.claude/runtime/dev-flow/held-status/feat-active-status.md" 2>/dev/null || true
cp "$target/docs/dev-flow/features/feat-verified/status.md" \
  "$target/.claude/runtime/dev-flow/held-status/feat-verified-status.md" 2>/dev/null || true
rm -f "$target/docs/dev-flow/features/feat-active/status.md" \
  "$target/docs/dev-flow/features/feat-verified/status.md"

if (cd "$repo" && "$upgrade" --target "$target" --apply) >/tmp/upgrade-apply.out 2>&1; then
  pass "apply succeeds"
  cp "$target/.claude/runtime/dev-flow/held-status/feat-active-status.md" \
    "$target/docs/dev-flow/features/feat-active/status.md" 2>/dev/null || true
  cp "$target/.claude/runtime/dev-flow/held-status/feat-verified-status.md" \
    "$target/docs/dev-flow/features/feat-verified/status.md" 2>/dev/null || true
else
  fail "apply failed"
  cat /tmp/upgrade-apply.out
fi

if [ -f "$target/.claude/skills/custom-team/SKILL.md" ]; then
  pass "custom skill preserved"
else
  fail "custom skill preserved"
fi
if [ -f "$target/.claude/rules/project-workflow.md" ]; then
  pass "project-workflow preserved"
else
  fail "project-workflow preserved"
fi
if rg -q 'enforcement_mode: "ask"' "$target/.claude/rules/project-workflow.md"; then
  pass "upgrade set enforcement_mode ask on old project-workflow"
else
  fail "upgrade set enforcement_mode ask on old project-workflow"
fi
current_version=$(node -e 'process.stdout.write(JSON.parse(require("fs").readFileSync(process.argv[1], "utf8")).workflow_version)' "$repo/.claude/skills/dev-flow/contract.json")
if rg -q "^  version: \"$current_version\"$" "$target/.claude/rules/project-workflow.md"; then
  pass "upgrade synchronized project-workflow version from contract"
else
  fail "upgrade synchronized project-workflow version from contract"
fi
if [ ! -e "$target/.claude/skills/grilling" ]; then
  pass "deprecated grilling removed"
else
  fail "deprecated grilling removed"
fi
if [ ! -e "$target/.claude/rules/vue3.md" ]; then
  pass "deprecated vue3.md removed"
else
  fail "deprecated vue3.md removed"
fi
if [ -f "$target/.claude/skills/dev-flow/scripts/dev-flow-status.mjs" ]; then
  pass "new status CLI installed"
else
  fail "new status CLI installed"
fi
if rg -q 'dev-flow-gate-guard' "$target/.claude/settings.json" && rg -q 'echo custom' "$target/.claude/settings.json"; then
  pass "settings hooks merged (dev-flow + custom retained)"
else
  fail "settings hooks merged (dev-flow + custom retained)"
  cat "$target/.claude/settings.json"
fi

# post-apply check clean
if (cd "$repo" && "$upgrade" --target "$target" --check) >/tmp/upgrade-check2.out 2>&1; then
  pass "post-apply check is clean"
else
  fail "post-apply check is clean"
  cat /tmp/upgrade-check2.out | head -30
fi

# backup dir exists
backup_dir=$(ls -d "$target/.claude/runtime/dev-flow"/upgrade-backup-* 2>/dev/null | head -1)
if [ -n "$backup_dir" ] && [ -d "$backup_dir" ]; then
  pass "upgrade backup directory created"
  if basename "$backup_dir" | rg -q '^upgrade-backup-[0-9]{8}T[0-9]{6}Z\.[A-Za-z0-9]+$'; then
    pass "upgrade backup path has a collision-resistant suffix"
  else
    fail "upgrade backup path has a collision-resistant suffix"
  fi
else
  fail "upgrade backup directory created"
  backup_dir=""
fi

# vue3 in backup (file path, not only dirs)
if [ -n "$backup_dir" ] && [ -f "$backup_dir/.claude/rules/vue3.md" ]; then
  pass "vue3.md backed up (file-or-dir backup works)"
else
  fail "vue3.md backed up (file-or-dir backup works)"
  [ -n "$backup_dir" ] && find "$backup_dir" -name 'vue3.md' 2>/dev/null
fi

# auth invalidated
if [ ! -e "$target/.claude/runtime/dev-flow/write-authorization.json" ]; then
  pass "write-authorization.json invalidated"
else
  fail "write-authorization.json invalidated"
fi
# auth in backup
if [ -n "$backup_dir" ] && [ -f "$backup_dir/.claude/runtime/dev-flow/write-authorization.json" ]; then
  pass "write-authorization.json backed up"
else
  fail "write-authorization.json backed up"
fi

# check-ok invalidated
if [ ! -e "$target/.claude/runtime/dev-flow/feat-active.check-ok" ] \
  && [ ! -e "$target/.claude/runtime/dev-flow/feat-verified.check-ok" ]; then
  pass "check-ok stamps invalidated"
else
  fail "check-ok stamps invalidated"
fi
if [ -n "$backup_dir" ] \
  && [ -f "$backup_dir/.claude/runtime/dev-flow/feat-active.check-ok" ] \
  && [ -f "$backup_dir/.claude/runtime/dev-flow/feat-verified.check-ok" ]; then
  pass "check-ok stamps backed up"
else
  fail "check-ok stamps backed up"
fi

# legacy shared SDD quarantined
if [ ! -e "$target/.claude/runtime/sdd/progress.md" ] \
  && [ ! -e "$target/.claude/runtime/sdd/task-1.md" ]; then
  pass "legacy shared SDD top-level files quarantined"
else
  fail "legacy shared SDD top-level files quarantined"
fi
if [ -n "$backup_dir" ] \
  && [ -f "$backup_dir/legacy-sdd/progress.md" ] \
  && [ -f "$backup_dir/legacy-sdd/task-1.md" ]; then
  pass "legacy SDD stored under backup/legacy-sdd/"
else
  fail "legacy SDD stored under backup/legacy-sdd/"
  [ -n "$backup_dir" ] && find "$backup_dir" -type f 2>/dev/null | head -40
fi

# feature-scoped SDD kept
if [ -f "$target/.claude/runtime/sdd/feat-keep/progress.md" ]; then
  pass "feature-scoped SDD directory preserved"
else
  fail "feature-scoped SDD directory preserved"
fi

# three feature types + archive untouched
post_features=$(snapshot_features)
if [ "$pre_features" = "$post_features" ]; then
  pass "in-flight feature assets untouched (active/verified/legacy + archive)"
else
  fail "in-flight feature assets untouched (active/verified/legacy + archive)"
  printf 'PRE:\n%s\nPOST:\n%s\n' "$pre_features" "$post_features"
fi

# ---------------------------------------------------------------------------
# Full rollback test: force preflight failure mid-apply
# Use a fresh target2 with the same migration fixtures; break hooks after
# candidate build by making doctor preflight fail via missing gate-guard
# registration — inject by removing executable bit on source doctor is hard.
# Instead: plant a broken settings that preflight fails, but first apply once
# with a sabotaged candidate: copy target, then run apply while temporarily
# wrapping doctor to always fail after the managed copy.
# ---------------------------------------------------------------------------
target2="$tmp/target2"
mkdir -p \
  "$target2/.claude/skills/custom-team" \
  "$target2/.claude/skills/grilling" \
  "$target2/.claude/rules" \
  "$target2/.claude/hooks" \
  "$target2/.claude/runtime/dev-flow" \
  "$target2/.claude/runtime/sdd" \
  "$target2/docs/dev-flow/features/feat-active" \
  "$target2/src"
git -C "$target2" init -q

printf '%s\n' 'custom skill' > "$target2/.claude/skills/custom-team/SKILL.md"
printf '%s\n' 'stale grilling' > "$target2/.claude/skills/grilling/SKILL.md"
printf '%s\n' '# Vue 3 rules' > "$target2/.claude/rules/vue3.md"
printf '%s\n' \
  'dev_flow:' \
  '  version: "0.6.0"' \
  '  paths:' \
  '    feature_root: docs/dev-flow/features' \
  '    review_root: docs/dev-flow/reviews' \
  '  verification:' \
  '    webapp_testing: "disabled"' \
  '  artifacts:' \
  '    retention: "compact"' \
  > "$target2/.claude/rules/project-workflow.md"
mkdir -p "$target2/.claude/skills/dev-flow"
printf '%s\n' '{"workflow_version":"0.6.0"}' > "$target2/.claude/skills/dev-flow/contract.json"
printf '%s\n' 'old skill' > "$target2/.claude/skills/dev-flow/SKILL.md"
# settings WITHOUT hooks → preflight will fail after apply copies managed files
# but wait: apply copies source settings which HAS hooks. So preflight would pass.
# Force failure: plant a broken project-workflow with strict + empty roots AFTER
# we need preflight to fail. The upgrade script sets ask only if enforcement_mode
# is missing. So plant strict + empty protected_write_roots:
printf '%s\n' \
  'dev_flow:' \
  '  enforcement_mode: "strict"' \
  '  protected_write_roots: []' \
  '  paths:' \
  '    feature_root: docs/dev-flow/features' \
  '    review_root: docs/dev-flow/reviews' \
  '  verification:' \
  '    webapp_testing: "disabled"' \
  '  artifacts:' \
  '    retention: "compact"' \
  > "$target2/.claude/rules/project-workflow.md"

printf '%s\n' '{"hooks":{"PreToolUse":[{"matcher":"Bash","hooks":[{"type":"command","command":"echo custom"}]}]}}' \
  > "$target2/.claude/settings.json"
printf '%s\n' 'baseline' > "$target2/src/a.js"
printf '%s\n' '{"state":"approved","feature_id":"feat-active"}' \
  > "$target2/.claude/runtime/dev-flow/write-authorization.json"
printf '%s\n' 'workflow_version: 0.7.0' \
  > "$target2/.claude/runtime/dev-flow/feat-active.check-ok"
printf '%s\n' 'legacy progress' > "$target2/.claude/runtime/sdd/progress.md"
printf '%s\n' 'legacy task' > "$target2/.claude/runtime/sdd/task-1.md"
# No active status.md: the pre-v1.0 refusal gate would block before preflight.
# Feature dir may exist without status for rollback of other assets.
printf '%s\n' '# feature note' > "$target2/docs/dev-flow/features/feat-active/note.md"

git -C "$target2" add .
git -C "$target2" -c user.name=t -c user.email=t@t commit -qm base

# Capture pre-state markers
pre_auth_hash=$(cksum < "$target2/.claude/runtime/dev-flow/write-authorization.json")
pre_checkok_hash=$(cksum < "$target2/.claude/runtime/dev-flow/feat-active.check-ok")
pre_vue3_hash=$(cksum < "$target2/.claude/rules/vue3.md")
pre_sdd_progress=$(cksum < "$target2/.claude/runtime/sdd/progress.md")
pre_grilling_hash=$(cksum < "$target2/.claude/skills/grilling/SKILL.md")
pre_contract=$(cksum < "$target2/.claude/skills/dev-flow/contract.json")
pre_project_workflow=$(cksum < "$target2/.claude/rules/project-workflow.md")
pre_note=$(cksum < "$target2/docs/dev-flow/features/feat-active/note.md")

if (cd "$repo" && "$upgrade" --target "$target2" --apply) >/tmp/upgrade-fail.out 2>&1; then
  fail "apply should fail when preflight fails (strict empty roots)"
  cat /tmp/upgrade-fail.out | head -40
else
  if rg -qi 'preflight failed|restor' /tmp/upgrade-fail.out; then
    pass "apply fails and restores on preflight failure"
  else
    fail "apply fails and restores on preflight failure"
    cat /tmp/upgrade-fail.out | head -40
  fi
fi

# Full rollback assertions
if [ -f "$target2/.claude/rules/vue3.md" ] \
  && [ "$(cksum < "$target2/.claude/rules/vue3.md")" = "$pre_vue3_hash" ]; then
  pass "rollback restores vue3.md"
else
  fail "rollback restores vue3.md"
fi
if [ -f "$target2/.claude/skills/grilling/SKILL.md" ] \
  && [ "$(cksum < "$target2/.claude/skills/grilling/SKILL.md")" = "$pre_grilling_hash" ]; then
  pass "rollback restores deprecated grilling"
else
  fail "rollback restores deprecated grilling"
fi
if [ -f "$target2/.claude/runtime/dev-flow/write-authorization.json" ] \
  && [ "$(cksum < "$target2/.claude/runtime/dev-flow/write-authorization.json")" = "$pre_auth_hash" ]; then
  pass "rollback restores write-authorization.json"
else
  fail "rollback restores write-authorization.json"
fi
if [ -f "$target2/.claude/runtime/dev-flow/feat-active.check-ok" ] \
  && [ "$(cksum < "$target2/.claude/runtime/dev-flow/feat-active.check-ok")" = "$pre_checkok_hash" ]; then
  pass "rollback restores check-ok stamp"
else
  fail "rollback restores check-ok stamp"
fi
if [ -f "$target2/.claude/runtime/sdd/progress.md" ] \
  && [ "$(cksum < "$target2/.claude/runtime/sdd/progress.md")" = "$pre_sdd_progress" ]; then
  pass "rollback restores legacy SDD files"
else
  fail "rollback restores legacy SDD files"
fi
if [ -f "$target2/.claude/skills/dev-flow/contract.json" ] \
  && [ "$(cksum < "$target2/.claude/skills/dev-flow/contract.json")" = "$pre_contract" ]; then
  pass "rollback restores managed contract.json"
else
  fail "rollback restores managed contract.json"
fi
if [ -f "$target2/.claude/rules/project-workflow.md" ] \
  && [ "$(cksum < "$target2/.claude/rules/project-workflow.md")" = "$pre_project_workflow" ]; then
  pass "rollback restores project-workflow version/default edits"
else
  fail "rollback restores project-workflow version/default edits"
fi
if [ -f "$target2/docs/dev-flow/features/feat-active/note.md" ] \
  && [ "$(cksum < "$target2/docs/dev-flow/features/feat-active/note.md")" = "$pre_note" ]; then
  pass "rollback leaves feature assets intact"
else
  fail "rollback leaves feature assets intact"
fi
if [ ! -e "$target2/.claude/commands/finish.md" ]; then
  pass "rollback removes managed files created by the failed apply"
else
  fail "rollback removes managed files created by the failed apply"
fi
if [ ! -e "$target2/.claude/dev-flow.manifest.json" ]; then
  pass "rollback restores absence of target manifest"
else
  fail "rollback restores absence of target manifest"
fi

# ---------------------------------------------------------------------------
# Post-preflight failure: invalidation is part of the transaction. Inject a
# failure after the first auth/stamp mutation and require the same full restore.
# ---------------------------------------------------------------------------
target3="$tmp/target3"
cp -R "$target2" "$target3"
sed 's/^  enforcement_mode: "strict"$/  enforcement_mode: "ask"/' \
  "$target3/.claude/rules/project-workflow.md" \
  > "$target3/.claude/rules/project-workflow.new"
mv "$target3/.claude/rules/project-workflow.new" \
  "$target3/.claude/rules/project-workflow.md"

pre3_auth=$(cksum < "$target3/.claude/runtime/dev-flow/write-authorization.json")
pre3_checkok=$(cksum < "$target3/.claude/runtime/dev-flow/feat-active.check-ok")
pre3_contract=$(cksum < "$target3/.claude/skills/dev-flow/contract.json")
pre3_workflow=$(cksum < "$target3/.claude/rules/project-workflow.md")

if (cd "$repo" && DEV_FLOW_UPGRADE_FAIL_AFTER_PREFLIGHT=1 \
  "$upgrade" --target "$target3" --apply) >/tmp/upgrade-post-preflight-fail.out 2>&1; then
  fail "apply should fail on injected post-preflight invalidation error"
else
  if rg -q 'injected failure after preflight|invalidation failed after preflight' \
    /tmp/upgrade-post-preflight-fail.out; then
    pass "post-preflight invalidation failure triggers rollback"
  else
    fail "post-preflight invalidation failure triggers rollback"
    head -40 /tmp/upgrade-post-preflight-fail.out
  fi
fi

if [ "$(cksum < "$target3/.claude/runtime/dev-flow/write-authorization.json")" = "$pre3_auth" ]; then
  pass "post-preflight rollback restores write authorization"
else
  fail "post-preflight rollback restores write authorization"
fi
if [ "$(cksum < "$target3/.claude/runtime/dev-flow/feat-active.check-ok")" = "$pre3_checkok" ]; then
  pass "post-preflight rollback restores check-ok stamp"
else
  fail "post-preflight rollback restores check-ok stamp"
fi
if [ "$(cksum < "$target3/.claude/skills/dev-flow/contract.json")" = "$pre3_contract" ]; then
  pass "post-preflight rollback restores managed files"
else
  fail "post-preflight rollback restores managed files"
fi
if [ "$(cksum < "$target3/.claude/rules/project-workflow.md")" = "$pre3_workflow" ]; then
  pass "post-preflight rollback restores project-workflow edits"
else
  fail "post-preflight rollback restores project-workflow edits"
fi
if [ ! -e "$target3/.claude/commands/finish.md" ] \
  && [ ! -e "$target3/.claude/dev-flow.manifest.json" ]; then
  pass "post-preflight rollback removes newly created managed files and manifest"
else
  fail "post-preflight rollback removes newly created managed files and manifest"
fi
if [ -f "$target3/.claude/runtime/sdd/progress.md" ] \
  && [ -f "$target3/.claude/rules/vue3.md" ] \
  && [ -f "$target3/.claude/skills/grilling/SKILL.md" ]; then
  pass "post-preflight rollback restores quarantined and deprecated paths"
else
  fail "post-preflight rollback restores quarantined and deprecated paths"
fi

# Upgrade is a mutator: managed/runtime paths may not traverse target symlinks.
target4="$tmp/target4"
external_runtime="$tmp/external-runtime"
mkdir -p "$target4/.claude" "$external_runtime"
printf '%s\n' 'external runtime sentinel' > "$external_runtime/sentinel"
external_before=$(cksum < "$external_runtime/sentinel")
ln -s "$external_runtime" "$target4/.claude/runtime"
if (cd "$repo" && "$upgrade" --target "$target4" --apply) \
  >/tmp/upgrade-symlink-fail.out 2>&1; then
  fail "upgrade rejects symlinked target mutation paths"
else
  if rg -q 'passes through a symbolic link' /tmp/upgrade-symlink-fail.out; then
    pass "upgrade rejects symlinked target mutation paths"
  else
    fail "upgrade rejects symlinked target mutation paths"
  fi
fi
if [ "$(cksum < "$external_runtime/sentinel")" = "$external_before" ] \
  && [ ! -e "$external_runtime/dev-flow" ]; then
  pass "rejected upgrade leaves the symlink target untouched"
else
  fail "rejected upgrade leaves the symlink target untouched"
fi

printf '\nSummary: %s failure(s)\n' "$failures"
[ "$failures" -eq 0 ]
