#!/usr/bin/env bash
set -u

root=$(cd "$(dirname "$0")/.." && pwd)
hooks_root=$(cd "$root/../../../hooks" && pwd)
gate_guard="$hooks_root/dev-flow-gate-guard.sh"
finish_guard="$hooks_root/dev-flow-finish-guard.sh"
fingerprint_cmd="$root/dev-flow-fingerprint"
status_cli="$root/dev-flow-status.mjs"

tmp=$(mktemp -d "${TMPDIR:-/tmp}/dev-flow-hooks.XXXXXX")
trap 'rm -rf "$tmp"' EXIT

failures=0

run_hook() {
  local hook=$1 payload=$2
  (cd "$tmp" && printf '%s' "$payload" | "$hook")
}

expect_decision() {
  local description=$1 hook=$2 payload=$3 decision=$4
  local output
  output=$(run_hook "$hook" "$payload")
  if printf '%s' "$output" | grep -q "\"permissionDecision\":\"$decision\""; then
    printf 'PASS %s\n' "$description"
  else
    printf 'FAIL expected %s: %s (got: %s)\n' "$decision" "$description" "$output"
    failures=$((failures + 1))
  fi
}

expect_ask() { expect_decision "$1" "$2" "$3" ask; }
expect_deny() { expect_decision "$1" "$2" "$3" deny; }

expect_allow() {
  local description=$1 hook=$2 payload=$3
  local output
  output=$(run_hook "$hook" "$payload")
  if [ -z "$output" ]; then
    printf 'PASS %s\n' "$description"
  else
    printf 'FAIL expected allow (empty output): %s (got: %s)\n' "$description" "$output"
    failures=$((failures + 1))
  fi
}

edit_payload() {
  printf '{"tool_name":"Edit","tool_input":{"file_path":"%s"}}' "$1"
}
commit_payload() {
  printf '{"tool_name":"Bash","tool_input":{"command":"%s"}}' "$1"
}

write_workflow() {
  local mode=$1
  printf '%s\n' \
    'dev_flow:' \
    '  paths:' \
    '    feature_root: docs/dev-flow/features' \
    '    review_root: docs/dev-flow/reviews' \
    '  verification:' \
    '    webapp_testing: "disabled"' \
    '  artifacts:' \
    '    retention: "compact"' \
    "  enforcement_mode: \"$mode\"" \
    '  protected_write_roots:' \
    '    - "src/**"' \
    > "$tmp/.claude/rules/project-workflow.md"
}

write_auth() {
  local state=$1
  mkdir -p "$tmp/.claude/runtime/dev-flow"
  printf '%s\n' \
    '{' \
    '  "feature_id": "demo",' \
    '  "level": "L",' \
    '  "profile": "standard",' \
    "  \"state\": \"$state\"," \
    '  "protected_roots": ["src/**"],' \
    '  "created_at": "2026-01-01T00:00:00Z",' \
    '  "approved_at": null' \
    '}' > "$tmp/.claude/runtime/dev-flow/write-authorization.json"
}

mkdir -p "$tmp/.claude/rules" "$tmp/docs/dev-flow/features/demo" "$tmp/docs/dev-flow/reviews" "$tmp/src" "$tmp/notes"
git -C "$tmp" init -q
write_workflow ask
printf '%s\n' 'baseline' > "$tmp/src/business.js"
printf '%s\n' 'note' > "$tmp/notes/readme.txt"
git -C "$tmp" add .
git -C "$tmp" -c user.name='dev-flow test' -c user.email='dev-flow@example.test' commit -qm baseline

# --- Model A: protected roots + authorization ---

# No auth, ask mode: protected path asks; unprotected allows; process paths allow.
expect_ask "ask mode: no auth asks on protected src path" "$gate_guard" "$(edit_payload "$tmp/src/business.js")"
expect_allow "ask mode: no auth allows unprotected notes path" "$gate_guard" "$(edit_payload "$tmp/notes/readme.txt")"
expect_allow "ask mode: allows feature_root writes without auth" "$gate_guard" "$(edit_payload "$tmp/docs/dev-flow/features/demo/status.md")"
expect_allow "ask mode: allows .claude writes without auth" "$gate_guard" "$(edit_payload "$tmp/.claude/rules/project-workflow.md")"
expect_allow "gate-guard allows when tool_input has no path" "$gate_guard" '{"tool_name":"Edit","tool_input":{}}'
expect_ask "gate-guard reads notebook_path for NotebookEdit" "$gate_guard" "$(printf '{"tool_name":"NotebookEdit","tool_input":{"notebook_path":"%s"}}' "$tmp/src/business.js")"

write_auth approval-pending
expect_ask "ask mode: approval-pending asks on protected path" "$gate_guard" "$(edit_payload "$tmp/src/business.js")"
expect_allow "ask mode: approval-pending still allows process paths" "$gate_guard" "$(edit_payload "$tmp/docs/dev-flow/features/demo/status.md")"
expect_ask "ask mode: approval-pending asks on ordinary Bash" "$gate_guard" "$(commit_payload "rm -rf src")"
expect_allow "ask mode: exact dev-flow control command is allowed" "$gate_guard" \
  "$(commit_payload "node .claude/skills/dev-flow/scripts/dev-flow-status.mjs --help")"
expect_ask "ask mode: chained dev-flow control command is rejected" "$gate_guard" \
  "$(commit_payload "dev-flow-status --help && rm -rf src")"
expect_ask "ask mode: piped dev-flow control command is rejected" "$gate_guard" \
  "$(commit_payload "dev-flow-status --help | rm -rf src")"
expect_ask "ask mode: control path in a later argv does not spoof control" "$gate_guard" \
  "$(commit_payload "rm -rf src .claude/skills/dev-flow/scripts/dev-flow-status.mjs")"
expect_allow "ask mode: single git add is delegated to finish-guard" "$gate_guard" "$(commit_payload "git add src/business.js")"
expect_ask "ask mode: chained git commit is not delegated" "$gate_guard" \
  "$(commit_payload "git commit -m x && rm -rf src")"

write_auth approved
expect_ask "ask mode: residual approved auth without status is stale" "$gate_guard" "$(edit_payload "$tmp/src/business.js")"

write_auth classified
expect_allow "ask mode: classified (XS/S) allows protected path" "$gate_guard" "$(edit_payload "$tmp/src/business.js")"

write_auth closed
expect_ask "ask mode: closed auth asks on protected path" "$gate_guard" "$(edit_payload "$tmp/src/business.js")"

# strict mode
write_workflow strict
rm -f "$tmp/.claude/runtime/dev-flow/write-authorization.json"
expect_deny "strict mode: no auth denies protected path" "$gate_guard" "$(edit_payload "$tmp/src/business.js")"
expect_allow "strict mode: no auth allows unprotected path" "$gate_guard" "$(edit_payload "$tmp/notes/readme.txt")"
expect_allow "strict mode: allows .claude path" "$gate_guard" "$(edit_payload "$tmp/.claude/rules/project-workflow.md")"

write_auth approval-pending
expect_deny "strict mode: approval-pending denies protected path" "$gate_guard" "$(edit_payload "$tmp/src/business.js")"
expect_deny "strict mode: approval-pending denies chained git commit" "$gate_guard" \
  "$(commit_payload "git commit -m x && rm -rf src")"
write_auth approved
expect_deny "strict mode: residual approved auth without status is stale" "$gate_guard" "$(edit_payload "$tmp/src/business.js")"
write_auth classified
expect_allow "strict mode: classified allows protected path" "$gate_guard" "$(edit_payload "$tmp/src/business.js")"

# off mode
write_workflow off
rm -f "$tmp/.claude/runtime/dev-flow/write-authorization.json"
expect_allow "off mode: always allows protected path" "$gate_guard" "$(edit_payload "$tmp/src/business.js")"

# empty protected roots => allow even in ask/strict (doctor will fail preflight for strict)
write_workflow strict
printf '%s\n' \
  'dev_flow:' \
  '  paths:' \
  '    feature_root: docs/dev-flow/features' \
  '    review_root: docs/dev-flow/reviews' \
  '  verification:' \
  '    webapp_testing: "disabled"' \
  '  artifacts:' \
  '    retention: "compact"' \
  '  enforcement_mode: "strict"' \
  '  protected_write_roots: []' \
  > "$tmp/.claude/rules/project-workflow.md"
expect_allow "strict with empty protected roots allows (no false deny-all)" "$gate_guard" "$(edit_payload "$tmp/src/business.js")"

# not onboarded
rm -f "$tmp/.claude/rules/project-workflow.md"
expect_allow "gate-guard allows when project is not onboarded" "$gate_guard" "$(edit_payload "$tmp/src/business.js")"
write_workflow ask

# --- dev-flow-finish-guard.sh ---
mkdir -p "$tmp/docs/dev-flow/features/demo"
printf '%s\n' \
  '---' \
  'dev_flow_status:' \
  '  schema_version: "3"' \
  '  feature_id: "demo"' \
  '  level: "L"' \
  '---' > "$tmp/docs/dev-flow/features/demo/status.md"

expect_ask "finish-guard asks on git commit with no check-ok stamp" "$finish_guard" "$(commit_payload "git commit -am wip")"
expect_ask "finish-guard asks on git push with no check-ok stamp" "$finish_guard" "$(commit_payload "git push origin main")"
expect_ask "finish-guard asks on git merge with no check-ok stamp" "$finish_guard" "$(commit_payload "git merge feature-x")"
expect_ask "finish-guard asks on git add with no check-ok stamp" "$finish_guard" "$(commit_payload "git add src/business.js")"
expect_ask "finish-guard rejects a chained git close-out command" "$finish_guard" \
  "$(commit_payload "git commit -m x && rm -rf src")"
expect_allow "finish-guard allows non-git bash commands" "$finish_guard" "$(commit_payload "ls -la")"
expect_allow "finish-guard allows git status" "$finish_guard" "$(commit_payload "git status")"

prepare_finishable_status() {
  rm -f "$tmp/docs/dev-flow/features/demo/status.md" "$tmp/.claude/runtime/dev-flow/write-authorization.json"
  run_hook_setup() { (cd "$tmp" && "$@"); }
  run_hook_setup node "$status_cli" init demo --level M --profile standard \
    --topology local --evidence-result verified --entry-gate writing-plans \
    --note 'hook fixture' >/dev/null || return 1
  run_hook_setup node "$status_cli" confirm-human demo requirement_confirmation \
    --status confirmed --evidence 'user confirmed hook requirements' >/dev/null || return 1
  printf '%s\n' '# plan' '### Task 1' '- implement' > "$tmp/docs/dev-flow/features/demo/plan.md"
  run_hook_setup node "$status_cli" add-asset demo \
    --path docs/dev-flow/features/demo/plan.md --kind plan >/dev/null || return 1
  run_hook_setup node "$status_cli" complete-gate demo writing-plans >/dev/null || return 1
  printf '%s\n' '# plan review' '## Findings' '- none' > "$tmp/docs/dev-flow/reviews/demo-plan-review.md"
  run_hook_setup node "$status_cli" add-asset demo \
    --path docs/dev-flow/reviews/demo-plan-review.md --kind review >/dev/null || return 1
  run_hook_setup node "$status_cli" complete-gate demo plan-review \
    --evidence-file docs/dev-flow/reviews/demo-plan-review.md --heading Findings >/dev/null || return 1
  run_hook_setup node "$status_cli" confirm-human demo implementation_approval \
    --status confirmed --evidence 'user approved hook implementation' >/dev/null || return 1
  printf '%s\n' '# code review' '## Findings' '- none' > "$tmp/docs/dev-flow/reviews/demo-code-review.md"
  run_hook_setup node "$status_cli" add-asset demo \
    --path docs/dev-flow/reviews/demo-code-review.md --kind review >/dev/null || return 1
  run_hook_setup node "$status_cli" complete-gate demo code-review \
    --evidence-file docs/dev-flow/reviews/demo-code-review.md --heading Findings >/dev/null || return 1
  printf '%s\n' '# verification' '- command passed' > "$tmp/docs/dev-flow/reviews/demo-verification.md"
  run_hook_setup node "$status_cli" complete-verification demo --command 'printf verification' \
    --report docs/dev-flow/reviews/demo-verification.md >/dev/null || return 1
}

if prepare_finishable_status; then
  printf 'PASS prepared finishable status through status CLI\n'
else
  printf 'FAIL could not prepare finishable status through status CLI\n'
  failures=$((failures + 1))
fi
expect_allow "valid approved auth allows protected Edit" "$gate_guard" "$(edit_payload "$tmp/src/business.js")"
expect_allow "valid approved auth allows ordinary Bash" "$gate_guard" "$(commit_payload "printf ok")"
mkdir -p "$tmp/lib"
printf '%s\n' 'lib baseline' > "$tmp/lib/business.js"
sed -i.bak 's/src\/\*\*/lib\/\*\*/' "$tmp/.claude/rules/project-workflow.md"
expect_ask "approved auth becomes structurally stale when protected roots change" \
  "$gate_guard" "$(edit_payload "$tmp/lib/business.js")"
sed -i.bak 's/lib\/\*\*/src\/\*\*/' "$tmp/.claude/rules/project-workflow.md"
rm -rf "$tmp/lib"

mkdir -p "$tmp/.claude/runtime/dev-flow"
write_final_assets() {
  local outcome=${1:-verified}
  local fp=$2
  local ver=$3
  printf '%s\n' '# feature demo' > "$tmp/docs/dev-flow/features/demo/feature.md"
  printf '%s\n' \
    '---' \
    'dev_flow_completion:' \
    '  schema_version: "1"' \
    "  workflow_version: \"$ver\"" \
    '  feature_id: "demo"' \
    '  level: "M"' \
    "  outcome: \"$outcome\"" \
    '  completed_at: "2026-01-01T00:00:00Z"' \
    "  business_diff_fingerprint: \"$fp\"" \
    '  retention: "compact"' \
    '  risk_labels: []' \
    '  risk_approval_evidence: ""' \
    '  risk_verification_summary: ""' \
    '  accepted_risks: []' \
    '  commits: []' \
    '  pull_request: ""' \
    '---' \
    '# done' > "$tmp/docs/dev-flow/features/demo/completion.md"
}

current_fp=$(cd "$tmp" && "$fingerprint_cmd" docs/dev-flow/features docs/dev-flow/reviews)
workflow_version=$(node "$root/dev-flow-policy.mjs" version)
printf 'workflow_version: %s\nfingerprint: %s\noutcome: verified\nchecked_at: 2026-01-01T00:00:00Z\n' \
  "$workflow_version" "$current_fp" > "$tmp/.claude/runtime/dev-flow/demo.check-ok"
# stamp alone without final assets is not logic-complete
expect_ask "finish-guard asks when stamp matches but final assets missing" \
  "$finish_guard" "$(commit_payload "git commit -am wip")"
write_final_assets verified "$current_fp" "$workflow_version"
current_fp=$(cd "$tmp" && "$fingerprint_cmd" docs/dev-flow/features docs/dev-flow/reviews)
printf 'workflow_version: %s\nfingerprint: %s\noutcome: verified\nchecked_at: 2026-01-01T00:00:00Z\n' \
  "$workflow_version" "$current_fp" > "$tmp/.claude/runtime/dev-flow/demo.check-ok"
# refresh completion fingerprint after writing assets
write_final_assets verified "$current_fp" "$workflow_version"
expect_allow "finish-guard allows git commit once logic-complete" "$finish_guard" "$(commit_payload "git commit -am wip")"
expect_allow "finish-guard allows git add once logic-complete" "$finish_guard" "$(commit_payload "git add src/business.js")"

cp "$tmp/docs/dev-flow/features/demo/completion.md" "$tmp/docs/dev-flow/features/demo/completion.valid"
printf '%s\n' 'not valid completion frontmatter' > "$tmp/docs/dev-flow/features/demo/completion.md"
expect_ask "finish-guard rejects malformed completion despite fresh stamp" \
  "$finish_guard" "$(commit_payload "git commit -am wip")"
mv "$tmp/docs/dev-flow/features/demo/completion.valid" "$tmp/docs/dev-flow/features/demo/completion.md"

# v0.7 stamps lack workflow_version and are always stale under v0.8+
printf 'fingerprint: %s\noutcome: verified\nchecked_at: 2026-01-01T00:00:00Z\n' "$current_fp" \
  > "$tmp/.claude/runtime/dev-flow/demo.check-ok"
expect_ask "finish-guard asks when stamp lacks workflow_version (v0.7)" \
  "$finish_guard" "$(commit_payload "git commit -am wip")"

printf 'workflow_version: 0.7.0\nfingerprint: %s\noutcome: verified\nchecked_at: 2026-01-01T00:00:00Z\n' \
  "$current_fp" > "$tmp/.claude/runtime/dev-flow/demo.check-ok"
expect_ask "finish-guard asks when stamp workflow_version mismatches" \
  "$finish_guard" "$(commit_payload "git commit -am wip")"

# partial without the required accepted-risk chain must not unlock Git
printf 'workflow_version: %s\nfingerprint: %s\noutcome: partial\nchecked_at: 2026-01-01T00:00:00Z\n' \
  "$workflow_version" "$current_fp" > "$tmp/.claude/runtime/dev-flow/demo.check-ok"
write_final_assets partial "$current_fp" "$workflow_version"
expect_ask "finish-guard rejects partial without an accepted-risk chain" "$finish_guard" "$(commit_payload "git commit -am wip")"

printf 'workflow_version: %s\nfingerprint: %s\noutcome: verified\nchecked_at: 2026-01-01T00:00:00Z\n' \
  "$workflow_version" "$current_fp" > "$tmp/.claude/runtime/dev-flow/demo.check-ok"
write_final_assets verified "$current_fp" "$workflow_version"

printf '%s\n' 'unstamped business change' > "$tmp/src/business.js"
expect_ask "finish-guard asks again once business diff changes after stamping" "$finish_guard" "$(commit_payload "git commit -am wip")"
printf '%s\n' 'baseline' > "$tmp/src/business.js"

# Re-stamp after business diff restored so fingerprint matches again.
current_fp=$(cd "$tmp" && "$fingerprint_cmd" docs/dev-flow/features docs/dev-flow/reviews)
printf 'workflow_version: %s\nfingerprint: %s\noutcome: verified\nchecked_at: 2026-01-01T00:00:00Z\n' \
  "$workflow_version" "$current_fp" > "$tmp/.claude/runtime/dev-flow/demo.check-ok"
write_final_assets verified "$current_fp" "$workflow_version"

# not now / pre-compact: status + completion + fresh stamp → Git allowed (v0.9)
expect_allow "finish-guard allows logic-complete without finalizer (not now)" \
  "$finish_guard" "$(commit_payload "git commit -am wip")"
expect_allow "finish-guard allows git push while logic-complete without finalizer" \
  "$finish_guard" "$(commit_payload "git push origin main")"

# stamp retained across not-now (do not remove check-ok)
assert_file_exists() {
  if [ -f "$1" ]; then
    printf 'PASS file exists: %s\n' "$1"
  else
    printf 'FAIL file missing: %s\n' "$1"
    failures=$((failures + 1))
  fi
}
assert_file_exists "$tmp/.claude/runtime/dev-flow/demo.check-ok"

# Deleting status alone is not finalization; the finalized validator must reject
# leftover process assets. Once the compact postconditions are represented, Git
# is allowed without a check-ok stamp.
rm -f "$tmp/docs/dev-flow/features/demo/status.md"
expect_ask "finish-guard rejects status deletion without finalized postconditions" \
  "$finish_guard" "$(commit_payload "git commit -am wip")"
rm -f "$tmp/docs/dev-flow/features/demo/plan.md" \
  "$tmp/docs/dev-flow/reviews/demo-plan-review.md" \
  "$tmp/docs/dev-flow/reviews/demo-code-review.md" \
  "$tmp/docs/dev-flow/reviews/demo-verification.md"
expect_allow "finish-guard allows a validator-confirmed finalized feature" \
  "$finish_guard" "$(commit_payload "git commit -am wip")"

# A closed authorization binds the just-finalized feature, but must not hide a
# different active feature that is not logic-complete.
write_auth closed
mkdir -p "$tmp/docs/dev-flow/features/other-active"
printf '%s\n' \
  '---' \
  'dev_flow_status:' \
  '  schema_version: "3"' \
  '  feature_id: "other-active"' \
  '  level: "M"' \
  '---' > "$tmp/docs/dev-flow/features/other-active/status.md"
expect_ask "finish-guard checks other active features after closed auth" \
  "$finish_guard" "$(commit_payload "git commit -am wip")"
rm -rf "$tmp/docs/dev-flow/features/other-active"

# restore in-progress feature without completion → not logic-complete
printf '%s\n' \
  '---' \
  'dev_flow_status:' \
  '  schema_version: "3"' \
  '  feature_id: "demo"' \
  '  level: "L"' \
  '---' > "$tmp/docs/dev-flow/features/demo/status.md"
rm -f "$tmp/docs/dev-flow/features/demo/completion.md" "$tmp/docs/dev-flow/features/demo/feature.md"
current_fp=$(cd "$tmp" && "$fingerprint_cmd" docs/dev-flow/features docs/dev-flow/reviews)
printf 'workflow_version: %s\nfingerprint: %s\noutcome: verified\nchecked_at: 2026-01-01T00:00:00Z\n' \
  "$workflow_version" "$current_fp" > "$tmp/.claude/runtime/dev-flow/demo.check-ok"
expect_ask "finish-guard asks when stamp present but final assets missing" \
  "$finish_guard" "$(commit_payload "git commit -am wip")"

mv "$tmp/.claude/rules/project-workflow.md" "$tmp/.claude/rules/project-workflow.md.bak"
expect_allow "finish-guard allows when project is not onboarded" "$finish_guard" "$(commit_payload "git commit -am wip")"
mv "$tmp/.claude/rules/project-workflow.md.bak" "$tmp/.claude/rules/project-workflow.md"

printf '\nSummary: %s failure(s)\n' "$failures"
[ "$failures" -eq 0 ]
