#!/usr/bin/env bash
set -u

root=$(cd "$(dirname "$0")/.." && pwd)
checker="$root/dev-flow-feature-check"
finalizer="$root/dev-flow-feature-finalize"
tmp=$(mktemp -d "${TMPDIR:-/tmp}/dev-flow-feature-check.XXXXXX")
trap 'rm -rf "$tmp"' EXIT

failures=0
run() {
  if [ "${DEBUG:-0}" = 1 ]; then
    "$@"
  else
    "$@" >/dev/null 2>&1
  fi
}
run_feature() {
  (cd "$tmp" && "$checker" "$@")
}
run_in_tmp() {
  (cd "$tmp" && "$@")
}
expect_pass() {
  if run "$@"; then
    printf 'PASS %s\n' "$*"
  else
    printf 'FAIL expected pass: %s\n' "$*"
    failures=$((failures + 1))
  fi
}
expect_fail() {
  if run "$@"; then
    printf 'FAIL expected failure: %s\n' "$*"
    failures=$((failures + 1))
  else
    printf 'PASS expected failure: %s\n' "$*"
  fi
}

expect_file() {
  if [ -f "$1" ]; then
    printf 'PASS file remains: %s\n' "$1"
  else
    printf 'FAIL expected file to remain: %s\n' "$1"
    failures=$((failures + 1))
  fi
}

update_gate_value() {
  local gate=$1
  local field=$2
  local value=$3
  awk -v target="$gate" -v field="$field" -v value="$value" '
    $0 == "    " target ":" { in_gate=1; print; next }
    in_gate && $0 ~ /^    [^ ]/ { in_gate=0 }
    in_gate && $0 ~ "^      " field ":" {
      print "      " field ": \"" value "\""
      in_gate=0
      next
    }
    { print }
  ' "$tmp/docs/dev-flow/features/demo/status.md" > "$tmp/docs/dev-flow/features/demo/status.new"
  mv "$tmp/docs/dev-flow/features/demo/status.new" "$tmp/docs/dev-flow/features/demo/status.md"
}

set_project_feature_root() {
  awk -v value="$1" '
    /^    feature_root:/ { print "    feature_root: " value; next }
    { print }
  ' "$tmp/.claude/rules/project-workflow.md" > "$tmp/.claude/rules/project-workflow.new"
  mv "$tmp/.claude/rules/project-workflow.new" "$tmp/.claude/rules/project-workflow.md"
}

set_status_level() {
  awk -v value="$1" '
    /^  level:/ { print "  level: \"" value "\""; next }
    { print }
  ' "$tmp/docs/dev-flow/features/demo/status.md" > "$tmp/docs/dev-flow/features/demo/status.new"
  mv "$tmp/docs/dev-flow/features/demo/status.new" "$tmp/docs/dev-flow/features/demo/status.md"
}

mkdir -p "$tmp/.claude/rules" "$tmp/docs/dev-flow/features/demo" "$tmp/docs/dev-flow/reviews" "$tmp/docs/dev-flow/features/demo/context" "$tmp/src"
git -C "$tmp" init -q
printf '%s\n' 'dev_flow:' '  paths:' '    feature_root: docs/dev-flow/features' '    review_root: docs/dev-flow/reviews' '  verification:' '    webapp_testing: "disabled"' '  artifacts:' '    retention: "compact"' > "$tmp/.claude/rules/project-workflow.md"
printf '%s\n' '---' 'dev_flow_status:' '  schema_version: "1"' '  workflow_version: "0.3.0"' '  feature_id: "demo"' '  level: "L"' '  current_gate: "verification-before-completion"' '  completed_gates:' '    - verification-before-completion' '  next_action: "finish"' '  assets:' '    - docs/dev-flow/features/demo/status.md' '    - docs/dev-flow/features/demo/context/verify.jsonl' '  context_manifests:' '    verify: docs/dev-flow/features/demo/context/verify.jsonl' '  human_gates:' '    requirement_confirmation:' '      required: true' '      status: "confirmed"' '      evidence: "user confirmed requirements"' '    implementation_approval:' '      required: true' '      status: "confirmed"' '      evidence: "user approved implementation"' '  risk_gates:' '    rollback_units: "light"' '    security_review: "none"' '    behavior_verification: "full"' '  validation:' '    last_validation_at: "2026-01-01"' '    last_validation_commands:' '      - "printf validation"' '    business_diff_fingerprint: "unknown"' '---' > "$tmp/docs/dev-flow/features/demo/status.md"
printf '%s\n' '{"file":"docs/dev-flow/features/demo/status.md","kind":"verification","reason":"fixture"}' > "$tmp/docs/dev-flow/features/demo/context/verify.jsonl"
printf '%s\n' '# verification' > "$tmp/docs/dev-flow/reviews/demo-verification.md"
printf '%s\n' '# manual' '实测：通过' > "$tmp/docs/dev-flow/reviews/demo-manual-test.md"
printf '%s\n' '### Task 1' '**Depends on:** none' > "$tmp/docs/dev-flow/features/demo/初步实现计划.md"
printf '%s\n' '# feature' > "$tmp/docs/dev-flow/features/demo/feature.md"
printf '%s\n' '---' 'dev_flow_completion:' '  retention: "compact"' '  outcome: "verified"' '---' '# completion' > "$tmp/docs/dev-flow/features/demo/completion.md"
printf '%s\n' 'baseline' > "$tmp/src/business.js"
git -C "$tmp" add .
git -C "$tmp" -c user.name='dev-flow test' -c user.email='dev-flow@example.test' commit -qm baseline
printf '%s\n' 'staged business change' > "$tmp/src/business.js"
git -C "$tmp" add src/business.js
fixture_fingerprint=$( { git -C "$tmp" diff --binary -- . ':(exclude).claude/**' ':(exclude)docs/dev-flow/features/**' ':(exclude)docs/dev-flow/reviews/**' ':(exclude)docs/claude-dev-flow-*'; git -C "$tmp" diff --cached --binary -- . ':(exclude).claude/**' ':(exclude)docs/dev-flow/features/**' ':(exclude)docs/dev-flow/reviews/**' ':(exclude)docs/claude-dev-flow-*'; while IFS= read -r file; do if [[ "$file" != .claude/* && "$file" != docs/dev-flow/features/* && "$file" != docs/dev-flow/reviews/* && "$file" != docs/claude-dev-flow-* ]]; then printf 'UNTRACKED %s ' "$file"; git -C "$tmp" hash-object -- "$file"; fi; done < <(git -C "$tmp" -c core.quotePath=false ls-files --others --exclude-standard); } | git -C "$tmp" hash-object --stdin )
awk -v fp="$fixture_fingerprint" '{ sub(/^    business_diff_fingerprint: ".*"$/, "    business_diff_fingerprint: \"" fp "\""); print }' "$tmp/docs/dev-flow/features/demo/status.md" > "$tmp/docs/dev-flow/features/demo/status.new"
mv "$tmp/docs/dev-flow/features/demo/status.new" "$tmp/docs/dev-flow/features/demo/status.md"

expect_fail run_feature ../demo --finish
expect_pass run_feature demo --finish
set_project_feature_root ../outside
expect_fail run_feature demo --finish
set_project_feature_root docs/dev-flow/features
set_status_level M
update_gate_value requirement_confirmation required false
update_gate_value implementation_approval required false
update_gate_value requirement_confirmation status pending
update_gate_value implementation_approval status pending
expect_pass run_feature demo --finish
set_status_level L
update_gate_value requirement_confirmation required true
update_gate_value implementation_approval required true
update_gate_value requirement_confirmation status confirmed
update_gate_value implementation_approval status confirmed
cp "$tmp/docs/dev-flow/features/demo/status.md" "$tmp/docs/dev-flow/features/demo/status.with-human-gates.md"
awk '
  /^  human_gates:$/ { skip=1; next }
  skip && /^  risk_gates:$/ { skip=0 }
  !skip { print }
' "$tmp/docs/dev-flow/features/demo/status.md" > "$tmp/docs/dev-flow/features/demo/status.new"
mv "$tmp/docs/dev-flow/features/demo/status.new" "$tmp/docs/dev-flow/features/demo/status.md"
expect_fail run_feature demo --finish
mv "$tmp/docs/dev-flow/features/demo/status.with-human-gates.md" "$tmp/docs/dev-flow/features/demo/status.md"
awk '{ sub(/^  current_gate: ".*"$/, "  current_gate: \"unknown-gate\""); print }' "$tmp/docs/dev-flow/features/demo/status.md" > "$tmp/docs/dev-flow/features/demo/status.new"
mv "$tmp/docs/dev-flow/features/demo/status.new" "$tmp/docs/dev-flow/features/demo/status.md"
expect_fail run_feature demo --finish
awk '{ sub(/^  current_gate: ".*"$/, "  current_gate: \"verification-before-completion\""); print }' "$tmp/docs/dev-flow/features/demo/status.md" > "$tmp/docs/dev-flow/features/demo/status.new"
mv "$tmp/docs/dev-flow/features/demo/status.new" "$tmp/docs/dev-flow/features/demo/status.md"
rm "$tmp/docs/dev-flow/reviews/demo-manual-test.md"
expect_fail run_feature demo --finish

printf '%s\n' '# manual' '实测：通过' > "$tmp/docs/dev-flow/reviews/demo-manual-test.md"
printf '%s\n' '{"file":"docs/dev-flow/features/demo/status.md","kind":"verification","reason":"fixture"}' '{"file":' > "$tmp/docs/dev-flow/features/demo/context/verify.jsonl"
expect_fail run_feature demo --finish
printf '%s\n' '{"file":"docs/dev-flow/features/demo/status.md","kind":"verification","reason":"fixture"}' > "$tmp/docs/dev-flow/features/demo/context/verify.jsonl"
printf '%s\n' '{"file":"docs/dev-flow/features/demo/status.md","kind":"verification","reason":"fixture"}' >> "$tmp/docs/dev-flow/features/demo/context/verify.jsonl"
expect_fail run_feature demo --finish
printf '%s\n' '{"file":"docs/dev-flow/features/demo/status.md","kind":"verification","reason":"fixture"}' > "$tmp/docs/dev-flow/features/demo/context/verify.jsonl"
update_gate_value implementation_approval evidence 'not required'
expect_fail run_feature demo --finish
update_gate_value implementation_approval evidence 'user approved implementation'
update_gate_value implementation_approval status pending
expect_fail run_feature demo --finish
update_gate_value implementation_approval status skipped
update_gate_value implementation_approval evidence 'not required'
expect_fail run_feature demo --finish
update_gate_value implementation_approval status confirmed
update_gate_value implementation_approval evidence 'user approved implementation'
printf '%s\n' 'additional business change' > "$tmp/src/business.js"
expect_fail run_feature demo --finish
printf '%s\n' 'staged business change' > "$tmp/src/business.js"
expect_pass run_feature demo --finish
printf '%s\n' 'do not delete' > "$tmp/.claude/sentinel"
awk '{ print; if ($0 == "  assets:") print "    - docs/dev-flow/features/demo/../../../../.claude/sentinel" }' "$tmp/docs/dev-flow/features/demo/status.md" > "$tmp/docs/dev-flow/features/demo/status.new"
mv "$tmp/docs/dev-flow/features/demo/status.new" "$tmp/docs/dev-flow/features/demo/status.md"
expect_fail run_feature demo --finish
expect_fail run_in_tmp "$finalizer" demo --retention=compact --confirm
expect_file "$tmp/.claude/sentinel"
awk '$0 != "    - docs/dev-flow/features/demo/../../../../.claude/sentinel"' "$tmp/docs/dev-flow/features/demo/status.md" > "$tmp/docs/dev-flow/features/demo/status.new"
mv "$tmp/docs/dev-flow/features/demo/status.new" "$tmp/docs/dev-flow/features/demo/status.md"
ln -s "$tmp/.claude" "$tmp/docs/dev-flow/features/demo/unsafe-link"
awk '{ print; if ($0 == "  assets:") print "    - docs/dev-flow/features/demo/unsafe-link/sentinel" }' "$tmp/docs/dev-flow/features/demo/status.md" > "$tmp/docs/dev-flow/features/demo/status.new"
mv "$tmp/docs/dev-flow/features/demo/status.new" "$tmp/docs/dev-flow/features/demo/status.md"
expect_fail run_feature demo --finish
expect_fail run_in_tmp "$finalizer" demo --retention=compact --confirm
expect_file "$tmp/.claude/sentinel"
awk '$0 != "    - docs/dev-flow/features/demo/unsafe-link/sentinel"' "$tmp/docs/dev-flow/features/demo/status.md" > "$tmp/docs/dev-flow/features/demo/status.new"
mv "$tmp/docs/dev-flow/features/demo/status.new" "$tmp/docs/dev-flow/features/demo/status.md"
rm "$tmp/docs/dev-flow/features/demo/unsafe-link"
expect_pass run_in_tmp "$finalizer" demo --retention=compact --confirm
expect_pass run_feature demo --finish

# --- Risk-minimal fixture setup ---
mkdir -p "$tmp/docs/dev-flow/features/risk-demo" "$tmp/docs/dev-flow/reviews"

# Create risk-minimal status.md
printf '%s\n' '---' 'dev_flow_status:' '  schema_version: "1"' '  workflow_version: "0.4.0"' '  feature_id: "risk-demo"' '  level: "S"' '  profile: "risk-minimal"' '  risk_labels: ["security"]' '  current_gate: "verification-before-completion"' '  completed_gates:' '    - verification-before-completion' '  next_action: "finish"' '  auto_continue: false' '  assets:' '    - docs/dev-flow/features/risk-demo/status.md' '  context_manifests:' '    implement: ""' '    review: ""' '    verify: ""' '  human_gates:' '    requirement_confirmation:' '      required: false' '      status: "not required"' '      evidence: "not required"' '    implementation_approval:' '      required: true' '      status: "confirmed"' '      evidence: "user approved risk-minimal path"' '  risk_gates:' '    requirements_coverage: "none"' '    plan_review: "none"' '    rollback_units: "light"' '    security_review: "light"' '    behavior_verification: "light"' '  classification:' '    schema_version: "1"' '    topology: "local"' '    target_files: ["src/business.js"]' '    symbols: ["exampleFunc"]' '    search_required: false' '    evidence_result: "verified"' '    external_references: []' '    scope_note: "Private function fix; no contract change"' '  validation:' '    last_validation_at: "2026-01-01"' '    last_validation_commands:' '      - "printf validation"' '    business_diff_fingerprint: "unknown"' '  accepted_risks: []' '---' > "$tmp/docs/dev-flow/features/risk-demo/status.md"

# Create verification report for risk-demo
printf '%s\n' '# verification' > "$tmp/docs/dev-flow/reviews/risk-demo-verification.md"

# Create manual test for risk-demo
printf '%s\n' '# manual' '实测：通过' > "$tmp/docs/dev-flow/reviews/risk-demo-manual-test.md"

# Create feature.md and completion.md for finalized state
printf '%s\n' '# feature' > "$tmp/docs/dev-flow/features/risk-demo/feature.md"
printf '%s\n' '---' 'dev_flow_completion:' '  feature_id: "risk-demo"' '  level: "S"' '  outcome: "verified"' '  completed_at: "2026-01-01"' '  retention: "compact"' '  risk_labels: ["security"]' '  risk_approval_evidence: "user confirmed risk-minimal path"' '  risk_verification_summary: "manual verification passed"' '  business_diff_fingerprint: ""' '  commits: []' '  pull_request: "none"' '  accepted_risks: []' '---' '# completion' > "$tmp/docs/dev-flow/features/risk-demo/completion.md"

# Set business diff fingerprint for risk-demo
fixture_fingerprint_risk=$( { git -C "$tmp" diff --binary -- . ':(exclude).claude/**' ':(exclude)docs/dev-flow/features/**' ':(exclude)docs/dev-flow/reviews/**' ':(exclude)docs/claude-dev-flow-*'; git -C "$tmp" diff --cached --binary -- . ':(exclude).claude/**' ':(exclude)docs/dev-flow/features/**' ':(exclude)docs/dev-flow/reviews/**' ':(exclude)docs/claude-dev-flow-*'; while IFS= read -r file; do if [[ "$file" != .claude/* && "$file" != docs/dev-flow/features/* && "$file" != docs/dev-flow/reviews/* && "$file" != docs/claude-dev-flow-* ]]; then printf 'UNTRACKED %s ' "$file"; git -C "$tmp" hash-object -- "$file"; fi; done < <(git -C "$tmp" -c core.quotePath=false ls-files --others --exclude-standard); } | git -C "$tmp" hash-object --stdin )
awk -v fp="$fixture_fingerprint_risk" '{ sub(/^    business_diff_fingerprint: ".*"$/, "    business_diff_fingerprint: \"" fp "\""); print }' "$tmp/docs/dev-flow/features/risk-demo/status.md" > "$tmp/docs/dev-flow/features/risk-demo/status.fp"
mv "$tmp/docs/dev-flow/features/risk-demo/status.fp" "$tmp/docs/dev-flow/features/risk-demo/status.md"

# Risk-minimal: S + security with correct evidence should PASS
expect_pass run_feature risk-demo --finish

# Risk-minimal: S + security missing implementation_approval should FAIL
cp "$tmp/docs/dev-flow/features/risk-demo/status.md" "$tmp/docs/dev-flow/features/risk-demo/status.bak"
awk -v target="implementation_approval" -v field="status" -v value="pending" '
  $0 == "    " target ":" { in_gate=1; print; next }
  in_gate && $0 ~ /^    [^ ]/ { in_gate=0 }
  in_gate && $0 ~ "^      status:"   { print "      status: \"pending\""; next }
  in_gate && $0 ~ "^      evidence:" { print "      evidence: \"not required\""; next }
  { print }
' "$tmp/docs/dev-flow/features/risk-demo/status.md" > "$tmp/docs/dev-flow/features/risk-demo/status.new"
mv "$tmp/docs/dev-flow/features/risk-demo/status.new" "$tmp/docs/dev-flow/features/risk-demo/status.md"
expect_fail run_feature risk-demo --finish

# Restore
cp "$tmp/docs/dev-flow/features/risk-demo/status.bak" "$tmp/docs/dev-flow/features/risk-demo/status.md"

# Risk-minimal: empty risk_labels should FAIL
awk '{ sub(/^  risk_labels: \[.*\]$/, "  risk_labels: []"); print }' "$tmp/docs/dev-flow/features/risk-demo/status.md" > "$tmp/docs/dev-flow/features/risk-demo/status.new"
mv "$tmp/docs/dev-flow/features/risk-demo/status.new" "$tmp/docs/dev-flow/features/risk-demo/status.md"
expect_fail run_feature risk-demo --finish
cp "$tmp/docs/dev-flow/features/risk-demo/status.bak" "$tmp/docs/dev-flow/features/risk-demo/status.md"

# Risk-minimal: stale business fingerprint should FAIL
printf '%s\n' 'additional business change' > "$tmp/src/business.js"
expect_fail run_feature risk-demo --finish
printf '%s\n' 'staged business change' > "$tmp/src/business.js"
git -C "$tmp" add src/business.js
expect_pass run_feature risk-demo --finish

# Risk-minimal finalized feature check
cp "$tmp/docs/dev-flow/features/risk-demo/status.md" "$tmp/docs/dev-flow/features/risk-demo/status.bak2"
rm "$tmp/docs/dev-flow/features/risk-demo/status.md"
expect_pass run_feature risk-demo --finish

# Risk-minimal completion with missing risk summary should FAIL
awk '!/risk_approval_evidence:/ && !/risk_verification_summary:/' "$tmp/docs/dev-flow/features/risk-demo/completion.md" > "$tmp/docs/dev-flow/features/risk-demo/completion.new"
mv "$tmp/docs/dev-flow/features/risk-demo/completion.new" "$tmp/docs/dev-flow/features/risk-demo/completion.md"
expect_fail run_feature risk-demo --finish

printf '\nSummary: %s failure(s)\n' "$failures"
[ "$failures" -eq 0 ]
