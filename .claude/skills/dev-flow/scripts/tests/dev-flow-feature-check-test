  local value=$2
  awk -v gate="$gate" -v value="$value" '
    /^  risk_gates:$/ { in_risk_gates=1; print; next }
    in_risk_gates && /^  [a-z_]+:/ { in_risk_gates=0 }
    in_risk_gates && $0 ~ "^    " gate ":" {
      print "    " gate ": \"" value "\""
      next
