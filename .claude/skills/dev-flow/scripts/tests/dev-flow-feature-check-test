  mv "$tmp/docs/dev-flow/features/demo/status.new" "$tmp/docs/dev-flow/features/demo/status.md"
}

write_risk_variant() {
  local label=$1
  local destination=$2
  awk -v label="$label" '
    /^  risk_gates:/ { in_risk_gates=1 }
    /^  [a-z_]+:/ && !/^  risk_gates:/ { in_risk_gates=0 }
    /^  risk_labels: / { print "  risk_labels: [\"" label "\"]"; next }
    /^    security:$/ { print "    " label ":"; next }
    /^      mode: / {
      if (label == "critical_correctness" || label == "irreversible_consequence") {
        print "      mode: \"report\""
        next
      }
    }
    /^      report: / {
      if (label == "critical_correctness" || label == "irreversible_consequence") {
        print "      report: \"docs/dev-flow/reviews/risk-demo-verification.md\""
        next
      }
    }
    in_risk_gates && /^    behavior_verification: / {
      if (label == "critical_correctness" || label == "irreversible_consequence") {
        print "    behavior_verification: \"full\""
        next
      }
    }
    in_risk_gates && /^    rollback_units: / {
      if (label == "irreversible_consequence") {
        print "    rollback_units: \"full\""
        next
      }
    }
    { print }
  ' "$tmp/docs/dev-flow/features/risk-demo/status.md" > "$destination"
}

