#!/usr/bin/env bash
set -u

root=$(cd "$(dirname "$0")/.." && pwd)
checker="$root/dev-flow-feature-check"
finalizer="$root/dev-flow-feature-finalize"
tmp=$(mktemp -d "${TMPDIR:-/tmp}/dev-flow-feature-check.XXXXXX")
trap 'rm -rf "$tmp"' EXIT

failures=0
run() {
  if [ "${DEBUG:-0}" = 1 ]; then
    "$@"
  else
    "$@" >/dev/null 2>&1
  fi
}
run_feature() {
  (cd "$tmp" && "$checker" "$@")
}
run_in_tmp() {
  (cd "$tmp" && "$@")
}
expect_pass() {
  if run "$@"; then
    printf 'PASS %s\n' "$*"
  else
    printf 'FAIL expected pass: %s\n' "$*"
    failures=$((failures + 1))
  fi
}
expect_fail() {
  if run "$@"; then
    printf 'FAIL expected failure: %s\n' "$*"
    failures=$((failures + 1))
  else
    printf 'PASS expected failure: %s\n' "$*"
  fi
}

expect_file() {
  if [ -f "$1" ]; then
    printf 'PASS file remains: %s\n' "$1"
  else
    printf 'FAIL expected file to remain: %s\n' "$1"
    failures=$((failures + 1))
  fi
}

update_gate_value() {
  local gate=$1
  local field=$2
  local value=$3
  awk -v target="$gate" -v field="$field" -v value="$value" '
    $0 == "    " target ":" { in_gate=1; print; next }
    in_gate && $0 ~ /^    [^ ]/ { in_gate=0 }
    in_gate && $0 ~ "^      " field ":" {
      print "      " field ": \"" value "\""
      in_gate=0
      next
    }
    { print }
  ' "$tmp/docs/dev-flow/features/demo/status.md" > "$tmp/docs/dev-flow/features/demo/status.new"
  mv "$tmp/docs/dev-flow/features/demo/status.new" "$tmp/docs/dev-flow/features/demo/status.md"
}

set_project_feature_root() {
  awk -v value="$1" '
    /^    feature_root:/ { print "    feature_root: " value; next }
    { print }
  ' "$tmp/.claude/rules/project-workflow.md" > "$tmp/.claude/rules/project-workflow.new"
  mv "$tmp/.claude/rules/project-workflow.new" "$tmp/.claude/rules/project-workflow.md"
}

set_status_level() {
  awk -v value="$1" '
    /^  level:/ { print "  level: \"" value "\""; next }
    { print }
  ' "$tmp/docs/dev-flow/features/demo/status.md" > "$tmp/docs/dev-flow/features/demo/status.new"
  mv "$tmp/docs/dev-flow/features/demo/status.new" "$tmp/docs/dev-flow/features/demo/status.md"
}

write_risk_variant() {
  local label=$1
  local destination=$2
  awk -v label="$label" '
    /^  risk_labels: / { print "  risk_labels: [\"" label "\"]"; next }
    /^    security:$/ { print "    " label ":"; next }
    { print }
  ' "$tmp/docs/dev-flow/features/risk-demo/status.md" > "$destination"
}

mkdir -p "$tmp/.claude/rules" "$tmp/docs/dev-flow/features/demo" "$tmp/docs/dev-flow/reviews" "$tmp/src"
git -C "$tmp" init -q
printf '%s\n' 'dev_flow:' '  paths:' '    feature_root: docs/dev-flow/features' '    review_root: docs/dev-flow/reviews' '  verification:' '    webapp_testing: "disabled"' '  artifacts:' '    retention: "compact"' > "$tmp/.claude/rules/project-workflow.md"
printf '%s\n' \
  '---' \
  'dev_flow_status:' \
  '  schema_version: "3"' \
  '  feature_id: "demo"' \
  '  level: "L"' \
  '  profile: "standard"' \
  '  risk_labels: []' \
  '  risk_evidence: {}' \
  '  classification:' \
  '    topology: "local"' \
  '    evidence_result: "not-applicable"' \
  '    note: "fixture"' \
  '  current_gate: "verification-before-completion"' \
  '  completed_gates:' \
  '    - verification-before-completion' \
  '  next_action: "finish"' \
  '  auto_continue: false' \
  '  human_gates:' \
  '    requirement_confirmation:' \
  '      required: true' \
  '      status: "confirmed"' \
  '      evidence: "user confirmed requirements"' \
  '    implementation_approval:' \
  '      required: true' \
  '      status: "confirmed"' \
  '      evidence: "user approved implementation"' \
  '  risk_gates:' \
  '    requirements_coverage: "none"' \
  '    plan_review: "none"' \
  '    rollback_units: "light"' \
  '    security_review: "none"' \
  '    behavior_verification: "full"' \
  '  assets:' \
  '    - {path: "docs/dev-flow/reviews/demo-verification.md", kind: "verification"}' \
  '  validation:' \
  '    last_at: "2026-01-01"' \
  '    commands:' \
  '      - "printf validation"' \
  '    business_diff_fingerprint: "unknown"' \
  '  accepted_risks: []' \
  '---' > "$tmp/docs/dev-flow/features/demo/status.md"
printf '%s\n' '# verification' > "$tmp/docs/dev-flow/reviews/demo-verification.md"
printf '%s\n' '# manual' '实测：通过' > "$tmp/docs/dev-flow/reviews/demo-manual-test.md"
printf '%s\n' '### Task 1' '**Depends on:** none' > "$tmp/docs/dev-flow/features/demo/初步实现计划.md"
printf '%s\n' '# feature' > "$tmp/docs/dev-flow/features/demo/feature.md"
printf '%s\n' '---' 'dev_flow_completion:' '  retention: "compact"' '  outcome: "verified"' '---' '# completion' > "$tmp/docs/dev-flow/features/demo/completion.md"
printf '%s\n' 'baseline' > "$tmp/src/business.js"
git -C "$tmp" add .
git -C "$tmp" -c user.name='dev-flow test' -c user.email='dev-flow@example.test' commit -qm baseline
printf '%s\n' 'staged business change' > "$tmp/src/business.js"
git -C "$tmp" add src/business.js
fixture_fingerprint=$(run_in_tmp "$root/dev-flow-fingerprint" docs/dev-flow/features docs/dev-flow/reviews)
awk -v fp="$fixture_fingerprint" '{ sub(/^    business_diff_fingerprint: ".*"$/, "    business_diff_fingerprint: \"" fp "\""); print }' "$tmp/docs/dev-flow/features/demo/status.md" > "$tmp/docs/dev-flow/features/demo/status.new"
mv "$tmp/docs/dev-flow/features/demo/status.new" "$tmp/docs/dev-flow/features/demo/status.md"

expect_fail run_feature ../demo --finish
expect_pass run_feature demo --finish
set_project_feature_root ../outside
expect_fail run_feature demo --finish
set_project_feature_root docs/dev-flow/features

set_status_level M
update_gate_value requirement_confirmation required false
update_gate_value implementation_approval required false
update_gate_value requirement_confirmation status pending
update_gate_value implementation_approval status pending
expect_pass run_feature demo --finish

# Lightweight L: only implementation_approval required — must pass finish.
set_status_level L
update_gate_value requirement_confirmation required false
update_gate_value implementation_approval required true
update_gate_value requirement_confirmation status pending
update_gate_value requirement_confirmation evidence 'not required'
update_gate_value implementation_approval status confirmed
update_gate_value implementation_approval evidence 'user approved lightweight L path'
expect_pass run_feature demo --finish

# Lightweight L without any required human gate — must fail.
update_gate_value implementation_approval required false
update_gate_value implementation_approval status pending
update_gate_value implementation_approval evidence 'not required'
expect_fail run_feature demo --finish

# Standard L: both human gates required and confirmed.
update_gate_value requirement_confirmation required true
update_gate_value implementation_approval required true
update_gate_value requirement_confirmation status confirmed
update_gate_value requirement_confirmation evidence 'user confirmed requirements'
update_gate_value implementation_approval status confirmed
update_gate_value implementation_approval evidence 'user approved implementation'
cp "$tmp/docs/dev-flow/features/demo/status.md" "$tmp/docs/dev-flow/features/demo/status.bak"

# Standard L with requirement_confirmation still pending — must fail.
update_gate_value requirement_confirmation status pending
expect_fail run_feature demo --finish
cp "$tmp/docs/dev-flow/features/demo/status.bak" "$tmp/docs/dev-flow/features/demo/status.md"

awk '
  /^  human_gates:$/ { skip=1; next }
  skip && /^  risk_gates:$/ { skip=0 }
  !skip { print }
' "$tmp/docs/dev-flow/features/demo/status.md" > "$tmp/docs/dev-flow/features/demo/status.new"
mv "$tmp/docs/dev-flow/features/demo/status.new" "$tmp/docs/dev-flow/features/demo/status.md"
expect_fail run_feature demo --finish
cp "$tmp/docs/dev-flow/features/demo/status.bak" "$tmp/docs/dev-flow/features/demo/status.md"

awk '{ sub(/^  current_gate: ".*"$/, "  current_gate: \"unknown-gate\""); print }' "$tmp/docs/dev-flow/features/demo/status.md" > "$tmp/docs/dev-flow/features/demo/status.new"
mv "$tmp/docs/dev-flow/features/demo/status.new" "$tmp/docs/dev-flow/features/demo/status.md"
expect_fail run_feature demo --finish
cp "$tmp/docs/dev-flow/features/demo/status.bak" "$tmp/docs/dev-flow/features/demo/status.md"

rm "$tmp/docs/dev-flow/reviews/demo-manual-test.md"
expect_fail run_feature demo --finish
printf '%s\n' '# manual' '实测：通过' > "$tmp/docs/dev-flow/reviews/demo-manual-test.md"

# Assets: kind must be one of the recognized asset_kinds.
awk '{ sub(/kind: "verification"/, "kind: \"bogus\""); print }' "$tmp/docs/dev-flow/features/demo/status.md" > "$tmp/docs/dev-flow/features/demo/status.new"
mv "$tmp/docs/dev-flow/features/demo/status.new" "$tmp/docs/dev-flow/features/demo/status.md"
expect_fail run_feature demo --finish
cp "$tmp/docs/dev-flow/features/demo/status.bak" "$tmp/docs/dev-flow/features/demo/status.md"

# Assets: a registered path must exist on disk.
awk '{ sub(/reviews\/demo-verification\.md/, "reviews/demo-missing.md"); print }' "$tmp/docs/dev-flow/features/demo/status.md" > "$tmp/docs/dev-flow/features/demo/status.new"
mv "$tmp/docs/dev-flow/features/demo/status.new" "$tmp/docs/dev-flow/features/demo/status.md"
expect_fail run_feature demo --finish
cp "$tmp/docs/dev-flow/features/demo/status.bak" "$tmp/docs/dev-flow/features/demo/status.md"

update_gate_value implementation_approval evidence 'not required'
expect_fail run_feature demo --finish
update_gate_value implementation_approval evidence 'user approved implementation'
update_gate_value implementation_approval status pending
expect_fail run_feature demo --finish
update_gate_value implementation_approval status skipped
update_gate_value implementation_approval evidence 'not required'
expect_fail run_feature demo --finish
update_gate_value implementation_approval status confirmed
update_gate_value implementation_approval evidence 'user approved implementation'
printf '%s\n' 'additional business change' > "$tmp/src/business.js"
expect_fail run_feature demo --finish
printf '%s\n' 'staged business change' > "$tmp/src/business.js"
expect_pass run_feature demo --finish

printf '%s\n' 'do not delete' > "$tmp/.claude/sentinel"
awk '{ print; if ($0 == "  assets:") print "    - {path: \"docs/dev-flow/features/demo/../../../../.claude/sentinel\", kind: \"spec\"}" }' "$tmp/docs/dev-flow/features/demo/status.md" > "$tmp/docs/dev-flow/features/demo/status.new"
mv "$tmp/docs/dev-flow/features/demo/status.new" "$tmp/docs/dev-flow/features/demo/status.md"
expect_fail run_feature demo --finish
expect_fail run_in_tmp "$finalizer" demo --retention=compact --confirm
expect_file "$tmp/.claude/sentinel"
cp "$tmp/docs/dev-flow/features/demo/status.bak" "$tmp/docs/dev-flow/features/demo/status.md"

ln -s "$tmp/.claude" "$tmp/docs/dev-flow/features/demo/unsafe-link"
awk '{ print; if ($0 == "  assets:") print "    - {path: \"docs/dev-flow/features/demo/unsafe-link/sentinel\", kind: \"spec\"}" }' "$tmp/docs/dev-flow/features/demo/status.md" > "$tmp/docs/dev-flow/features/demo/status.new"
mv "$tmp/docs/dev-flow/features/demo/status.new" "$tmp/docs/dev-flow/features/demo/status.md"
expect_fail run_feature demo --finish
expect_fail run_in_tmp "$finalizer" demo --retention=compact --confirm
expect_file "$tmp/.claude/sentinel"
rm "$tmp/docs/dev-flow/features/demo/unsafe-link"
cp "$tmp/docs/dev-flow/features/demo/status.bak" "$tmp/docs/dev-flow/features/demo/status.md"

expect_pass run_in_tmp "$finalizer" demo --retention=compact --confirm
expect_pass run_feature demo --finish

# --- Risk-minimal fixture setup ---
mkdir -p "$tmp/docs/dev-flow/features/risk-demo" "$tmp/docs/dev-flow/reviews"

printf '%s\n' \
  '---' \
  'dev_flow_status:' \
  '  schema_version: "3"' \
  '  feature_id: "risk-demo"' \
  '  level: "S"' \
  '  profile: "risk-minimal"' \
  '  risk_labels: ["security"]' \
  '  risk_evidence:' \
  '    security:' \
  '      mode: "inline"' \
  '      conclusion: "Reviewed token cleanup and denied-path behavior"' \
  '      verification: "docs/dev-flow/reviews/risk-demo-manual-test.md"' \
  '      report: ""' \
  '  classification:' \
  '    topology: "local"' \
  '    evidence_result: "verified"' \
  '    note: "Private function fix; no contract change"' \
  '  current_gate: "verification-before-completion"' \
  '  completed_gates:' \
  '    - verification-before-completion' \
  '  next_action: "finish"' \
  '  auto_continue: false' \
  '  human_gates:' \
  '    requirement_confirmation:' \
  '      required: false' \
  '      status: "pending"' \
  '      evidence: "not required"' \
  '    implementation_approval:' \
  '      required: true' \
  '      status: "confirmed"' \
  '      evidence: "user approved risk-minimal path"' \
  '  risk_gates:' \
  '    requirements_coverage: "none"' \
  '    plan_review: "none"' \
  '    rollback_units: "light"' \
  '    security_review: "light"' \
  '    behavior_verification: "light"' \
  '  assets:' \
  '    - {path: "docs/dev-flow/reviews/risk-demo-verification.md", kind: "verification"}' \
  '  validation:' \
  '    last_at: "2026-01-01"' \
  '    commands:' \
  '      - "printf validation"' \
  '    business_diff_fingerprint: "unknown"' \
  '  accepted_risks: []' \
  '---' > "$tmp/docs/dev-flow/features/risk-demo/status.md"

printf '%s\n' '# verification' > "$tmp/docs/dev-flow/reviews/risk-demo-verification.md"
printf '%s\n' '# manual' '实测：通过' > "$tmp/docs/dev-flow/reviews/risk-demo-manual-test.md"
printf '%s\n' '# feature' > "$tmp/docs/dev-flow/features/risk-demo/feature.md"
printf '%s\n' '---' 'dev_flow_completion:' '  feature_id: "risk-demo"' '  level: "S"' '  outcome: "verified"' '  completed_at: "2026-01-01"' '  retention: "compact"' '  risk_labels: ["security"]' '  risk_approval_evidence: "user confirmed risk-minimal path"' '  risk_verification_summary: "manual verification passed"' '  business_diff_fingerprint: ""' '  commits: []' '  pull_request: "none"' '  accepted_risks: []' '---' '# completion' > "$tmp/docs/dev-flow/features/risk-demo/completion.md"

fixture_fingerprint_risk=$(run_in_tmp "$root/dev-flow-fingerprint" docs/dev-flow/features docs/dev-flow/reviews)
awk -v fp="$fixture_fingerprint_risk" '{ sub(/^    business_diff_fingerprint: ".*"$/, "    business_diff_fingerprint: \"" fp "\""); print }' "$tmp/docs/dev-flow/features/risk-demo/status.md" > "$tmp/docs/dev-flow/features/risk-demo/status.new"
mv "$tmp/docs/dev-flow/features/risk-demo/status.new" "$tmp/docs/dev-flow/features/risk-demo/status.md"

# Risk-minimal: S + security with correct evidence should PASS
expect_pass run_feature risk-demo --finish

# Every supported label has a concrete minimum-gate contract.
for label in data money external availability critical_correctness irreversible_consequence; do
  write_risk_variant "$label" "$tmp/docs/dev-flow/features/risk-demo/status.$label.md"
  expect_pass run_in_tmp node "$root/dev-flow-validate.mjs" status "$tmp" "docs/dev-flow/features/risk-demo/status.$label.md"
  rm "$tmp/docs/dev-flow/features/risk-demo/status.$label.md"
done
write_risk_variant data "$tmp/docs/dev-flow/features/risk-demo/status.invalid-data.md"
awk '{ sub(/^    rollback_units: ".*"$/, "    rollback_units: \"none\""); print }' "$tmp/docs/dev-flow/features/risk-demo/status.invalid-data.md" > "$tmp/docs/dev-flow/features/risk-demo/status.new"
mv "$tmp/docs/dev-flow/features/risk-demo/status.new" "$tmp/docs/dev-flow/features/risk-demo/status.invalid-data.md"
expect_fail run_in_tmp node "$root/dev-flow-validate.mjs" status "$tmp" docs/dev-flow/features/risk-demo/status.invalid-data.md
write_risk_variant external "$tmp/docs/dev-flow/features/risk-demo/status.invalid-external.md"
awk '{ sub(/^    behavior_verification: ".*"$/, "    behavior_verification: \"none\""); print }' "$tmp/docs/dev-flow/features/risk-demo/status.invalid-external.md" > "$tmp/docs/dev-flow/features/risk-demo/status.new"
mv "$tmp/docs/dev-flow/features/risk-demo/status.new" "$tmp/docs/dev-flow/features/risk-demo/status.invalid-external.md"
expect_fail run_in_tmp node "$root/dev-flow-validate.mjs" status "$tmp" docs/dev-flow/features/risk-demo/status.invalid-external.md
rm "$tmp/docs/dev-flow/features/risk-demo/status.invalid-data.md" "$tmp/docs/dev-flow/features/risk-demo/status.invalid-external.md"

# Risk-minimal: S + security missing implementation_approval should FAIL
cp "$tmp/docs/dev-flow/features/risk-demo/status.md" "$tmp/docs/dev-flow/features/risk-demo/status.bak"
awk -v target="implementation_approval" -v field="status" -v value="pending" '
  $0 == "    " target ":" { in_gate=1; print; next }
  in_gate && $0 ~ /^    [^ ]/ { in_gate=0 }
  in_gate && $0 ~ "^      status:"   { print "      status: \"pending\""; next }
  in_gate && $0 ~ "^      evidence:" { print "      evidence: \"not required\""; next }
  { print }
' "$tmp/docs/dev-flow/features/risk-demo/status.md" > "$tmp/docs/dev-flow/features/risk-demo/status.new"
mv "$tmp/docs/dev-flow/features/risk-demo/status.new" "$tmp/docs/dev-flow/features/risk-demo/status.md"
expect_fail run_feature risk-demo --finish
cp "$tmp/docs/dev-flow/features/risk-demo/status.bak" "$tmp/docs/dev-flow/features/risk-demo/status.md"

# Risk-minimal: empty risk_labels should FAIL
awk '{ sub(/^  risk_labels: \[.*\]$/, "  risk_labels: []"); print }' "$tmp/docs/dev-flow/features/risk-demo/status.md" > "$tmp/docs/dev-flow/features/risk-demo/status.new"
mv "$tmp/docs/dev-flow/features/risk-demo/status.new" "$tmp/docs/dev-flow/features/risk-demo/status.md"
expect_fail run_feature risk-demo --finish
cp "$tmp/docs/dev-flow/features/risk-demo/status.bak" "$tmp/docs/dev-flow/features/risk-demo/status.md"

# Risk-minimal: missing risk_evidence block should FAIL
awk '
  /^  risk_evidence:$/ { in_evidence=1; next }
  in_evidence && /^  [a-z_]+:/ { in_evidence=0 }
  !in_evidence { print }
' "$tmp/docs/dev-flow/features/risk-demo/status.md" > "$tmp/docs/dev-flow/features/risk-demo/status.new"
mv "$tmp/docs/dev-flow/features/risk-demo/status.new" "$tmp/docs/dev-flow/features/risk-demo/status.md"
expect_fail run_feature risk-demo --finish
cp "$tmp/docs/dev-flow/features/risk-demo/status.bak" "$tmp/docs/dev-flow/features/risk-demo/status.md"

# Risk-minimal: security must not lower its minimum gate to none
awk '{ sub(/^    security_review: ".*"$/, "    security_review: \"none\""); print }' "$tmp/docs/dev-flow/features/risk-demo/status.md" > "$tmp/docs/dev-flow/features/risk-demo/status.new"
mv "$tmp/docs/dev-flow/features/risk-demo/status.new" "$tmp/docs/dev-flow/features/risk-demo/status.md"
expect_fail run_feature risk-demo --finish
cp "$tmp/docs/dev-flow/features/risk-demo/status.bak" "$tmp/docs/dev-flow/features/risk-demo/status.md"

# Assets: kind must be one of the recognized asset_kinds.
awk '{ sub(/kind: "verification"/, "kind: \"bogus\""); print }' "$tmp/docs/dev-flow/features/risk-demo/status.md" > "$tmp/docs/dev-flow/features/risk-demo/status.new"
mv "$tmp/docs/dev-flow/features/risk-demo/status.new" "$tmp/docs/dev-flow/features/risk-demo/status.md"
expect_fail run_in_tmp node "$root/dev-flow-validate.mjs" status "$tmp" docs/dev-flow/features/risk-demo/status.md
cp "$tmp/docs/dev-flow/features/risk-demo/status.bak" "$tmp/docs/dev-flow/features/risk-demo/status.md"

# Assets: a registered path must exist on disk.
awk '{ sub(/reviews\/risk-demo-verification\.md/, "reviews/risk-demo-missing.md"); print }' "$tmp/docs/dev-flow/features/risk-demo/status.md" > "$tmp/docs/dev-flow/features/risk-demo/status.new"
mv "$tmp/docs/dev-flow/features/risk-demo/status.new" "$tmp/docs/dev-flow/features/risk-demo/status.md"
expect_fail run_in_tmp node "$root/dev-flow-validate.mjs" status "$tmp" docs/dev-flow/features/risk-demo/status.md
cp "$tmp/docs/dev-flow/features/risk-demo/status.bak" "$tmp/docs/dev-flow/features/risk-demo/status.md"

# Classification: topology must be a recognized value.
awk '{ sub(/^    topology: ".*"$/, "    topology: \"made-up\""); print }' "$tmp/docs/dev-flow/features/risk-demo/status.md" > "$tmp/docs/dev-flow/features/risk-demo/status.new"
mv "$tmp/docs/dev-flow/features/risk-demo/status.new" "$tmp/docs/dev-flow/features/risk-demo/status.md"
expect_fail run_in_tmp node "$root/dev-flow-validate.mjs" status "$tmp" docs/dev-flow/features/risk-demo/status.md
cp "$tmp/docs/dev-flow/features/risk-demo/status.bak" "$tmp/docs/dev-flow/features/risk-demo/status.md"

# M/L may carry risk labels, but must keep the standard profile.
awk '{ sub(/^  level: ".*"$/, "  level: \"M\""); sub(/^  profile: ".*"$/, "  profile: \"standard\""); print }' "$tmp/docs/dev-flow/features/risk-demo/status.md" > "$tmp/docs/dev-flow/features/risk-demo/status.standard-m.md"
expect_pass run_in_tmp node "$root/dev-flow-validate.mjs" status "$tmp" docs/dev-flow/features/risk-demo/status.standard-m.md
awk '{ sub(/^  level: ".*"$/, "  level: \"M\""); print }' "$tmp/docs/dev-flow/features/risk-demo/status.md" > "$tmp/docs/dev-flow/features/risk-demo/status.invalid-m.md"
expect_fail run_in_tmp node "$root/dev-flow-validate.mjs" status "$tmp" docs/dev-flow/features/risk-demo/status.invalid-m.md
awk '{ sub(/^  profile: ".*"$/, "  profile: \"standard\""); print }' "$tmp/docs/dev-flow/features/risk-demo/status.md" > "$tmp/docs/dev-flow/features/risk-demo/status.invalid-s.md"
expect_fail run_in_tmp node "$root/dev-flow-validate.mjs" status "$tmp" docs/dev-flow/features/risk-demo/status.invalid-s.md
rm "$tmp/docs/dev-flow/features/risk-demo/status.standard-m.md" "$tmp/docs/dev-flow/features/risk-demo/status.invalid-m.md" "$tmp/docs/dev-flow/features/risk-demo/status.invalid-s.md"

# A full required gate must use a real report instead of inline-only evidence.
awk '{ sub(/^    security_review: ".*"$/, "    security_review: \"full\""); print }' "$tmp/docs/dev-flow/features/risk-demo/status.md" > "$tmp/docs/dev-flow/features/risk-demo/status.new"
mv "$tmp/docs/dev-flow/features/risk-demo/status.new" "$tmp/docs/dev-flow/features/risk-demo/status.md"
expect_fail run_feature risk-demo --finish
printf '%s\n' '# security review' 'SEC-1 已确认的安全缓解措施' > "$tmp/docs/dev-flow/reviews/risk-demo-security-review.md"
awk '{ sub(/^      mode: ".*"$/, "      mode: \"report\""); sub(/^      report: ".*"$/, "      report: \"docs/dev-flow/reviews/risk-demo-security-review.md\""); print }' "$tmp/docs/dev-flow/features/risk-demo/status.md" > "$tmp/docs/dev-flow/features/risk-demo/status.new"
mv "$tmp/docs/dev-flow/features/risk-demo/status.new" "$tmp/docs/dev-flow/features/risk-demo/status.md"
expect_pass run_feature risk-demo --finish

# Report evidence has the same path-safety boundary as every other asset.
awk '{ sub(/^      report: ".*"$/, "      report: \"../.claude/sentinel\""); print }' "$tmp/docs/dev-flow/features/risk-demo/status.md" > "$tmp/docs/dev-flow/features/risk-demo/status.new"
mv "$tmp/docs/dev-flow/features/risk-demo/status.new" "$tmp/docs/dev-flow/features/risk-demo/status.md"
expect_fail run_feature risk-demo --finish
cp "$tmp/docs/dev-flow/features/risk-demo/status.bak" "$tmp/docs/dev-flow/features/risk-demo/status.md"
ln -s "$tmp/.claude" "$tmp/docs/dev-flow/reviews/risk-link"
awk '{ sub(/^      mode: ".*"$/, "      mode: \"report\""); sub(/^      report: ".*"$/, "      report: \"docs/dev-flow/reviews/risk-link/sentinel\""); print }' "$tmp/docs/dev-flow/features/risk-demo/status.md" > "$tmp/docs/dev-flow/features/risk-demo/status.new"
mv "$tmp/docs/dev-flow/features/risk-demo/status.new" "$tmp/docs/dev-flow/features/risk-demo/status.md"
expect_fail run_feature risk-demo --finish
rm "$tmp/docs/dev-flow/reviews/risk-link"
cp "$tmp/docs/dev-flow/features/risk-demo/status.bak" "$tmp/docs/dev-flow/features/risk-demo/status.md"

# Risk-minimal: stale business fingerprint should FAIL
printf '%s\n' 'additional business change' > "$tmp/src/business.js"
expect_fail run_feature risk-demo --finish
printf '%s\n' 'staged business change' > "$tmp/src/business.js"
git -C "$tmp" add src/business.js
expect_pass run_feature risk-demo --finish

# Risk-minimal finalized feature check
rm "$tmp/docs/dev-flow/features/risk-demo/status.md"
expect_pass run_feature risk-demo --finish

# Risk-minimal completion with missing risk summary should FAIL
awk '!/risk_approval_evidence:/ && !/risk_verification_summary:/' "$tmp/docs/dev-flow/features/risk-demo/completion.md" > "$tmp/docs/dev-flow/features/risk-demo/completion.new"
mv "$tmp/docs/dev-flow/features/risk-demo/completion.new" "$tmp/docs/dev-flow/features/risk-demo/completion.md"
expect_fail run_feature risk-demo --finish

printf '\nSummary: %s failure(s)\n' "$failures"
[ "$failures" -eq 0 ]
