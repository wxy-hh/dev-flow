# v0.9: compact with untracked deletes requires exact token.
confirm_compact() {
  local feature=$1
  local inv
  local token
  local out
  out=$(run_in_tmp "$finalizer" "$feature" --retention=compact 2>&1) || true
  inv=$(printf '%s
' "$out" | sed -n 's/^Inventory: //p' | head -1)
  token=$(printf '%s
' "$out" | sed -n 's/^DELETE-UNTRACKED://p' | head -1)
  if [ -n "$token" ]; then
    token="DELETE-UNTRACKED:$token"
    run_in_tmp "$finalizer" "$feature" --retention=compact --confirm --inventory "$inv" --confirm-untracked "$token"
  else
    run_in_tmp "$finalizer" "$feature" --retention=compact --confirm --inventory "$inv"
  fi
}

tmp=$(mktemp -d "${TMPDIR:-/tmp}/dev-flow-feature-check.XXXXXX")
trap 'rm -rf "$tmp"' EXIT

failures=0
run() {
  if [ "${DEBUG:-0}" = 1 ]; then
    "$@"
  else
    "$@" >/dev/null 2>&1
  fi
}
run_feature() {
  (cd "$tmp" && "$checker" "$@")
}
run_in_tmp() {
  (cd "$tmp" && "$@")
}
expect_pass() {
  if run "$@"; then
    printf 'PASS %s\n' "$*"
  else
    printf 'FAIL expected pass: %s\n' "$*"
    failures=$((failures + 1))
  fi
}
expect_fail() {
  if run "$@"; then
    printf 'FAIL expected failure: %s\n' "$*"
    failures=$((failures + 1))
  else
    printf 'PASS expected failure: %s\n' "$*"
  fi
}

expect_file() {
  if [ -f "$1" ]; then
    printf 'PASS file remains: %s\n' "$1"
  else
    printf 'FAIL expected file to remain: %s\n' "$1"
    failures=$((failures + 1))
  fi
}

# dry-run → Inventory → --confirm --inventory <sha> [--confirm-untracked token]
run_finalizer_confirm() {
  local feature=$1
  local retention=$2
  local dry_out inv token
  dry_out=$(run_in_tmp "$finalizer" "$feature" --retention="$retention" 2>&1) || true
  inv=$(printf '%s\n' "$dry_out" | sed -n 's/^Inventory: //p' | head -1)
  if [ -z "$inv" ]; then
    printf 'ERROR dry-run produced no Inventory line\n' >&2
    printf '%s\n' "$dry_out" >&2
    return 1
  fi
  token=$(printf '%s\n' "$dry_out" | sed -n 's/^Untracked delete token://p' | head -1 | tr -d '[:space:]')
  if [ -z "$token" ]; then
    token=$(printf '%s\n' "$dry_out" | sed -n 's/^DELETE-UNTRACKED:/DELETE-UNTRACKED:/p' | head -1 | tr -d '[:space:]')
  fi
  if [ "$retention" = compact ] && [ -n "$token" ]; then
    run_in_tmp "$finalizer" "$feature" --retention="$retention" --confirm --inventory "$inv" --confirm-untracked "$token"
  else
    run_in_tmp "$finalizer" "$feature" --retention="$retention" --confirm --inventory "$inv"
  fi
}

update_gate_value() {
  local gate=$1
  local field=$2
  local value=$3
  awk -v target="$gate" -v field="$field" -v value="$value" '
    $0 == "    " target ":" { in_gate=1; print; next }
    in_gate && $0 ~ /^    [^ ]/ { in_gate=0 }
    in_gate && $0 ~ "^      " field ":" {
      print "      " field ": \"" value "\""
      in_gate=0
      next
    }
    { print }
  ' "$tmp/docs/dev-flow/features/demo/status.md" > "$tmp/docs/dev-flow/features/demo/status.new"
  mv "$tmp/docs/dev-flow/features/demo/status.new" "$tmp/docs/dev-flow/features/demo/status.md"
}

