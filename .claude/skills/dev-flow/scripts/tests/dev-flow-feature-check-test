#!/usr/bin/env bash
set -uo pipefail

scripts=$(cd "$(dirname "$0")/.." && pwd)
checker="$scripts/dev-flow-feature-check"
tmp=$(mktemp -d "${TMPDIR:-/tmp}/dev-flow-feature-check.XXXXXX")
trap 'rm -rf "$tmp"' EXIT

failures=0

run_feature() {
  (cd "$tmp" && "$checker" "$@")
}

expect_pass() {
  local label=$1
  shift
  if "$@" >/dev/null 2>&1; then
    printf 'PASS %s\n' "$label"
  else
    printf 'FAIL expected pass: %s\n' "$label"
    failures=$((failures + 1))
  fi
}

expect_fail() {
  local label=$1
  shift
  if "$@" >/dev/null 2>&1; then
    printf 'FAIL expected failure: %s\n' "$label"
    failures=$((failures + 1))
  else
    printf 'PASS expected failure: %s\n' "$label"
  fi
}

write_work() {
  local risks=$1
  local approval=$2
  local approval_evidence=$3
  local verification=$4
  local accepted_risks=$5
  local phase=${6:-done}
  local batch=${7:-done}
  local evidence=${8:-'pnpm test — passed'}
  local checkbox='[x]'
  [ "$batch" = done ] || checkbox='[ ]'

  mkdir -p "$tmp/docs/dev-flow/features/demo"
  printf '%s\n' \
    '# Demo work' \
    '' \
    '## State' \
    '- Level: L' \
    "- Risks: $risks" \
    "- Phase: $phase" \
    "- Approval: $approval" \
    "- Approval evidence: $approval_evidence" \
    "- Verification: $verification" \
    "- Accepted risks: $accepted_risks" \
    '- Updated: 2026-07-10' \
    '' \
    '## Boundary' \
    '- Add the requested behavior.' \
    '' \
    '## Batches' \
    "- $checkbox Batch 1: implementation and focused check" \
    '' \
    '## Risk and rollback' \
    '- Revert the batch diff.' \
    '' \
    '## Verification' \
    "- Evidence: $evidence" \
    > "$tmp/docs/dev-flow/features/demo/work.md"
}

mkdir -p "$tmp/.claude/rules"
git -C "$tmp" init -q
printf '%s\n' \
  'dev_flow:' \
  '  version: "0.4.0"' \
  '  paths:' \
  '    feature_root: "docs/dev-flow/features"' \
  > "$tmp/.claude/rules/project-workflow.md"

expect_fail 'rejects traversal feature id' run_feature ../demo --finish
expect_fail 'requires work.md' run_feature demo --finish

write_work none not-required none passed none
expect_pass 'accepts low-risk L work' run_feature demo --finish

sed -i.bak 's/version: "0.4.0"/version: "0.3.0"/' "$tmp/.claude/rules/project-workflow.md"
rm -f "$tmp/.claude/rules/project-workflow.md.bak"
expect_fail 'requires workflow 0.4.0' run_feature demo --finish
sed -i.bak 's/version: "0.3.0"/version: "0.4.0"/' "$tmp/.claude/rules/project-workflow.md"
rm -f "$tmp/.claude/rules/project-workflow.md.bak"

sed -i.bak 's#docs/dev-flow/features#../outside#' "$tmp/.claude/rules/project-workflow.md"
rm -f "$tmp/.claude/rules/project-workflow.md.bak"
expect_fail 'rejects unsafe feature root' run_feature demo --finish
sed -i.bak 's#../outside#docs/dev-flow/features#' "$tmp/.claude/rules/project-workflow.md"
rm -f "$tmp/.claude/rules/project-workflow.md.bak"

ln -s "$tmp/docs/dev-flow/features" "$tmp/linked-features"
sed -i.bak 's#docs/dev-flow/features#linked-features#' "$tmp/.claude/rules/project-workflow.md"
rm -f "$tmp/.claude/rules/project-workflow.md.bak"
expect_fail 'rejects symlinked feature root' run_feature demo --finish
sed -i.bak 's#linked-features#docs/dev-flow/features#' "$tmp/.claude/rules/project-workflow.md"
rm -f "$tmp/.claude/rules/project-workflow.md.bak"

write_work security pending none passed none
expect_fail 'blocks high-risk pending approval' run_feature demo --finish

write_work security confirmed none passed none
expect_fail 'blocks confirmation without evidence' run_feature demo --finish

write_work security confirmed ' NONE ' passed none
expect_fail 'blocks normalized placeholder approval evidence' run_feature demo --finish

write_work security confirmed 'user confirmed after risk card' passed none
expect_pass 'accepts confirmed high-risk work' run_feature demo --finish

write_work security skipped 'user asked to skip' passed none
expect_fail 'blocks skipped gate without accepted risk' run_feature demo --finish

write_work security skipped 'user accepted the disclosed risk' passed 'security: user accepted'
expect_pass 'accepts explicit risk acceptance' run_feature demo --finish

write_work external confirmed 'user confirmed after risk card' passed none implementation pending
expect_fail 'blocks unfinished batch' run_feature demo --finish

write_work none not-required none pending none verification
expect_fail 'blocks pending verification' run_feature demo --finish

write_work none not-required none failed none done
expect_fail 'blocks failed verification' run_feature demo --finish

write_work none not-required none partial none done
expect_fail 'blocks partial verification without accepted risk' run_feature demo --finish

write_work none not-required none partial 'runtime path not available: user accepted' done
expect_pass 'accepts explicit partial verification risk' run_feature demo --finish

write_work none not-required none passed none done done none
expect_fail 'requires verification evidence' run_feature demo --finish

write_work none not-required none passed none done done pending
expect_fail 'rejects placeholder verification evidence' run_feature demo --finish

write_work none not-required none passed none done done ' PENDING '
expect_fail 'rejects normalized placeholder verification evidence' run_feature demo --finish

write_work none not-required none passed none
awk '/^- Updated:/ { print; print "- Approval: pending"; next } { print }' \
  "$tmp/docs/dev-flow/features/demo/work.md" > "$tmp/docs/dev-flow/features/demo/work.new"
mv "$tmp/docs/dev-flow/features/demo/work.new" "$tmp/docs/dev-flow/features/demo/work.md"
expect_fail 'rejects duplicate State fields' run_feature demo --finish

write_work mystery confirmed 'user confirmed' passed none
expect_fail 'rejects unknown risk tag' run_feature demo --finish

write_work none not-required none pending none implementation pending
expect_pass 'non-finish mode accepts active work' run_feature demo

printf '\nSummary: %s failure(s)\n' "$failures"
[ "$failures" -eq 0 ]
