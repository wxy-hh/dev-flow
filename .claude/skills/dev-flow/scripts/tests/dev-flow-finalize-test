#!/usr/bin/env bash
# Task 4 acceptance: dry-run, inventory drift, compact/full cleanup,
# feature isolation, mid-move recovery.
set -u

root=$(cd "$(dirname "$0")/.." && pwd)
finalizer="$root/dev-flow-feature-finalize"

# v0.9: compact with untracked deletes requires exact token.
confirm_compact() {
  local feature=$1
  local inv token out
  out=$(run_in_tmp "$finalizer" "$feature" --retention=compact 2>&1) || true
  inv=$(printf '%s\n' "$out" | sed -n 's/^Inventory: //p' | head -1)
  token=$(printf '%s\n' "$out" | sed -n 's/^DELETE-UNTRACKED:/DELETE-UNTRACKED:/p' | head -1)
  if [ -z "$token" ]; then
    token=$(printf '%s\n' "$out" | sed -n 's/^Untracked delete token:[[:space:]]*//p' | head -1)
  fi
  # token may be on next line after "Untracked delete token:"
  if [ -z "$token" ] || [ "$token" = "Untracked delete token:" ]; then
    token=$(printf '%s\n' "$out" | awk '/^Untracked delete token:/{getline; print; exit}')
  fi
  if [ -n "$token" ]; then
    run_in_tmp "$finalizer" "$feature" --retention=compact --confirm --inventory "$inv" --confirm-untracked "$token"
  else
    run_in_tmp "$finalizer" "$feature" --retention=compact --confirm --inventory "$inv"
  fi
}

fingerprint_cmd="$root/dev-flow-fingerprint"
policy_cmd="$root/dev-flow-policy.mjs"
validator="$root/dev-flow-validate.mjs"

tmp=$(mktemp -d "${TMPDIR:-/tmp}/dev-flow-finalize.XXXXXX")
trap 'rm -rf "$tmp"' EXIT

failures=0

run_in_tmp() {
  (cd "$tmp" && "$@")
}

expect_pass() {
  if "$@"; then
    printf 'PASS %s\n' "$*"
  else
    printf 'FAIL expected pass: %s\n' "$*"
    failures=$((failures + 1))
  fi
}

expect_fail() {
  if "$@"; then
    printf 'FAIL expected failure: %s\n' "$*"
    failures=$((failures + 1))
  else
    printf 'PASS expected failure: %s\n' "$*"
  fi
}

assert_file() {
  if [ -f "$1" ]; then
    printf 'PASS file exists: %s\n' "$1"
  else
    printf 'FAIL file missing: %s\n' "$1"
    failures=$((failures + 1))
  fi
}

assert_no_file() {
  if [ ! -e "$1" ]; then
    printf 'PASS absent: %s\n' "$1"
  else
    printf 'FAIL expected absent: %s\n' "$1"
    failures=$((failures + 1))
  fi
}

assert_contains() {
  local file=$1 pattern=$2
  if [ -f "$file" ] && rg -q -- "$pattern" "$file"; then
    printf 'PASS %s contains %s\n' "$file" "$pattern"
  else
    printf 'FAIL expected %s to contain %s\n' "$file" "$pattern"
    failures=$((failures + 1))
  fi
}

assert_eq() {
  local desc=$1 expected=$2 actual=$3
  if [ "$expected" = "$actual" ]; then
    printf 'PASS %s\n' "$desc"
  else
    printf 'FAIL %s (expected=%s actual=%s)\n' "$desc" "$expected" "$actual"
    failures=$((failures + 1))
  fi
}

write_workflow() {
  mkdir -p "$tmp/.claude/rules" "$tmp/docs/dev-flow/features" "$tmp/docs/dev-flow/reviews" "$tmp/src"
  printf '%s\n' \
    'dev_flow:' \
    '  paths:' \
    '    feature_root: docs/dev-flow/features' \
    '    review_root: docs/dev-flow/reviews' \
    '  verification:' \
    '    webapp_testing: "disabled"' \
    '  artifacts:' \
    '    retention: "compact"' \
    > "$tmp/.claude/rules/project-workflow.md"
}

