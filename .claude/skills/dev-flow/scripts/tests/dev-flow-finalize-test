    DEV_FLOW_FINALIZE_FAIL_AFTER=1 DEV_FLOW_FINALIZE_FAIL_RESTORE_AFTER=1 \
    "$finalizer" gamma --retention=compact --confirm --inventory "$restore_inv" 2>&1)
fi
restore_fail_rc=$?
set -e
