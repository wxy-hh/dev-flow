  printf '%s\n' \
    '{' \
    "  \"feature_id\": \"$id\"," \
    '  "level": "L",' \
    '  "profile": "standard",' \
    '  "state": "approved",' \
    '  "protected_roots": ["src/**"],' \
    '  "created_at": "2026-01-01T00:00:00Z",' \
    '  "approved_at": "2026-01-01T00:00:00Z"' \
    '}' > "$tmp/.claude/runtime/dev-flow/write-authorization.json"
}

stamp_feature() {
  local id=$1
  local fp
  fp=$(run_in_tmp "$fingerprint_cmd" docs/dev-flow/features docs/dev-flow/reviews)
  local version
  version=$(node "$policy_cmd" version)
  printf 'workflow_version: %s\nfingerprint: %s\noutcome: verified\nchecked_at: 2026-01-01T00:00:00Z\n' \
    "$version" "$fp" > "$tmp/.claude/runtime/dev-flow/${id}.check-ok"
  # Keep status fingerprint aligned for completeness.
  awk -v fp="$fp" '{ sub(/^    business_diff_fingerprint: ".*"$/, "    business_diff_fingerprint: \"" fp "\""); print }' \
    "$tmp/docs/dev-flow/features/$id/status.md" > "$tmp/docs/dev-flow/features/$id/status.new"
  mv "$tmp/docs/dev-flow/features/$id/status.new" "$tmp/docs/dev-flow/features/$id/status.md"
  awk -v fp="$fp" '{ sub(/^  business_diff_fingerprint: ".*"$/, "  business_diff_fingerprint: \"" fp "\""); print }' \
    "$tmp/docs/dev-flow/features/$id/completion.md" > "$tmp/docs/dev-flow/features/$id/completion.new"
  mv "$tmp/docs/dev-flow/features/$id/completion.new" "$tmp/docs/dev-flow/features/$id/completion.md"
}

inventory_of() {
  local id=$1
  local retention=${2:-compact}
  run_in_tmp "$finalizer" "$id" --retention="$retention" 2>/dev/null \
    | sed -n 's/^Inventory: //p' | head -1
}

count_feature_reviews() {
  local id=$1
  local n=0
  local name
  for name in \
    "${id}-verification.md" \
    "${id}-code-review.md" \
    "${id}-manual-test.md" \
    "${id}-plan-review.md" \
    "${id}-security-review.md" \
    "${id}-partial-acceptance.md"
  do
    [ -f "$tmp/docs/dev-flow/reviews/$name" ] && n=$((n + 1))
  done
  # also dated forms
  local f
  for f in "$tmp/docs/dev-flow/reviews/"*"-${id}-"*.md; do
    [ -e "$f" ] || continue
    n=$((n + 1))
  done
  printf '%s' "$n"
}

snapshot_path() {
  # path + size + sha for isolation checks
  local p=$1
  if [ ! -e "$p" ]; then
    printf 'missing'
    return
  fi
  if [ -f "$p" ]; then
    printf 'file:%s:%s' "$(wc -c < "$p" | tr -d ' ')" "$(shasum -a 256 "$p" | awk '{print $1}')"
  elif [ -d "$p" ]; then
    find "$p" -type f -print 2>/dev/null | sort | while IFS= read -r child; do
      printf '%s\t' "${child#$p/}"
      shasum -a 256 "$child" 2>/dev/null | awk '{print $1}'
    done | shasum -a 256 | awk '{print $1}'
  else
    printf 'other'
  fi
}

# ---------- bootstrap ----------
write_workflow
git -C "$tmp" init -q
printf '%s\n' 'baseline' > "$tmp/src/business.js"
git -C "$tmp" add .
git -C "$tmp" -c user.name='dev-flow test' -c user.email='dev-flow@example.test' commit -qm baseline
printf '%s\n' 'change' > "$tmp/src/business.js"
git -C "$tmp" add src/business.js

write_feature alpha compact
write_feature beta compact
printf '%s\n' 'legacy alpha SDD' > "$tmp/.claude/runtime/sdd/alpha-legacy.md"
printf '%s\n' 'legacy beta SDD' > "$tmp/.claude/runtime/sdd/beta-legacy.md"
stamp_feature alpha
stamp_feature beta

# ---------- final-assets validator (new strict + historical legacy) ----------
expect_pass run_in_tmp node "$validator" final-assets "$tmp" \
  docs/dev-flow/features/alpha/feature.md \
  docs/dev-flow/features/alpha/completion.md \
  --status docs/dev-flow/features/alpha/status.md

cp "$tmp/docs/dev-flow/features/alpha/completion.md" "$tmp/docs/dev-flow/features/alpha/completion.strict"
sed '/^  workflow_version:/d' "$tmp/docs/dev-flow/features/alpha/completion.strict" \
  > "$tmp/docs/dev-flow/features/alpha/completion.md"
expect_fail run_in_tmp node "$validator" final-assets "$tmp" \
  docs/dev-flow/features/alpha/feature.md \
  docs/dev-flow/features/alpha/completion.md \
  --status docs/dev-flow/features/alpha/status.md
mv "$tmp/docs/dev-flow/features/alpha/completion.strict" "$tmp/docs/dev-flow/features/alpha/completion.md"

# Active completion must preserve the same risk labels as status.
cp "$tmp/docs/dev-flow/features/alpha/status.md" "$tmp/docs/dev-flow/features/alpha/status.strict"
sed 's/^  risk_labels: \[\]$/  risk_labels: ["money"]/' \
  "$tmp/docs/dev-flow/features/alpha/status.strict" \
  > "$tmp/docs/dev-flow/features/alpha/status.md"
expect_fail run_in_tmp node "$validator" final-assets "$tmp" \
  docs/dev-flow/features/alpha/feature.md \
  docs/dev-flow/features/alpha/completion.md \
  --status docs/dev-flow/features/alpha/status.md
mv "$tmp/docs/dev-flow/features/alpha/status.strict" "$tmp/docs/dev-flow/features/alpha/status.md"

# A partial completion must preserve the exact accepted-risk ids from status.
cp "$tmp/docs/dev-flow/features/alpha/status.md" "$tmp/docs/dev-flow/features/alpha/status.strict"
cp "$tmp/docs/dev-flow/features/alpha/completion.md" "$tmp/docs/dev-flow/features/alpha/completion.strict"
sed 's/^  accepted_risks: \[\]$/  accepted_risks: ["AR-001"]/' \
  "$tmp/docs/dev-flow/features/alpha/status.strict" \
  > "$tmp/docs/dev-flow/features/alpha/status.md"
sed -e 's/^  outcome: "verified"$/  outcome: "partial"/' \
  -e 's/^  accepted_risks: \[\]$/  accepted_risks: ["AR-999"]/' \
  "$tmp/docs/dev-flow/features/alpha/completion.strict" \
  > "$tmp/docs/dev-flow/features/alpha/completion.md"
printf '%s\n' '' '## AR-999' '- reason: accepted product limitation' \
  '- evidence: user approval recorded in session evidence' \
  >> "$tmp/docs/dev-flow/features/alpha/completion.md"
expect_fail run_in_tmp node "$validator" final-assets "$tmp" \
  docs/dev-flow/features/alpha/feature.md \
  docs/dev-flow/features/alpha/completion.md \
  --status docs/dev-flow/features/alpha/status.md
mv "$tmp/docs/dev-flow/features/alpha/status.strict" "$tmp/docs/dev-flow/features/alpha/status.md"
mv "$tmp/docs/dev-flow/features/alpha/completion.strict" "$tmp/docs/dev-flow/features/alpha/completion.md"

# Matching ids are not enough: partial completion must retain reason/evidence sections.
cp "$tmp/docs/dev-flow/features/alpha/status.md" "$tmp/docs/dev-flow/features/alpha/status.strict"
cp "$tmp/docs/dev-flow/features/alpha/completion.md" "$tmp/docs/dev-flow/features/alpha/completion.strict"
sed 's/^  accepted_risks: \[\]$/  accepted_risks: ["AR-001"]/' \
  "$tmp/docs/dev-flow/features/alpha/status.strict" \
  > "$tmp/docs/dev-flow/features/alpha/status.md"
sed -e 's/^  outcome: "verified"$/  outcome: "partial"/' \
  -e 's/^  accepted_risks: \[\]$/  accepted_risks: ["AR-001"]/' \
  "$tmp/docs/dev-flow/features/alpha/completion.strict" \
  > "$tmp/docs/dev-flow/features/alpha/completion.md"
expect_fail run_in_tmp node "$validator" final-assets "$tmp" \
  docs/dev-flow/features/alpha/feature.md \
  docs/dev-flow/features/alpha/completion.md \
  --status docs/dev-flow/features/alpha/status.md
mv "$tmp/docs/dev-flow/features/alpha/status.strict" "$tmp/docs/dev-flow/features/alpha/status.md"
mv "$tmp/docs/dev-flow/features/alpha/completion.strict" "$tmp/docs/dev-flow/features/alpha/completion.md"

# The accepted-risk section must carry completed facts, not placeholders.
cp "$tmp/docs/dev-flow/features/alpha/status.md" "$tmp/docs/dev-flow/features/alpha/status.strict"
cp "$tmp/docs/dev-flow/features/alpha/completion.md" "$tmp/docs/dev-flow/features/alpha/completion.strict"
sed 's/^  accepted_risks: \[\]$/  accepted_risks: ["AR-001"]/' \
  "$tmp/docs/dev-flow/features/alpha/status.strict" \
  > "$tmp/docs/dev-flow/features/alpha/status.md"
sed -e 's/^  outcome: "verified"$/  outcome: "partial"/' \
  -e 's/^  accepted_risks: \[\]$/  accepted_risks: ["AR-001"]/' \
  "$tmp/docs/dev-flow/features/alpha/completion.strict" \
  > "$tmp/docs/dev-flow/features/alpha/completion.md"
printf '%s\n' '' '## AR-001' '- reason: pending' '- evidence: TBD' \
  >> "$tmp/docs/dev-flow/features/alpha/completion.md"
expect_fail run_in_tmp node "$validator" final-assets "$tmp" \
  docs/dev-flow/features/alpha/feature.md \
  docs/dev-flow/features/alpha/completion.md \
  --status docs/dev-flow/features/alpha/status.md
mv "$tmp/docs/dev-flow/features/alpha/status.strict" "$tmp/docs/dev-flow/features/alpha/status.md"
mv "$tmp/docs/dev-flow/features/alpha/completion.strict" "$tmp/docs/dev-flow/features/alpha/completion.md"

# completed_at is a machine contract, not merely a non-empty note.
cp "$tmp/docs/dev-flow/features/alpha/completion.md" "$tmp/docs/dev-flow/features/alpha/completion.strict"
sed 's/^  completed_at: ".*"$/  completed_at: "2026-02-30T00:00:00Z"/' \
  "$tmp/docs/dev-flow/features/alpha/completion.strict" \
  > "$tmp/docs/dev-flow/features/alpha/completion.md"
expect_fail run_in_tmp node "$validator" final-assets "$tmp" \
  docs/dev-flow/features/alpha/feature.md \
  docs/dev-flow/features/alpha/completion.md \
  --status docs/dev-flow/features/alpha/status.md
mv "$tmp/docs/dev-flow/features/alpha/completion.strict" "$tmp/docs/dev-flow/features/alpha/completion.md"

mkdir -p "$tmp/docs/dev-flow/features/legacy-finalized"
printf '%s\n' '# legacy feature' > "$tmp/docs/dev-flow/features/legacy-finalized/feature.md"
printf '%s\n' '---' 'dev_flow_completion:' '  retention: "compact"' \
  '  outcome: "verified"' '---' '# legacy completion' \
  > "$tmp/docs/dev-flow/features/legacy-finalized/completion.md"
legacy_out=$(run_in_tmp node "$validator" final-assets "$tmp" \
  docs/dev-flow/features/legacy-finalized/feature.md \
  docs/dev-flow/features/legacy-finalized/completion.md 2>&1)
legacy_rc=$?
assert_eq 'legacy finalized completion remains compatible' 0 "$legacy_rc"
if printf '%s' "$legacy_out" | rg -q 'WARN legacy finalized completion'; then
  printf 'PASS legacy finalized completion emits warning\n'
else
  printf 'FAIL legacy finalized completion warning missing\n'
  failures=$((failures + 1))
fi

mkdir -p "$tmp/docs/dev-flow/features/legacy-partial"
printf '%s\n' '# legacy partial feature' > "$tmp/docs/dev-flow/features/legacy-partial/feature.md"
printf '%s\n' '---' 'dev_flow_completion:' '  retention: "compact"' \
  '  outcome: "partial"' '  accepted_risks: ["AR-old"]' '---' '# legacy partial completion' \
  > "$tmp/docs/dev-flow/features/legacy-partial/completion.md"
legacy_partial_out=$(run_in_tmp node "$validator" final-assets "$tmp" \
  docs/dev-flow/features/legacy-partial/feature.md \
  docs/dev-flow/features/legacy-partial/completion.md 2>&1)
legacy_partial_rc=$?
assert_eq 'legacy partial completion remains compatible' 0 "$legacy_partial_rc"
if printf '%s' "$legacy_partial_out" | rg -q 'WARN legacy partial completion'; then
  printf 'PASS legacy partial completion emits AR preservation warning\n'
else
  printf 'FAIL legacy partial completion AR preservation warning missing\n'
  failures=$((failures + 1))
fi

# A fresh fingerprint is insufficient when the stamped outcome differs from completion.
cp "$tmp/.claude/runtime/dev-flow/alpha.check-ok" "$tmp/.claude/runtime/dev-flow/alpha.check-ok.valid"
sed 's/^outcome: verified$/outcome: partial/' \
  "$tmp/.claude/runtime/dev-flow/alpha.check-ok.valid" \
  > "$tmp/.claude/runtime/dev-flow/alpha.check-ok"
expect_fail run_in_tmp "$finalizer" alpha --retention=compact
mv "$tmp/.claude/runtime/dev-flow/alpha.check-ok.valid" \
  "$tmp/.claude/runtime/dev-flow/alpha.check-ok"

# Status can change without changing the business fingerprint. Finalizer must
# revalidate the active route instead of trusting an older business-only stamp.
cp "$tmp/docs/dev-flow/features/alpha/status.md" "$tmp/docs/dev-flow/features/alpha/status.route-valid"
sed '/^    - verification-before-completion$/d' \
  "$tmp/docs/dev-flow/features/alpha/status.route-valid" \
  > "$tmp/docs/dev-flow/features/alpha/status.md"
expect_fail run_in_tmp "$finalizer" alpha --retention=compact
mv "$tmp/docs/dev-flow/features/alpha/status.route-valid" \
  "$tmp/docs/dev-flow/features/alpha/status.md"

printf '%s\n' 'archive target sentinel' > "$tmp/.claude/archive-sentinel"
ln -s "$tmp/.claude" "$tmp/docs/dev-flow/features/alpha/archive"
expect_fail run_in_tmp "$finalizer" alpha --retention=full
assert_file "$tmp/.claude/archive-sentinel"
rm "$tmp/docs/dev-flow/features/alpha/archive"

# ---------- dry-run: exit 0, zero modifications ----------
before_alpha_status=$(snapshot_path "$tmp/docs/dev-flow/features/alpha/status.md")
before_alpha_ver=$(snapshot_path "$tmp/docs/dev-flow/reviews/alpha-verification.md")
before_alpha_completion=$(snapshot_path "$tmp/docs/dev-flow/features/alpha/completion.md")
before_beta_status=$(snapshot_path "$tmp/docs/dev-flow/features/beta/status.md")
before_beta_ver=$(snapshot_path "$tmp/docs/dev-flow/reviews/beta-verification.md")

dry_out=$(run_in_tmp "$finalizer" alpha --retention=compact 2>&1)
dry_rc=$?
assert_eq 'dry-run exits 0' 0 "$dry_rc"
inv=$(printf '%s\n' "$dry_out" | sed -n 's/^Inventory: //p' | head -1)
if [ -n "$inv" ] && printf '%s' "$inv" | rg -q '^[0-9a-f]{64}$'; then
  printf 'PASS dry-run prints 64-hex Inventory\n'
else
  printf 'FAIL dry-run Inventory missing or malformed: %s\n' "$inv"
  failures=$((failures + 1))
fi
assert_eq 'dry-run does not mutate alpha status' "$before_alpha_status" "$(snapshot_path "$tmp/docs/dev-flow/features/alpha/status.md")"
assert_eq 'dry-run does not mutate alpha verification' "$before_alpha_ver" "$(snapshot_path "$tmp/docs/dev-flow/reviews/alpha-verification.md")"
assert_file "$tmp/docs/dev-flow/features/alpha/status.md"
assert_file "$tmp/docs/dev-flow/reviews/alpha-verification.md"
assert_file "$tmp/.claude/runtime/dev-flow/alpha.check-ok"

# ---------- confirm without inventory fails, zero mods ----------
expect_fail run_in_tmp "$finalizer" alpha --retention=compact --confirm
assert_eq 'no-inventory confirm does not mutate status' "$before_alpha_status" "$(snapshot_path "$tmp/docs/dev-flow/features/alpha/status.md")"
assert_file "$tmp/docs/dev-flow/features/alpha/status.md"
assert_file "$tmp/.claude/runtime/dev-flow/alpha.check-ok"

# ---------- inventory hash drift: zero-mod fail ----------
expect_fail run_in_tmp "$finalizer" alpha --retention=compact --confirm --inventory deadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef
assert_eq 'hash-drift does not mutate status' "$before_alpha_status" "$(snapshot_path "$tmp/docs/dev-flow/features/alpha/status.md")"
assert_eq 'hash-drift does not mutate verification' "$before_alpha_ver" "$(snapshot_path "$tmp/docs/dev-flow/reviews/alpha-verification.md")"
assert_eq 'hash-drift leaves beta status alone' "$before_beta_status" "$(snapshot_path "$tmp/docs/dev-flow/features/beta/status.md")"
assert_file "$tmp/docs/dev-flow/features/alpha/status.md"
assert_file "$tmp/.claude/runtime/dev-flow/alpha.check-ok"

# ---------- mid-move failure full recovery ----------
# Inject failure after the first quarantine move; everything must restore.
fail_out=$(
  cd "$tmp" && DEV_FLOW_FINALIZE_FAIL_AFTER=1 \
    "$finalizer" alpha --retention=full --confirm --inventory "$inv" 2>&1
) || true
assert_file "$tmp/docs/dev-flow/features/alpha/status.md"
