#!/usr/bin/env bash
# Print the business diff fingerprint: a git hash over unstaged + staged
# diffs and untracked files, excluding workflow asset paths. Shared by
# dev-flow-feature-check and the finish-guard hook so freshness comparisons
# always use one implementation.
#
# Usage: dev-flow-fingerprint [<feature-root> <review-root>]
# Roots default to the values in .claude/rules/project-workflow.md.
set -u

root=$(git rev-parse --show-toplevel 2>/dev/null) || exit 2
cd "$root" || exit 2

workflow_file=.claude/rules/project-workflow.md

config_value() {
  awk -v key="$1" '$0 ~ "^[[:space:]]*" key ":" { value=$0; sub("^[^:]*:[[:space:]]*", "", value); gsub(/^"|"$/, "", value); print value; exit }' "$workflow_file" 2>/dev/null
}

feature_root=${1:-$(config_value feature_root)}
review_root=${2:-$(config_value review_root)}
if [ -z "$feature_root" ] || [ -z "$review_root" ]; then
  printf 'ERROR feature/review roots are unavailable\n' >&2
  exit 2
fi

is_workflow_path() {
  case "$1" in
    .claude/*|"$feature_root"/*|"$review_root"/*|docs/claude-dev-flow-*) return 0 ;;
    *) return 1 ;;
  esac
}

{
  git diff --binary -- . \
    ':(exclude).claude/**' \
    ":(exclude)$feature_root/**" \
    ":(exclude)$review_root/**" \
    ':(exclude)docs/claude-dev-flow-*'
  git diff --cached --binary -- . \
    ':(exclude).claude/**' \
    ":(exclude)$feature_root/**" \
    ":(exclude)$review_root/**" \
    ':(exclude)docs/claude-dev-flow-*'
  while IFS= read -r file; do
    [ -z "$file" ] && continue
    if ! is_workflow_path "$file"; then
      printf 'UNTRACKED %s ' "$file"
      git hash-object -- "$file"
    fi
  done < <(git -c core.quotePath=false ls-files --others --exclude-standard)
} | git hash-object --stdin
