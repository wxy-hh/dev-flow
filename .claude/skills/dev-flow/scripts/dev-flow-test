#!/usr/bin/env bash
# Run the complete dev-flow package regression suite from this script's path.
# Every group runs even after a failure so maintainers receive the full result.
set -u

scripts_dir=$(cd "$(dirname "$0")" && pwd)
tests_dir="$scripts_dir/tests"
failures=0

run_group() {
  local label=$1 command=$2
  printf '\n== %s ==\n' "$label"
  if "$command"; then
    printf 'PASS suite: %s\n' "$label"
  else
    printf 'FAIL suite: %s\n' "$label"
    failures=$((failures + 1))
  fi
}

for test_name in \
  dev-flow-status-test \
  dev-flow-feature-check-test \
  dev-flow-finalize-test \
  dev-flow-hooks-test \
  dev-flow-execution-test \
  dev-flow-upgrade-test \
  dev-flow-doctor-test; do
  run_group "$test_name" "$tests_dir/$test_name"
done
run_group dev-flow-doctor "$scripts_dir/dev-flow-doctor"

printf '\nSummary: %s failure(s) across 7 regression groups plus doctor\n' "$failures"
[ "$failures" -eq 0 ]
