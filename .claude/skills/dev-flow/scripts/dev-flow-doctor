#!/usr/bin/env bash
# Static consistency checks for the lean dev-flow package.
set -uo pipefail

root=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
cd "$root" || exit 2

passes=0
warnings=0
failures=0
pass() { printf 'PASS %s\n' "$1"; passes=$((passes + 1)); }
warn() { printf 'WARN %s\n' "$1"; warnings=$((warnings + 1)); }
fail() { printf 'FAIL %s\n' "$1"; failures=$((failures + 1)); }

check_file() {
  [ -f "$1" ] && pass "file exists: $1" || fail "missing file: $1"
}

require_pattern() {
  local file=$1 pattern=$2 label=$3
  if [ ! -f "$file" ]; then
    fail "$label (missing $file)"
  elif rg -q -- "$pattern" "$file"; then
    pass "$label"
  else
    fail "$label"
  fi
}

forbid_pattern() {
  local pattern=$1 label=$2
  shift 2
  local output status
  output=$(rg -n -- "$pattern" "$@" 2>/dev/null)
  status=$?
  if [ "$status" -eq 0 ]; then
    fail "$label"
    printf '%s\n' "$output"
  elif [ "$status" -eq 1 ]; then
    pass "$label"
  else
    fail "$label (search failed)"
  fi
}

line_budget() {
  local file=$1 limit=$2 label=$3 lines
  [ -f "$file" ] || return
  lines=$(wc -l < "$file" | tr -d ' ')
  [ "$lines" -le "$limit" ] && pass "$label ($lines/$limit lines)" || fail "$label ($lines/$limit lines)"
}

printf '# dev-flow doctor\n\n'

for command in rg git; do
  command -v "$command" >/dev/null 2>&1 && pass "command available: $command" || fail "missing command: $command"
done

for file in \
  .claude/skills/dev-flow/SKILL.md \
  .claude/skills/dev-flow/scripts/dev-flow-feature-check \
  .claude/skills/dev-flow/scripts/tests/dev-flow-feature-check-test \
  .claude/commands/dev-task.md \
  .claude/commands/onboard-dev-flow.md \
  .claude/rules/project-workflow.template.md \
  templates/CLAUDE.dev-flow-snippet.md; do
  check_file "$file"
done

require_pattern .claude/rules/project-workflow.template.md 'version: "0\.4\.0"' 'project template uses workflow 0.4.0'
require_pattern .claude/rules/project-workflow.template.md 'feature_root:' 'project template defines feature_root'
require_pattern .claude/skills/dev-flow/SKILL.md 'security.*data.*money.*external.*availability|security.*money.*availability' 'dev-flow defines independent risk tags'
require_pattern .claude/skills/dev-flow/SKILL.md '三个及以上架构层' 'dev-flow treats cross-layer topology as an L signal'
require_pattern .claude/skills/dev-flow/SKILL.md '标签按失败后果触发' 'dev-flow risk tags are consequence-based'
require_pattern .claude/skills/dev-flow/SKILL.md '\[HUMAN GATE:implementation_approval\]' 'dev-flow contains the risk implementation gate'
require_pattern .claude/skills/dev-flow/SKILL.md '最初.*直接改|初始.*直接改|original.*direct' 'initial direct-change request cannot silently approve disclosed risk'
require_pattern .claude/skills/dev-flow/SKILL.md 'work\.md' 'dev-flow uses a single work file'
require_pattern .claude/skills/dev-flow/SKILL.md '普通 XS/S：零流程文件' 'dev-flow keeps ordinary small tasks artifact-free'
require_pattern .claude/skills/dev-flow/scripts/dev-flow-feature-check 'Approval evidence' 'feature checker requires approval evidence'
require_pattern .claude/skills/dev-flow/scripts/dev-flow-feature-check 'Verification' 'feature checker requires verification state'

if find .claude/skills/dev-flow/scripts -maxdepth 1 -type f -name '*finalize*' | rg -q .; then fail 'legacy finalizer is removed'; else pass 'legacy finalizer is removed'; fi
if find .claude/skills/dev-flow/scripts -maxdepth 1 -type f -name '*validate.mjs' | rg -q .; then fail 'legacy context validator is removed'; else pass 'legacy context validator is removed'; fi

active_paths=(.claude/agents .claude/commands .claude/skills .claude/rules README.md docs/claude-dev-flow-migration.md docs/claude-dev-flow-post-migration-usage.md docs/claude-dev-flow-smoke-test.md templates)
legacy_pattern='status[.]md|dev_flow_''status|context/(implement|review|verify)[.]jsonl|context man''ifest|context_man''ifest|review_''root:|runtime_''root:|sdd_''progress:|requirement_''confirmation|Auto-''continue|dev-flow-feature-final''ize|completion[.]md'
forbid_pattern "$legacy_pattern" \
  'active workflow has no legacy multi-asset contract' "${active_paths[@]}"

forbid_pattern '至少 3 个|找不到就是你失职' \
  'review prompts do not incentivize fabricated findings' \
  .claude/skills/plan-review/references/review-prompts.md

if rg -n '^tools: .*"(Write|Edit)"' .claude/agents/security-reviewer.md >/dev/null 2>&1; then
  fail 'security-reviewer is read-only'
else
  pass 'security-reviewer is read-only'
fi

leak_pattern='为当前项目规划时必须使用 Vue|pnpm dev:mock|Cmp-Menu|Cmp-Portal|placeAnOrder|getProductList'
leak_output=$(rg -n --glob '!vue3.md' --glob '!**/scripts/dev-flow-doctor' -- "$leak_pattern" .claude 2>/dev/null)
leak_status=$?
if [ "$leak_status" -eq 0 ]; then
  fail 'reusable workflow has no known source-project leakage'
  printf '%s\n' "$leak_output"
elif [ "$leak_status" -eq 1 ]; then
  pass 'reusable workflow has no known source-project leakage'
else
  fail 'source-project leakage scan failed'
fi

if [ -f .claude/rules/project-workflow.md ]; then
  require_pattern .claude/rules/project-workflow.md '^dev_flow:' 'project workflow has dev_flow config'
  require_pattern .claude/rules/project-workflow.md 'version: "0\.4\.0"' 'project workflow uses 0.4.0'
  forbid_pattern '<detect|<none\|present>|<local-config\|repo-governed>|<disabled\|enabled>|<optional\|required\|custom>' \
    'project workflow has no unresolved placeholders' .claude/rules/project-workflow.md
else
  warn 'source package has no project-workflow.md; target projects must run /onboard-dev-flow'
fi

while IFS= read -r script; do
  [ -x "$script" ] && pass "script is executable: $script" || fail "script is not executable: $script"
done < <(find .claude/skills -path '*/scripts/*' -type f | sort)

line_budget .claude/skills/dev-flow/SKILL.md 250 'dev-flow core stays compact'
line_budget .claude/rules/project-workflow.template.md 180 'project template stays compact'
line_budget .claude/skills/dev-flow/scripts/dev-flow-feature-check 220 'feature checker stays compact'

printf '\nSummary: %s passed, %s warning(s), %s failure(s)\n' "$passes" "$warnings" "$failures"
[ "$failures" -eq 0 ]
