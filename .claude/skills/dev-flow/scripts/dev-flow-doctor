#!/usr/bin/env bash
# 静态检查 dev-flow 迁移包或已 onboarding 项目的关键约束。
# 不修改业务代码，不运行项目测试，不生成流程产物。
set -uo pipefail

failures=0
warnings=0
passes=0

root=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
cd "$root" || exit 2

PREFLIGHT=false
for arg in "$@"; do
  case "$arg" in
    --preflight) PREFLIGHT=true ;;
    --help|-h) printf 'Usage: %s [--preflight]\n' "$0"; exit 0 ;;
  esac
done

CONTRACT=".claude/skills/dev-flow/contract.json"

pass() { printf 'PASS %s\n' "$1"; passes=$((passes + 1)); }
warn() { printf 'WARN %s\n' "$1"; warnings=$((warnings + 1)); }
fail() { printf 'FAIL %s\n' "$1"; failures=$((failures + 1)); }

need_cmd() {
  if command -v "$1" >/dev/null 2>&1; then
    pass "command available: $1"
  else
    fail "missing required command: $1"
  fi
}

check_file() {
  if [ -f "$1" ]; then
    pass "file exists: $1"
  else
    fail "missing file: $1"
  fi
}

check_exec() {
  if [ -x "$1" ]; then
    pass "script is executable: $1"
  else
    fail "script is not executable: $1"
  fi
}

require_pattern() {
  local file=$1 pattern=$2 message=$3
  if [ ! -f "$file" ]; then
    fail "$message (file missing: $file)"
    return
  fi
  if rg -q -- "$pattern" "$file"; then
    pass "$message"
  else
    fail "$message"
  fi
}

forbid_pattern() {
  local pattern=$1 message=$2
  shift 2
  local output status
  output=$(rg -n -- "$pattern" "$@" 2>/dev/null)
  status=$?
  if [ "$status" -eq 0 ]; then
    fail "$message"
    printf '%s\n' "$output"
  elif [ "$status" -eq 1 ]; then
    pass "$message"
  else
    fail "$message (search failed)"
  fi
}

contract_field() {
  node -e "
    const c = JSON.parse(require('fs').readFileSync('$CONTRACT', 'utf8'));
    const v = $1;
    if (Array.isArray(v)) { v.forEach((x) => console.log(x)); }
    else if (v && typeof v === 'object') { Object.entries(v).forEach(([k, val]) => console.log(k + '\t' + val)); }
    else { console.log(v); }
  " 2>/dev/null
}

printf '# dev-flow doctor\n\n'

## ---------------------------------------------------------------------
## 结构：关键文件、可执行脚本、契约可解析、孪生技能已合并、hooks 已注册
## ---------------------------------------------------------------------
printf '## 结构\n\n'

need_cmd git
need_cmd rg
need_cmd node

for f in \
  ".claude/rules/project-workflow.template.md" \
  ".claude/rules/specs/README.md" \
  "$CONTRACT" \
  ".claude/skills/dev-flow/SKILL.md" \
  ".claude/skills/dev-flow/references/protocol.md" \
  ".claude/skills/dev-flow/references/standard-ml.md" \
  ".claude/skills/dev-flow/references/risk-gates.md" \
  ".claude/skills/req-probe/SKILL.md" \
  ".claude/skills/dev-flow/scripts/dev-flow-policy.mjs" \
  ".claude/skills/dev-flow/scripts/dev-flow-feature-check" \
  ".claude/skills/dev-flow/scripts/dev-flow-feature-finalize" \
  ".claude/skills/dev-flow/scripts/dev-flow-fingerprint" \
  ".claude/skills/dev-flow/scripts/dev-flow-validate.mjs" \
  ".claude/agents/security-reviewer.md" \
  ".claude/skills/plan-review/references/review-prompts.md" \
  ".claude/skills/code-review/references/code-reviewer.md" \
  ".claude/skills/executing-plans/implementer-prompt.md" \
  ".claude/skills/executing-plans/task-reviewer-prompt.md" \
  ".claude/skills/executing-plans/references/subagent-mode.md" \
  ".claude/skills/executing-plans/scripts/task-brief" \
  ".claude/skills/executing-plans/scripts/review-package" \
  ".claude/skills/executing-plans/scripts/task-schedule" \
  ".claude/skills/executing-plans/scripts/sdd-workspace" \
  ".claude/skills/executing-plans/scripts/sdd-checkpoint" \
  ".claude/skills/dev-flow/scripts/dev-flow-status.mjs" \
  ".claude/skills/dev-flow/scripts/dev-flow-test" \
  ".claude/skills/dev-flow/scripts/dev-flow-manifest" \
  ".claude/skills/dev-flow/scripts/dev-flow-upgrade" \
  ".claude/skills/dev-flow/references/status-cli.md" \
  ".claude/skills/dev-flow/references/partial-verification.md" \
  ".claude/settings.json" \
  ".claude/hooks/dev-flow-gate-guard.sh" \
  ".claude/hooks/dev-flow-finish-guard.sh"; do
  check_file "$f"
done

if node -e "JSON.parse(require('fs').readFileSync('$CONTRACT', 'utf8'))" >/dev/null 2>&1; then
  pass "contract.json parses as valid JSON"
else
  fail "contract.json parses as valid JSON"
fi

for stale_dir in grilling requesting-code-review subagent-driven-development; do
  if [ -e ".claude/skills/$stale_dir" ]; then
    fail "merged-away skill directory still present: .claude/skills/$stale_dir"
  else
    pass "merged-away skill directory absent: $stale_dir"
  fi
done

if [ -f ".claude/settings.json" ] && rg -q 'dev-flow-gate-guard\.sh' ".claude/settings.json" && rg -q 'dev-flow-finish-guard\.sh' ".claude/settings.json"; then
  pass "settings.json registers both dev-flow hooks"
else
  fail "settings.json registers both dev-flow hooks"
fi

scoped_spec_count=0
while IFS= read -r spec_index; do
  scoped_spec_count=$((scoped_spec_count + 1))
  require_pattern "$spec_index" '^## Pre-Development Checklist' "scoped spec has Pre-Development Checklist: $spec_index"
  require_pattern "$spec_index" '^## Quality Check' "scoped spec has Quality Check: $spec_index"
done < <(find .claude/rules/specs -mindepth 2 -maxdepth 2 -name index.md 2>/dev/null | sort)
[ "$scoped_spec_count" -eq 0 ] && pass "no scoped spec index files configured"

script_count=0
while IFS= read -r script; do
  script_count=$((script_count + 1))
  check_exec "$script"
done < <({ find .claude/skills -path '*/scripts/*' -type f; find .claude/hooks -type f 2>/dev/null; } | sort)
[ "$script_count" -eq 0 ] && warn "no skill scripts found"

## Forbidden call edges (Layer 0/1/2 isolation)
# status ↛ feature-check/finalize; feature-check ↛ status/finalize;
# finalize ↛ status/feature-check; validator/fingerprint/policy ↛ mutators.
scripts_dir=".claude/skills/dev-flow/scripts"
forbid_call_edge() {
  local source=$1
  local pattern=$2
  local label=$3
  local hits
  # Ignore comments and pure prohibition docs; match real path/command references.
  hits=$(rg -n -- "$pattern" "$source" 2>/dev/null \
    | rg -v ':[ \t]*(#|//|/\*|\*)' \
    | rg -v 'Must not call|禁止调用' \
    || true)
  if [ -n "$hits" ]; then
    fail "forbidden call edge: $label"
    printf '%s\n' "$hits"
  else
    pass "forbidden call edge absent: $label"
  fi
}
forbid_call_edge "$scripts_dir/dev-flow-status.mjs" 'dev-flow-feature-check|dev-flow-feature-finalize' 'status → feature-check/finalize'
forbid_call_edge "$scripts_dir/dev-flow-feature-check" 'dev-flow-status|dev-flow-feature-finalize' 'feature-check → status/finalize'
forbid_call_edge "$scripts_dir/dev-flow-feature-finalize" 'dev-flow-status|dev-flow-feature-check' 'feature-finalize → status/feature-check'
forbid_call_edge "$scripts_dir/dev-flow-validate.mjs" 'dev-flow-status|dev-flow-feature-check|dev-flow-feature-finalize' 'validator → mutators'
forbid_call_edge "$scripts_dir/dev-flow-fingerprint" 'dev-flow-status|dev-flow-feature-check|dev-flow-feature-finalize|dev-flow-validate' 'fingerprint → upper layers'
forbid_call_edge "$scripts_dir/dev-flow-policy.mjs" 'dev-flow-status|dev-flow-feature-check|dev-flow-feature-finalize|dev-flow-validate|dev-flow-fingerprint' 'policy → upper layers'

## ---------------------------------------------------------------------
## preflight：本地安装完整性（不比较源包）
## ---------------------------------------------------------------------
if [ "$PREFLIGHT" = true ]; then
  printf '\n## preflight\n\n'

  MANIFEST=".claude/dev-flow.manifest.json"
  if [ -f "$MANIFEST" ]; then
    if .claude/skills/dev-flow/scripts/dev-flow-manifest verify --manifest "$MANIFEST" >/tmp/dev-flow-manifest-verify.out 2>&1; then
      pass "managed manifest hashes match local files"
    else
      fail "managed manifest hashes match local files"
      cat /tmp/dev-flow-manifest-verify.out 2>/dev/null | head -20
    fi
  else
    warn "no .claude/dev-flow.manifest.json (expected after v0.7 upgrade/onboarding)"
  fi

  if [ -f ".claude/settings.json" ] && rg -q 'dev-flow-gate-guard\.sh' ".claude/settings.json" && rg -q 'dev-flow-finish-guard\.sh' ".claude/settings.json"; then
    pass "hooks registered in settings.json"
  else
    fail "hooks registered in settings.json"
  fi
  for h in .claude/hooks/dev-flow-gate-guard.sh .claude/hooks/dev-flow-finish-guard.sh; do
    check_exec "$h"
  done

  if [ -f ".claude/rules/project-workflow.md" ]; then
    require_pattern ".claude/rules/project-workflow.md" '^dev_flow:' "project-workflow.md has dev_flow config"
    forbid_pattern '<detect|<none\|present>|<false\|true>|<local-config\|repo-governed>|<required-for-L-behavior\|optional\|custom>|<disabled\|enabled>' \
      "project-workflow.md has no unresolved config placeholders" \
      ".claude/rules/project-workflow.md"
    mode=$(awk '/^[[:space:]]*enforcement_mode:/ { v=$0; sub(/^[^:]*:[[:space:]]*/, "", v); gsub(/^"|"$/, "", v); print v; exit }' ".claude/rules/project-workflow.md")
    [ -z "$mode" ] && mode=off
    if [ "$mode" = strict ]; then
      roots=$(awk '
        /^[[:space:]]*protected_write_roots:[[:space:]]*$/ { in_block=1; next }
        in_block && /^[[:space:]]*-[[:space:]]+/ { print; next }
        in_block && /^[[:space:]]*[a-z_]+:/ { exit }
        /^[[:space:]]*protected_write_roots:[[:space:]]*\[/ { print; exit }
      ' ".claude/rules/project-workflow.md")
      roots_trimmed=$(printf '%s' "$roots" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
      if [ -z "$roots_trimmed" ] || [ "$roots_trimmed" = "[]" ] || [ "$roots_trimmed" = "protected_write_roots: []" ]; then
        fail "strict enforcement_mode requires non-empty protected_write_roots"
      else
        unsafe=false
        while IFS= read -r line; do
          [ -z "$line" ] && continue
          case "$line" in
            *..*|*//*) unsafe=true ;;
          esac
        done <<< "$roots"
        if [ "$unsafe" = true ]; then
          fail "protected_write_roots contains unsafe patterns"
        else
          pass "strict mode has non-empty safe protected_write_roots"
        fi
      fi
    else
      pass "enforcement_mode is $mode (strict root check skipped)"
    fi
  else
    warn "project-workflow.md missing for preflight (ok in source migration package; target projects need /onboard-dev-flow)"
  fi

  for stale_dir in grilling requesting-code-review subagent-driven-development; do
    if [ -e ".claude/skills/$stale_dir" ]; then
      fail "merged-away skill directory still present: $stale_dir"
    else
      pass "merged-away skill directory absent: $stale_dir"
    fi
  done

  printf '\nSummary: %s passed, %s warning(s), %s failure(s)\n' "$passes" "$warnings" "$failures"
  [ "$failures" -eq 0 ]
  exit $?
fi

if git check-ignore -q ".claude/runtime/sdd/.probe" 2>/dev/null; then
  pass ".claude/runtime is ignored"
else
  fail ".claude/runtime is not ignored"
fi

if git check-ignore -q ".claude/settings.local.json" 2>/dev/null; then
  pass ".claude/settings.local.json is ignored"
else
  fail ".claude/settings.local.json is not ignored"
fi

## ---------------------------------------------------------------------
## 一致性：risk-gates.md 与 contract.json 同步、行数预算、单一版本源、无泄漏
## ---------------------------------------------------------------------
printf '\n## 一致性\n\n'

while IFS= read -r label; do
  [ -z "$label" ] && continue
  require_pattern ".claude/skills/dev-flow/references/risk-gates.md" "\`${label}\`" "risk-gates.md documents risk label: ${label}"
done < <(contract_field 'c.risk_labels')

# contract.json is the machine authority. The documentation table is checked
# deliberately narrowly: only the per-label backticked `gate: level` entries
# in the minimum-mapping table participate, so prose and table presentation can
# evolve without becoming a parser protocol.
risk_gates_doc=".claude/skills/dev-flow/references/risk-gates.md"
mapping_tmp=$(mktemp)
node - "$CONTRACT" "$risk_gates_doc" > "$mapping_tmp" <<'NODE'
const fs = require('fs');
const [, , contractPath, docPath] = process.argv;
const minimum = JSON.parse(fs.readFileSync(contractPath, 'utf8')).minimum_risk_gates || {};
const lines = fs.readFileSync(docPath, 'utf8').split(/\r?\n/);
const rows = new Map();
const duplicateLabels = new Set();
let inMapping = false;
for (const line of lines) {
  if (/^##\s+最低门禁映射\s*$/.test(line)) {
    inMapping = true;
    continue;
  }
  if (inMapping && /^##\s+/.test(line)) break;
  if (!inMapping || !/^\s*\|/.test(line)) continue;
  const cells = line.split('|');
  const labelMatch = (cells[1] || '').match(/`([^`]+)`/);
  if (!labelMatch) continue;
  const label = labelMatch[1];
  if (rows.has(label)) duplicateLabels.add(label);
  const fragments = [...(cells.slice(2).join('|').matchAll(/`([^`]+)`/g))]
    .map((match) => match[1])
    .filter((value) => /^[a-z_]+:\s*(?:none|light|full)$/.test(value));
  rows.set(label, new Set(fragments.map((value) => value.replace(/:\s+/, ': '))));
}
let failures = 0;
for (const [label, gates] of Object.entries(minimum)) {
  const actual = rows.get(label);
  if (!actual) {
    console.log(`MISSING_LABEL\t${label}`);
    failures += 1;
    continue;
  }
  const expected = new Set(Object.entries(gates).map(([gate, level]) => `${gate}: ${level}`));
  for (const gate of expected) {
    if (!actual.has(gate)) {
      console.log(`MISSING_GATE\t${label}\t${gate}`);
      failures += 1;
    }
  }
  for (const gate of actual) {
    if (!expected.has(gate)) {
      console.log(`EXTRA_GATE\t${label}\t${gate}`);
      failures += 1;
    }
  }
}
for (const label of rows.keys()) {
  if (!Object.hasOwn(minimum, label)) {
    console.log(`EXTRA_LABEL\t${label}`);
    failures += 1;
  }
}
for (const label of duplicateLabels) {
  console.log(`DUPLICATE_LABEL\t${label}`);
  failures += 1;
}
if (failures === 0) console.log('PASS\tminimum risk mappings exactly match contract');
NODE
mapping_status=$?
mapping_output=$(cat "$mapping_tmp")
rm -f "$mapping_tmp"
if [ "$mapping_status" -ne 0 ]; then
  fail "risk-gates.md minimum mapping check could not read contract/table"
else
  while IFS=$'\t' read -r kind label gate; do
    [ -z "$kind" ] && continue
    case "$kind" in
      PASS) pass "risk-gates.md minimum mappings exactly match contract" ;;
      MISSING_LABEL) fail "risk-gates.md minimum mapping missing label: $label" ;;
      EXTRA_LABEL) fail "risk-gates.md minimum mapping has extra label: $label" ;;
      DUPLICATE_LABEL) fail "risk-gates.md minimum mapping has duplicate label: $label" ;;
      MISSING_GATE) fail "risk-gates.md minimum mapping missing gate for $label: $gate" ;;
      EXTRA_GATE) fail "risk-gates.md minimum mapping has extra gate for $label: $gate" ;;
    esac
  done <<< "$mapping_output"
fi

while IFS= read -r line; do
  [ -z "$line" ] && continue
  budget_path=${line%%$'\t'*}
  budget_max=${line##*$'\t'}
  [ "$budget_path" = "per_downstream_skill_max" ] && continue
  if [ ! -f "$budget_path" ]; then
    fail "line budget target missing: $budget_path"
    continue
  fi
  actual=$(wc -l < "$budget_path" | tr -d ' ')
  if [ "$actual" -le "$budget_max" ]; then
    pass "line budget: $budget_path ($actual/$budget_max)"
  else
    fail "line budget exceeded: $budget_path ($actual/$budget_max)"
  fi
done < <(contract_field 'c.line_budgets')

per_skill_max=$(contract_field 'c.line_budgets.per_downstream_skill_max')
if [ -f .claude/dev-flow.manifest.json ]; then
  while IFS= read -r skill_file; do
    [ -z "$skill_file" ] && continue
    [ -f "$skill_file" ] || continue
    actual=$(wc -l < "$skill_file" | tr -d ' ')
    if [ "$actual" -le "$per_skill_max" ]; then
      pass "line budget: $skill_file ($actual/$per_skill_max)"
    else
      fail "line budget exceeded: $skill_file ($actual/$per_skill_max)"
    fi
  done < <(node -e '
    const fs = require("fs");
    const m = JSON.parse(fs.readFileSync(".claude/dev-flow.manifest.json", "utf8"));
    for (const entry of m.files || []) {
      if (/^\.claude\/skills\/[^/]+\/SKILL\.md$/.test(entry.path)
          && entry.path !== ".claude/skills/dev-flow/SKILL.md") {
        console.log(entry.path);
      }
    }
  ' | sort -u)
else
  warn "manifest missing; skip downstream skill line budgets"
fi

# Package version single-source: only contract.json may hardcode a numeric
# workflow_version. Exclude:
# - docs/plans/** — design/implementation plans may name target versions
# - **/scripts/tests/** — fixtures simulate stamps/completions
# - **/completion.md — feature provenance stamps (protocol schema 2); not package
#   sources. Host projects keep old or current stamps across upgrade; doctor and
#   upgrade preflight must not treat them as version-source leaks.
# Only scan roots that exist (host upgrades often lack templates/README.md).
version_scan_paths=()
for version_scan_path in .claude templates README.md docs; do
  if [ -e "$version_scan_path" ]; then
    version_scan_paths+=("$version_scan_path")
  fi
done
if [ "${#version_scan_paths[@]}" -eq 0 ]; then
  pass "workflow_version has a single source of truth (contract.json)"
else
  version_output=$(rg -n \
    --glob '!contract.json' \
    --glob '!docs/plans/**' \
    --glob '!**/scripts/tests/**' \
    --glob '!**/completion.md' \
    -- 'workflow_version:\s*"[0-9]' \
    "${version_scan_paths[@]}" 2>/dev/null)
  version_status=$?
  if [ "$version_status" -eq 1 ]; then
    pass "workflow_version has a single source of truth (contract.json)"
  elif [ "$version_status" -eq 0 ]; then
    fail "workflow_version is hardcoded outside contract.json"
    printf '%s\n' "$version_output"
  else
    fail "workflow_version single-source check failed to run"
  fi
fi

leak_pattern='为当前项目规划时必须使用 Vue|pnpm dev:mock|Cmp-Menu|Cmp-Portal|src/mock|Vue/Vue Router/Pinia API 已自动导入|是否违反 Vue 3|Vue/TS|Vue/TypeScript|Vue 模板|accountType|request\.ts|Vue 性能|placeAnOrder|getProductList'
# Framework/stack rules are project-owned and not part of the reusable package;
# scan only managed workflow surfaces. Custom stack rules under .claude/rules
# are ignored so doctor does not treat project-local conventions as package leaks.
leak_output=$(rg -n --glob '!**/scripts/dev-flow-doctor' -- "$leak_pattern" \
  ".claude/agents" ".claude/commands" ".claude/skills" 2>/dev/null)
leak_status=$?
if [ "$leak_status" -eq 1 ]; then
  pass "reusable workflow layer has no known source-project leakage"
elif [ "$leak_status" -eq 0 ]; then
  fail "reusable workflow layer has no known source-project leakage"
  printf '%s\n' "$leak_output"
else
  fail "reusable workflow layer has no known source-project leakage (search failed)"
fi

heavy_pattern='Tr[e]llis|task[.]json|workflow[-]state|jo[u]rnal|auto[-]commit|默认创建[ ]task'
heavy_scan_paths=()
for heavy_scan_path in .claude/agents .claude/commands .claude/skills .claude/rules README.md docs templates; do
  if [ -e "$heavy_scan_path" ]; then
    heavy_scan_paths+=("$heavy_scan_path")
  fi
done
if [ "${#heavy_scan_paths[@]}" -eq 0 ]; then
  pass "workflow layer does not introduce heavy workflow concepts"
else
  heavy_output=$(rg -n --glob '!**/scripts/dev-flow-doctor' -- "$heavy_pattern" \
    "${heavy_scan_paths[@]}" 2>/dev/null)
  heavy_status=$?
  if [ "$heavy_status" -eq 1 ]; then
    pass "workflow layer does not introduce heavy workflow concepts"
  elif [ "$heavy_status" -eq 0 ]; then
    fail "workflow layer does not introduce heavy workflow concepts"
    printf '%s\n' "$heavy_output"
  else
    fail "workflow layer does not introduce heavy workflow concepts (search failed)"
  fi
fi

forbid_pattern '至少 3 个|找不到就是你失职' \
  "plan-review prompts do not incentivize fabricated findings" \
  ".claude/skills/plan-review/references/review-prompts.md"

if rg -n '^tools: .*"(Write|Edit)"' ".claude/agents/security-reviewer.md" >/dev/null; then
  fail "security-reviewer is not read-only"
  rg -n '^tools: .*"(Write|Edit)"' ".claude/agents/security-reviewer.md"
else
  pass "security-reviewer is read-only"
fi

## ---------------------------------------------------------------------
## 适配层：仅当目标项目已 onboard（存在 project-workflow.md）时检查
## ---------------------------------------------------------------------
printf '\n## 适配层\n\n'

if [ -f ".claude/rules/project-workflow.md" ]; then
  require_pattern ".claude/rules/project-workflow.md" '^dev_flow:' "project-workflow.md has dev_flow config"
  require_pattern ".claude/rules/project-workflow.md" 'retention:' "project-workflow.md has artifact retention config"
  expected_workflow_version=$(contract_field 'c.workflow_version')
  project_workflow_version=$(awk '
    /^dev_flow:[[:space:]]*$/ { in_dev_flow=1; next }
    in_dev_flow && /^  version:[[:space:]]*/ {
      value=$0
      sub(/^[^:]*:[[:space:]]*/, "", value)
      gsub(/^"|"$/, "", value)
      print value
      exit
    }
    in_dev_flow && /^[^[:space:]]/ { exit }
  ' .claude/rules/project-workflow.md)
  if [ "$project_workflow_version" = "$expected_workflow_version" ]; then
    pass "project-workflow.md version matches contract ($expected_workflow_version)"
  else
    fail "project-workflow.md version must match contract ($expected_workflow_version; got ${project_workflow_version:-missing})"
  fi
  forbid_pattern '<detect|<none\|present>|<false\|true>|<local-config\|repo-governed>|<required-for-L-behavior\|optional\|custom>|<disabled\|enabled>' \
    "project-workflow.md has no unresolved config placeholders" \
    ".claude/rules/project-workflow.md"

  if rg -n '\|\s*test\s*\|[^|]*(dev|watch|serve)|test:\s*.*(dev|watch|serve)' ".claude/rules/project-workflow.md" >/dev/null; then
    warn "project-workflow.md test command looks like a dev/watch command; confirm automated-tests is correct"
  else
    pass "project-workflow.md test command does not look like dev/watch"
  fi
else
  warn "missing .claude/rules/project-workflow.md; this is expected in the source migration package, but target projects should run /onboard-dev-flow"
fi

## ---------------------------------------------------------------------
## 核心不变量：只指向 protocol.md 与 SKILL.md，不再散射到下游技能
## ---------------------------------------------------------------------
printf '\n## 核心不变量\n\n'

require_pattern ".claude/skills/dev-flow/references/protocol.md" 'HUMAN GATE 硬协议' "protocol.md documents HUMAN GATE hard protocol"
require_pattern ".claude/skills/dev-flow/references/protocol.md" '当前回合必须停止' "protocol.md requires stopping the turn on HUMAN GATE/Auto-continue:no"
require_pattern ".claude/skills/dev-flow/references/protocol.md" '不能由实现后的' "protocol.md keeps plan-review from being replaced by code-review"
require_pattern ".claude/skills/dev-flow/references/protocol.md" '\[HANDOFF\]' "protocol.md documents the HANDOFF format"
require_pattern ".claude/skills/dev-flow/references/protocol.md" '资产读取优先级' "protocol.md documents asset read priority"
require_pattern ".claude/skills/dev-flow/references/protocol.md" 'dev_flow_completion:' "protocol.md documents completion.md frontmatter schema"
require_pattern ".claude/skills/dev-flow/SKILL.md" '不可回归的三条底线' "dev-flow SKILL.md states the three non-negotiable baselines"
require_pattern ".claude/skills/dev-flow/SKILL.md" '风险不抬高规模' "dev-flow SKILL.md keeps risk labels from raising scale level"

require_pattern ".claude/commands/finish.md" '\[ASSET FINALIZATION\]' "finish.md documents ASSET FINALIZATION stop protocol"
require_pattern ".claude/commands/finish.md" '禁止同回合' "finish.md forbids same-turn --confirm"
require_pattern ".claude/commands/finish.md" 'not now' "finish.md documents not now path"
require_pattern ".claude/commands/finish.md" 'dev-flow-status.mjs complete-verification' "finish.md records verification through status CLI before feature-check"
finish_state_b=$(sed -n '/^### 状态 B：/,/^### 状态 C：/p' ".claude/commands/finish.md")
if printf '%s\n' "$finish_state_b" | rg -q -- 'dev_flow\.artifacts\.retention' \
  && printf '%s\n' "$finish_state_b" | rg -q -- '--retention="\$RETENTION"' \
  && ! printf '%s\n' "$finish_state_b" | rg -q -- '--retention=(compact|full)'; then
  pass "finish.md derives dry-run retention from project config"
else
  fail "finish.md must derive State B dry-run retention from dev_flow.artifacts.retention"
fi
require_pattern ".claude/skills/finishing-a-development-branch/SKILL.md" '\[ASSET FINALIZATION\]' "finishing skill documents ASSET FINALIZATION stop protocol"
require_pattern ".claude/skills/finishing-a-development-branch/SKILL.md" '--inventory' "finishing skill requires --inventory on confirm"
require_pattern ".claude/skills/verification-before-completion/SKILL.md" '不得互相调用' "verification skill forbids complete-verification/feature-check wrapper calls"
require_pattern ".claude/hooks/dev-flow-finish-guard.sh" 'logic-complete' "finish-guard handles logic-complete without finalizer"

## ---------------------------------------------------------------------
## 在途 feature：verified-unfinalized 仅 WARN（ready-to-finalize）
## ---------------------------------------------------------------------
printf '\n## 在途 feature\n\n'

if [ -f ".claude/rules/project-workflow.md" ]; then
  feature_root=$(awk '/^[[:space:]]*feature_root:/ { v=$0; sub(/^[^:]*:[[:space:]]*/, "", v); gsub(/^"|"$/, "", v); print v; exit }' ".claude/rules/project-workflow.md")
  if [ -n "$feature_root" ] && [ -d "$feature_root" ]; then
    unfinalized=0
    while IFS= read -r feature_dir; do
      [ -z "$feature_dir" ] && continue
      [ -f "$feature_dir/status.md" ] || continue
      [ -f "$feature_dir/completion.md" ] || continue
      feature_id=$(basename "$feature_dir")
      warn "ready-to-finalize: feature ${feature_id} is logic-complete with status still present (optional compact|retain full|not now; Git not blocked)"
      unfinalized=$((unfinalized + 1))
    done < <(find "$feature_root" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort)
    if [ "$unfinalized" -eq 0 ]; then
      pass "no verified-unfinalized features"
    fi
  else
    pass "no feature_root to scan for verified-unfinalized"
  fi
else
  pass "skip verified-unfinalized scan (no project-workflow.md)"
fi

printf '\nSummary: %s passed, %s warning(s), %s failure(s)\n' "$passes" "$warnings" "$failures"

if [ "$failures" -gt 0 ]; then
  exit 1
fi
