#!/usr/bin/env bash
# 静态检查 dev-flow 迁移包或已 onboarding 项目的关键约束。
# 不修改业务代码，不运行项目测试，不生成流程产物。
set -uo pipefail

failures=0
warnings=0
passes=0

root=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
cd "$root" || exit 2

CONTRACT=".claude/skills/dev-flow/contract.json"

pass() { printf 'PASS %s\n' "$1"; passes=$((passes + 1)); }
warn() { printf 'WARN %s\n' "$1"; warnings=$((warnings + 1)); }
fail() { printf 'FAIL %s\n' "$1"; failures=$((failures + 1)); }

need_cmd() {
  if command -v "$1" >/dev/null 2>&1; then
    pass "command available: $1"
  else
    fail "missing required command: $1"
  fi
}

check_file() {
  if [ -f "$1" ]; then
    pass "file exists: $1"
  else
    fail "missing file: $1"
  fi
}

check_exec() {
  if [ -x "$1" ]; then
    pass "script is executable: $1"
  else
    fail "script is not executable: $1"
  fi
}

require_pattern() {
  local file=$1 pattern=$2 message=$3
  if [ ! -f "$file" ]; then
    fail "$message (file missing: $file)"
    return
  fi
  if rg -q -- "$pattern" "$file"; then
    pass "$message"
  else
    fail "$message"
  fi
}

forbid_pattern() {
  local pattern=$1 message=$2
  shift 2
  local output status
  output=$(rg -n -- "$pattern" "$@" 2>/dev/null)
  status=$?
  if [ "$status" -eq 0 ]; then
    fail "$message"
    printf '%s\n' "$output"
  elif [ "$status" -eq 1 ]; then
    pass "$message"
  else
    fail "$message (search failed)"
  fi
}

contract_field() {
  node -e "
    const c = JSON.parse(require('fs').readFileSync('$CONTRACT', 'utf8'));
    const v = $1;
    if (Array.isArray(v)) { v.forEach((x) => console.log(x)); }
    else if (v && typeof v === 'object') { Object.entries(v).forEach(([k, val]) => console.log(k + '\t' + val)); }
    else { console.log(v); }
  " 2>/dev/null
}

printf '# dev-flow doctor\n\n'

## ---------------------------------------------------------------------
## 结构：关键文件、可执行脚本、契约可解析、孪生技能已合并、hooks 已注册
## ---------------------------------------------------------------------
printf '## 结构\n\n'

need_cmd git
need_cmd rg
need_cmd node

for f in \
  ".claude/rules/project-workflow.template.md" \
  ".claude/rules/specs/README.md" \
  "$CONTRACT" \
  ".claude/skills/dev-flow/SKILL.md" \
  ".claude/skills/dev-flow/references/protocol.md" \
  ".claude/skills/dev-flow/references/standard-ml.md" \
  ".claude/skills/dev-flow/references/risk-gates.md" \
  ".claude/skills/req-probe/SKILL.md" \
  ".claude/skills/dev-flow/scripts/dev-flow-feature-check" \
  ".claude/skills/dev-flow/scripts/dev-flow-feature-finalize" \
  ".claude/skills/dev-flow/scripts/dev-flow-fingerprint" \
  ".claude/skills/dev-flow/scripts/dev-flow-validate.mjs" \
  ".claude/agents/security-reviewer.md" \
  ".claude/skills/plan-review/references/review-prompts.md" \
  ".claude/skills/code-review/references/code-reviewer.md" \
  ".claude/skills/executing-plans/implementer-prompt.md" \
  ".claude/skills/executing-plans/task-reviewer-prompt.md" \
  ".claude/skills/executing-plans/references/subagent-mode.md" \
  ".claude/skills/executing-plans/scripts/task-brief" \
  ".claude/skills/executing-plans/scripts/review-package" \
  ".claude/skills/executing-plans/scripts/sdd-workspace" \
  ".claude/settings.json" \
  ".claude/hooks/dev-flow-gate-guard.sh" \
  ".claude/hooks/dev-flow-finish-guard.sh"; do
  check_file "$f"
done

if node -e "JSON.parse(require('fs').readFileSync('$CONTRACT', 'utf8'))" >/dev/null 2>&1; then
  pass "contract.json parses as valid JSON"
else
  fail "contract.json parses as valid JSON"
fi

for stale_dir in grilling requesting-code-review subagent-driven-development; do
  if [ -e ".claude/skills/$stale_dir" ]; then
    fail "merged-away skill directory still present: .claude/skills/$stale_dir"
  else
    pass "merged-away skill directory absent: $stale_dir"
  fi
done

if [ -f ".claude/settings.json" ] && rg -q 'dev-flow-gate-guard\.sh' ".claude/settings.json" && rg -q 'dev-flow-finish-guard\.sh' ".claude/settings.json"; then
  pass "settings.json registers both dev-flow hooks"
else
  fail "settings.json registers both dev-flow hooks"
fi

scoped_spec_count=0
while IFS= read -r spec_index; do
  scoped_spec_count=$((scoped_spec_count + 1))
  require_pattern "$spec_index" '^## Pre-Development Checklist' "scoped spec has Pre-Development Checklist: $spec_index"
  require_pattern "$spec_index" '^## Quality Check' "scoped spec has Quality Check: $spec_index"
done < <(find .claude/rules/specs -mindepth 2 -maxdepth 2 -name index.md 2>/dev/null | sort)
[ "$scoped_spec_count" -eq 0 ] && pass "no scoped spec index files configured"

if git check-ignore -q ".claude/runtime/sdd/.probe" 2>/dev/null; then
  pass ".claude/runtime is ignored"
else
  fail ".claude/runtime is not ignored"
fi

if git check-ignore -q ".claude/settings.local.json" 2>/dev/null; then
  pass ".claude/settings.local.json is ignored"
else
  fail ".claude/settings.local.json is not ignored"
fi

script_count=0
while IFS= read -r script; do
  script_count=$((script_count + 1))
  check_exec "$script"
done < <({ find .claude/skills -path '*/scripts/*' -type f; find .claude/hooks -type f 2>/dev/null; } | sort)
[ "$script_count" -eq 0 ] && warn "no skill scripts found"

## ---------------------------------------------------------------------
## 一致性：risk-gates.md 与 contract.json 同步、行数预算、单一版本源、无泄漏
## ---------------------------------------------------------------------
printf '\n## 一致性\n\n'

while IFS= read -r label; do
  [ -z "$label" ] && continue
  require_pattern ".claude/skills/dev-flow/references/risk-gates.md" "\`${label}\`" "risk-gates.md documents risk label: ${label}"
done < <(contract_field 'c.risk_labels')

while IFS= read -r line; do
  [ -z "$line" ] && continue
  budget_path=${line%%$'\t'*}
  budget_max=${line##*$'\t'}
  [ "$budget_path" = "per_downstream_skill_max" ] && continue
  if [ ! -f "$budget_path" ]; then
    fail "line budget target missing: $budget_path"
    continue
  fi
  actual=$(wc -l < "$budget_path" | tr -d ' ')
  if [ "$actual" -le "$budget_max" ]; then
    pass "line budget: $budget_path ($actual/$budget_max)"
  else
    fail "line budget exceeded: $budget_path ($actual/$budget_max)"
  fi
done < <(contract_field 'c.line_budgets')

per_skill_max=$(contract_field 'c.line_budgets.per_downstream_skill_max')
while IFS= read -r skill_file; do
  [ -z "$skill_file" ] && continue
  actual=$(wc -l < "$skill_file" | tr -d ' ')
  if [ "$actual" -le "$per_skill_max" ]; then
    pass "line budget: $skill_file ($actual/$per_skill_max)"
  else
    fail "line budget exceeded: $skill_file ($actual/$per_skill_max)"
  fi
done < <(find .claude/skills -mindepth 2 -maxdepth 2 -name SKILL.md ! -path '.claude/skills/dev-flow/*' | sort)

version_output=$(rg -n --glob '!contract.json' -- 'workflow_version:\s*"[0-9]' .claude templates README.md docs 2>/dev/null)
version_status=$?
if [ "$version_status" -eq 1 ]; then
  pass "workflow_version has a single source of truth (contract.json)"
elif [ "$version_status" -eq 0 ]; then
  fail "workflow_version is hardcoded outside contract.json"
  printf '%s\n' "$version_output"
else
  fail "workflow_version single-source check failed to run"
fi

leak_pattern='为当前项目规划时必须使用 Vue|pnpm dev:mock|Cmp-Menu|Cmp-Portal|src/mock|Vue/Vue Router/Pinia API 已自动导入|是否违反 Vue 3|Vue/TS|Vue/TypeScript|Vue 模板|accountType|request\.ts|Vue 性能|placeAnOrder|getProductList'
leak_output=$(rg -n --glob '!vue3.md' --glob '!**/scripts/dev-flow-doctor' -- "$leak_pattern" \
  ".claude/agents" ".claude/commands" ".claude/skills" ".claude/rules" 2>/dev/null)
leak_status=$?
if [ "$leak_status" -eq 1 ]; then
  pass "reusable workflow layer has no known source-project leakage"
elif [ "$leak_status" -eq 0 ]; then
  fail "reusable workflow layer has no known source-project leakage"
  printf '%s\n' "$leak_output"
else
  fail "reusable workflow layer has no known source-project leakage (search failed)"
fi

heavy_pattern='Tr[e]llis|task[.]json|workflow[-]state|jo[u]rnal|auto[-]commit|默认创建[ ]task'
heavy_output=$(rg -n --glob '!**/scripts/dev-flow-doctor' -- "$heavy_pattern" \
  ".claude/agents" ".claude/commands" ".claude/skills" ".claude/rules" "README.md" "docs" "templates" 2>/dev/null)
heavy_status=$?
if [ "$heavy_status" -eq 1 ]; then
  pass "workflow layer does not introduce heavy workflow concepts"
elif [ "$heavy_status" -eq 0 ]; then
  fail "workflow layer does not introduce heavy workflow concepts"
  printf '%s\n' "$heavy_output"
else
  fail "workflow layer does not introduce heavy workflow concepts (search failed)"
fi

forbid_pattern '至少 3 个|找不到就是你失职' \
  "plan-review prompts do not incentivize fabricated findings" \
  ".claude/skills/plan-review/references/review-prompts.md"

if rg -n '^tools: .*"(Write|Edit)"' ".claude/agents/security-reviewer.md" >/dev/null; then
  fail "security-reviewer is not read-only"
  rg -n '^tools: .*"(Write|Edit)"' ".claude/agents/security-reviewer.md"
else
  pass "security-reviewer is read-only"
fi

## ---------------------------------------------------------------------
## 适配层：仅当目标项目已 onboard（存在 project-workflow.md）时检查
## ---------------------------------------------------------------------
printf '\n## 适配层\n\n'

if [ -f ".claude/rules/project-workflow.md" ]; then
  require_pattern ".claude/rules/project-workflow.md" '^dev_flow:' "project-workflow.md has dev_flow config"
  require_pattern ".claude/rules/project-workflow.md" 'retention:' "project-workflow.md has artifact retention config"
  forbid_pattern '<detect|<none\|present>|<false\|true>|<local-config\|repo-governed>|<required-for-L-behavior\|optional\|custom>|<disabled\|enabled>' \
    "project-workflow.md has no unresolved config placeholders" \
    ".claude/rules/project-workflow.md"

  if rg -n '\|\s*test\s*\|[^|]*(dev|watch|serve)|test:\s*.*(dev|watch|serve)' ".claude/rules/project-workflow.md" >/dev/null; then
    warn "project-workflow.md test command looks like a dev/watch command; confirm automated-tests is correct"
  else
    pass "project-workflow.md test command does not look like dev/watch"
  fi
else
  warn "missing .claude/rules/project-workflow.md; this is expected in the source migration package, but target projects should run /onboard-dev-flow"
fi

## ---------------------------------------------------------------------
## 核心不变量：只指向 protocol.md 与 SKILL.md，不再散射到下游技能
## ---------------------------------------------------------------------
printf '\n## 核心不变量\n\n'

require_pattern ".claude/skills/dev-flow/references/protocol.md" 'HUMAN GATE 硬协议' "protocol.md documents HUMAN GATE hard protocol"
require_pattern ".claude/skills/dev-flow/references/protocol.md" '当前回合必须停止' "protocol.md requires stopping the turn on HUMAN GATE/Auto-continue:no"
require_pattern ".claude/skills/dev-flow/references/protocol.md" '不能由实现后的' "protocol.md keeps plan-review from being replaced by code-review"
require_pattern ".claude/skills/dev-flow/references/protocol.md" '\[HANDOFF\]' "protocol.md documents the HANDOFF format"
require_pattern ".claude/skills/dev-flow/references/protocol.md" '资产读取优先级' "protocol.md documents asset read priority"
require_pattern ".claude/skills/dev-flow/references/protocol.md" 'dev_flow_completion:' "protocol.md documents completion.md frontmatter schema"
require_pattern ".claude/skills/dev-flow/SKILL.md" '不可回归的三条底线' "dev-flow SKILL.md states the three non-negotiable baselines"
require_pattern ".claude/skills/dev-flow/SKILL.md" '风险不抬高规模' "dev-flow SKILL.md keeps risk labels from raising scale level"

printf '\nSummary: %s passed, %s warning(s), %s failure(s)\n' "$passes" "$warnings" "$failures"

if [ "$failures" -gt 0 ]; then
  exit 1
fi
