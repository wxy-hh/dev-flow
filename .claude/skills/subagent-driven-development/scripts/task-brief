#!/usr/bin/env bash
# 从实现计划中提取单个任务全文，写入实现者一次性读取的文件。
# 这样控制者不需要把整段任务文本粘贴进上下文。
#
# 用法：task-brief PLAN_FILE TASK_NUMBER [OUTFILE]
# 默认 OUTFILE：<repo-root>/.claude/runtime/sdd/task-<N>-brief.md
# 同一个 worktree 内的并发运行共享该目录。
set -euo pipefail

if [ $# -lt 2 ] || [ $# -gt 3 ]; then
  echo "用法: task-brief PLAN_FILE TASK_NUMBER [OUTFILE]" >&2
  exit 2
fi

plan=$1
n=$2
[ -f "$plan" ] || { echo "计划文件不存在: $plan" >&2; exit 2; }

if [ $# -eq 3 ]; then
  out=$3
else
  dir=$("$(cd "$(dirname "$0")" && pwd)/sdd-workspace")
  out="$dir/task-${n}-brief.md"
fi

awk -v n="$n" '
  /^```/ { infence = !infence }
  !infence && /^#+[ \t]+(Task|任务)[ \t]+[0-9]+/ {
    intask = ($0 ~ ("^#+[ \t]+(Task|任务)[ \t]+" n "([^0-9]|$)"))
  }
  intask { print }
' "$plan" > "$out"

if [ ! -s "$out" ]; then
  echo "未在 ${plan} 中找到任务 ${n}（标题需匹配 'Task ${n}' 或 '任务 ${n}'）" >&2
  exit 3
fi

echo "已写入 ${out}: $(wc -l < "$out" | tr -d ' ') 行"
